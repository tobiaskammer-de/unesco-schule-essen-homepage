---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import {
  fetchCalendar,
  upcomingEvents,
  buildMonth,
  formatEventRange,
  formatDayNum,
  formatMonthShort,
} from "../lib/calendar";
import { getSingle } from "../lib/pageContent";

const page = await getSingle("pageKalender");
const allEvents = await fetchCalendar();
const upcoming = await upcomingEvents();

// Build 3 months worth of views, starting from current month
const today = new Date();
const berlin = new Intl.DateTimeFormat("en-CA", {
  timeZone: "Europe/Berlin",
  year: "numeric",
  month: "2-digit",
}).formatToParts(today);
const curYear = Number(berlin.find((p) => p.type === "year")!.value);
const curMonth0 = Number(berlin.find((p) => p.type === "month")!.value) - 1;

// 14 Monate bauen (–2 vor heute bis +11 danach). Initial sichtbar ist
// der aktuelle Monat; Prev/Next blendet clientseitig um.
const months = [];
for (let offset = -2; offset < 12; offset++) {
  let y = curYear;
  let m = curMonth0 + offset;
  while (m > 11) { m -= 12; y += 1; }
  while (m < 0) { m += 12; y -= 1; }
  months.push(buildMonth(y, m, allEvents));
}
const currentIndex = 2; // Index des „heute"-Monats in der obigen Liste

const WEEKDAYS = ["Mo", "Di", "Mi", "Do", "Fr", "Sa", "So"];

const lastUpdated = new Intl.DateTimeFormat("de-DE", {
  day: "numeric",
  month: "long",
  year: "numeric",
  hour: "2-digit",
  minute: "2-digit",
  timeZone: "Europe/Berlin",
}).format(today);
---
<BaseLayout title="Kalender — UNESCO-Schule Essen">
<style is:global>
  /* ---------- Kalender ---------- */
  .kl-intro{background:var(--creme);padding:var(--space-section) 0;}
  .kl-intro-grid{
    display:grid;grid-template-columns:minmax(0,5fr) minmax(0,7fr);
    gap:48px;align-items:end;
  }
  .kl-intro h2{
    font-family:var(--serif);font-weight:500;
    font-size:clamp(28px,3vw,40px);line-height:1.1;
    color:var(--petrol);letter-spacing:-0.015em;margin:0;
  }
  .kl-intro p{
    font-family:var(--sans);font-size:16.5px;line-height:1.7;color:var(--tinte);
    margin:0 0 14px;
  }
  .kl-intro .meta{
    font-family:var(--sans);font-size:13px;color:var(--stein);
    letter-spacing:0.04em;display:inline-flex;align-items:center;gap:8px;
    padding:6px 14px;border:1px solid var(--hairline);background:#fff;
    border-radius:999px;
  }
  .kl-intro .meta .dot{width:6px;height:6px;border-radius:50%;background:var(--sage);}

  /* Legend */
  .kl-legend{
    display:flex;flex-wrap:wrap;gap:16px;margin-top:18px;
  }
  .kl-legend .item{
    display:inline-flex;align-items:center;gap:8px;
    font-family:var(--sans);font-size:13px;color:var(--tinte);
  }
  .kl-legend .swatch{
    width:12px;height:12px;border-radius:2px;
    background:var(--petrol);display:inline-block;
  }
  .kl-legend .swatch.highlight{background:var(--bordeaux);}
  .kl-legend .swatch.exam{background:var(--gold);}
  .kl-legend .swatch.holiday{background:var(--sage);}

  /* Months */
  .kl-months{background:var(--offwhite);padding:var(--space-section) 0;border-top:1px solid var(--hairline);}
  .kl-month{
    display:none;
  }
  .kl-month.is-visible{display:block;}
  .kl-nav{
    display:flex;align-items:center;justify-content:space-between;
    gap:16px;flex-wrap:wrap;margin-bottom:24px;
  }
  .kl-nav-title{
    display:flex;align-items:baseline;gap:18px;flex-wrap:wrap;
  }
  .kl-nav-title h3{
    font-family:var(--serif);font-weight:500;
    font-size:clamp(28px,3vw,42px);line-height:1.1;letter-spacing:-0.02em;
    color:var(--petrol);margin:0;
    text-transform:capitalize;
  }
  .kl-nav-title .count{
    font-family:var(--sans);font-size:13px;color:var(--stein);letter-spacing:0.04em;
  }
  .kl-nav-buttons{
    display:inline-flex;align-items:stretch;gap:0;
    border:1px solid var(--hairline);background:#fff;
  }
  .kl-nav-btn{
    background:transparent;border:0;cursor:pointer;
    font-family:var(--sans);font-size:14px;font-weight:500;color:var(--petrol);
    padding:10px 16px;display:inline-flex;align-items:center;gap:8px;
    transition:background var(--transition-fast), color var(--transition-fast);
  }
  .kl-nav-btn:hover:not(:disabled){background:var(--creme);}
  .kl-nav-btn:disabled{color:rgba(14,77,79,0.3);cursor:not-allowed;}
  .kl-nav-btn.kl-today{
    border-left:1px solid var(--hairline);
    border-right:1px solid var(--hairline);
    background:var(--creme);font-weight:600;
  }
  .kl-nav-btn.kl-today:hover:not(:disabled){background:var(--petrol);color:var(--creme);}
  .kl-nav-btn .icon{font-size:16px;line-height:1;}
  .kl-grid{
    display:grid;grid-template-columns:repeat(7, minmax(0, 1fr));
    background:var(--hairline);
    border:1px solid var(--hairline);
  }
  .kl-grid .weekday{
    background:var(--creme);padding:10px 8px;text-align:center;
    font-family:var(--sans);font-size:11px;font-weight:600;
    letter-spacing:0.14em;text-transform:uppercase;color:var(--petrol);
  }
  .kl-grid .weekday.we{color:var(--bordeaux);}
  .kl-day{
    background:#fff;
    min-height:112px;padding:8px 10px;
    display:flex;flex-direction:column;gap:6px;
    position:relative;
  }
  .kl-day.out{background:var(--offwhite);color:rgba(0,0,0,0.4);}
  .kl-day .num{
    font-family:var(--serif);font-weight:500;font-size:20px;line-height:1;
    color:var(--petrol);letter-spacing:-0.015em;
    font-variant-numeric:tabular-nums;
  }
  .kl-day.out .num{color:rgba(14,77,79,0.35);}
  .kl-day.we .num{color:var(--bordeaux);}
  .kl-day.today{background:var(--creme);}
  .kl-day.today .num{
    display:inline-flex;align-items:center;justify-content:center;
    width:28px;height:28px;border-radius:50%;
    background:var(--bordeaux);color:var(--creme);font-size:15px;
    font-variant-numeric:tabular-nums;
  }
  .kl-evlist{display:flex;flex-direction:column;gap:3px;margin-top:2px;}
  .kl-event{
    display:block;
    font-family:var(--sans);font-size:11.5px;line-height:1.3;
    padding:3px 6px;border-radius:2px;
    background:var(--petrol);color:var(--creme);
    white-space:nowrap;overflow:hidden;text-overflow:ellipsis;
    border-left:2px solid transparent;
  }
  .kl-event.highlight{background:var(--bordeaux);}
  .kl-event.exam{background:var(--gold);color:#2a1d08;}
  .kl-event.holiday{background:rgba(127,176,105,0.22);color:#3e6b2a;border-left-color:var(--sage);}
  .kl-event.more{background:transparent;color:var(--stein);padding:2px 4px;font-size:11px;font-weight:500;}

  /* Upcoming list */
  .kl-list{background:var(--creme);padding:var(--space-section) 0;border-top:1px solid var(--hairline);}
  .kl-list .head{max-width:820px;margin:0 0 40px;}
  .kl-list .head .eyebrow{display:block;margin-bottom:14px;}
  .kl-list .head h2{
    font-family:var(--serif);font-weight:500;
    font-size:clamp(30px,3.2vw,44px);line-height:1.15;letter-spacing:-0.015em;
    color:var(--petrol);margin:0 0 10px;
  }
  .kl-list .head p{
    font-family:var(--sans);font-size:16.5px;line-height:1.65;color:var(--stein);margin:0;
  }
  .kl-items{
    list-style:none;margin:0;padding:0;
    background:#fff;border:1px solid var(--hairline);
    border-top:var(--card-accent-width) solid var(--petrol);
  }
  .kl-item{
    display:grid;grid-template-columns:minmax(0,110px) minmax(0,1fr) minmax(0,140px);
    gap:24px;align-items:center;
    padding:20px 28px;border-bottom:1px solid var(--hairline);
  }
  .kl-item:last-child{border-bottom:0;}
  .kl-item .date{
    font-family:var(--serif);font-weight:500;font-size:26px;line-height:1;
    color:var(--petrol);letter-spacing:-0.012em;font-variant-numeric:tabular-nums;
  }
  .kl-item .date small{
    display:block;font-family:var(--sans);font-size:12px;color:var(--stein);
    font-weight:500;letter-spacing:0.08em;text-transform:uppercase;margin-top:4px;
  }
  .kl-item .title{
    font-family:var(--sans);font-weight:500;font-size:16px;line-height:1.4;color:var(--tinte);margin:0;
  }
  .kl-item .title em{font-style:italic;color:var(--stein);font-weight:400;}
  .kl-item .tag{
    justify-self:end;
    font-family:var(--sans);font-size:11px;font-weight:500;
    letter-spacing:0.1em;text-transform:uppercase;
    padding:4px 10px;background:var(--creme);color:var(--petrol);
  }
  .kl-item .tag.highlight{background:var(--bordeaux);color:var(--creme);}
  .kl-item .tag.exam{background:var(--gold);color:#2a1d08;}
  .kl-item .tag.holiday{background:rgba(127,176,105,0.22);color:#3e6b2a;}

  .kl-empty{
    padding:48px 28px;text-align:center;
    font-family:var(--sans);color:var(--stein);font-size:16px;
  }

  @media (max-width:960px){
    .kl-intro-grid{grid-template-columns:1fr;gap:24px;}
    .kl-day{min-height:80px;padding:6px 7px;}
    .kl-day .num{font-size:16px;}
    .kl-event{font-size:10px;padding:2px 4px;}
    .kl-item{grid-template-columns:80px 1fr;gap:14px;padding:16px 20px;}
    .kl-item .tag{grid-column:2;justify-self:start;}
    .kl-item .date{font-size:20px;}
  }
  @media (max-width:640px){
    .kl-grid .weekday{font-size:10px;padding:6px 4px;letter-spacing:0.08em;}
    .kl-day{min-height:68px;cursor:pointer;padding:6px 4px;}
    .kl-day .num{font-size:14px;}
    .kl-evlist{gap:2px;}
    /* Eingeklappt: Events sind farbige Streifen */
    .kl-event{font-size:0;line-height:0;height:4px;padding:0;border-radius:2px;}
    .kl-event.more{display:none;}
    /* Tap-to-expand: Tag voll sichtbar, Events wieder lesbar */
    .kl-day.is-open{
      min-height:auto;
      box-shadow:0 0 0 2px var(--petrol);z-index:2;position:relative;
      grid-column:1 / -1;
    }
    .kl-day.is-open .kl-evlist{gap:4px;}
    .kl-day.is-open .kl-event{
      font-size:12.5px;line-height:1.3;height:auto;padding:4px 8px;white-space:normal;
    }
    .kl-day.is-open .kl-event.more{display:block;}
    .kl-day.is-open .num{font-size:22px;margin-bottom:4px;}
  }
  @media (max-width:400px){
    /* Navigation + Wochentage kompakter, mehr Inhaltsraum */
    .kl-nav{flex-direction:column;align-items:flex-start;gap:12px;}
    .kl-nav-buttons{align-self:stretch;}
    .kl-nav-btn{flex:1;justify-content:center;padding:12px 8px;}
    .kl-day{min-height:56px;padding:5px 3px;}
    .kl-day .num{font-size:13px;}
    .kl-grid .weekday{font-size:9.5px;letter-spacing:0.04em;padding:6px 2px;}
    /* Kl-items (Listenansicht): noch knapper */
    .kl-item{padding:14px 16px;gap:10px;}
  }
</style>

<main id="top">

<PageHero variant="feature">
  <Fragment slot="eyebrow">{page.hero.eyebrow}</Fragment>
  <Fragment slot="title">{page.hero.title}{page.hero.titleHighlight && <> <em>{page.hero.titleHighlight}</em></>}</Fragment>
  <Fragment slot="lede">{page.hero.lede}</Fragment>
</PageHero>

<section class="kl-intro" aria-label="Legende und Hinweise">
  <div class="container">
    <div class="kl-intro-grid">
      <div>
        <h2>Immer aktuell —<br>direkt aus unserem Google-Kalender.</h2>
      </div>
      <div>
        <p>Der Kalender unten wird automatisch aus unserem zentralen Schulkalender gespeist und einmal täglich aktualisiert. Ändert sich ein Termin, landet er hier — ohne dass jemand die Website anfassen muss.</p>
        <span class="meta"><span class="dot"></span>Zuletzt aktualisiert: {lastUpdated}&nbsp;Uhr</span>
        <div class="kl-legend" aria-label="Farbkodierung">
          <span class="item"><span class="swatch"></span>Regulärer Termin</span>
          <span class="item"><span class="swatch highlight"></span>Besonderer Termin</span>
          <span class="item"><span class="swatch exam"></span>Prüfung / Klausur</span>
          <span class="item"><span class="swatch holiday"></span>Ferien / schulfrei</span>
        </div>
      </div>
    </div>
  </div>
</section>

<section class="kl-months" aria-label="Monatsansicht">
  <div class="container">
    <div class="kl-nav" role="navigation" aria-label="Monatsnavigation">
      <div class="kl-nav-title">
        <h3 id="klNavLabel">{months[currentIndex].monthLabel}</h3>
        <span class="count" id="klNavCount"></span>
      </div>
      <div class="kl-nav-buttons">
        <button type="button" class="kl-nav-btn" id="klPrev" aria-label="Vorheriger Monat">
          <span class="icon" aria-hidden="true">‹</span> Zurück
        </button>
        <button type="button" class="kl-nav-btn kl-today" id="klToday" aria-label="Zum aktuellen Monat springen">
          Heute
        </button>
        <button type="button" class="kl-nav-btn" id="klNext" aria-label="Nächster Monat">
          Weiter <span class="icon" aria-hidden="true">›</span>
        </button>
      </div>
    </div>

    {months.map((m, mIdx) => {
      const inMonthCount = m.days.filter((d) => d.inMonth && d.events.length).length;
      return (
        <div
          class={`kl-month ${mIdx === currentIndex ? "is-visible" : ""}`}
          data-month-index={mIdx}
          data-month-label={m.monthLabel}
          data-month-count={inMonthCount}
        >
          <div class="kl-grid" role="grid" aria-label={`Kalender ${m.monthLabel}`}>
            {WEEKDAYS.map((wd, i) => (
              <div class={`weekday ${i >= 5 ? "we" : ""}`}>{wd}</div>
            ))}
            {m.days.map((d, idx) => {
              const weekdayIdx = idx % 7;
              const isWeekend = weekdayIdx >= 5;
              const maxVisible = 3;
              const visible = d.events.slice(0, maxVisible);
              const rest = d.events.length - visible.length;
              return (
                <div class={`kl-day ${d.inMonth ? "" : "out"} ${isWeekend ? "we" : ""}`} data-iso={d.iso}>
                  <span class="num">{d.day}</span>
                  {visible.length > 0 && (
                    <div class="kl-evlist">
                      {visible.map((e) => (
                        <span class={`kl-event ${e.category}`} title={e.title}>{e.title}</span>
                      ))}
                      {rest > 0 && (
                        <span class="kl-event more">+{rest} weitere</span>
                      )}
                    </div>
                  )}
                </div>
              );
            })}
          </div>
        </div>
      );
    })}
  </div>
</section>

<script is:inline define:vars={{ serverCurrentIndex: currentIndex, totalMonths: months.length }}>
  (function(){
    // Clientseitig echtes "heute" in Berliner Zeit bestimmen — nicht Build-Zeit.
    var todayISO = new Date().toLocaleDateString('en-CA', { timeZone: 'Europe/Berlin' });

    // 1) .today-Markierung auf den aktuellen Tag setzen (alte vom Build entfernen)
    document.querySelectorAll('.kl-day').forEach(function(d){
      var iso = d.getAttribute('data-iso');
      var inMonth = !d.classList.contains('out');
      d.classList.toggle('today', inMonth && iso === todayISO);
    });

    // 2) Aktuellen Monat-Index aus tatsächlichem Heute ableiten
    var currentIndex = serverCurrentIndex;
    var months = document.querySelectorAll('.kl-month');
    for (var i = 0; i < months.length; i++){
      var todayCell = months[i].querySelector('.kl-day.today');
      if (todayCell){ currentIndex = i; break; }
    }

    // 3) Veraltete Termine in der Listenansicht ausblenden
    var countVisible = 0;
    document.querySelectorAll('.kl-item[data-end-date]').forEach(function(li){
      if (li.getAttribute('data-end-date') < todayISO){
        li.style.display = 'none';
      } else {
        countVisible++;
      }
    });
    var listHeadCount = document.querySelector('.kl-list .head p');
    if (listHeadCount){
      listHeadCount.textContent = 'Chronologisch sortiert — ab heute und in die Zukunft. Insgesamt ' + countVisible + ' Einträge.';
    }

    var idx = currentIndex;
    var label = document.getElementById('klNavLabel');
    var count = document.getElementById('klNavCount');
    var prev = document.getElementById('klPrev');
    var next = document.getElementById('klNext');
    var today = document.getElementById('klToday');
    var all = document.querySelectorAll('.kl-month');

    function show(i){
      if (i < 0 || i >= totalMonths) return;
      idx = i;
      all.forEach(function(el){
        var mi = parseInt(el.getAttribute('data-month-index'), 10);
        el.classList.toggle('is-visible', mi === idx);
      });
      var current = all[idx];
      if (label) label.textContent = current.getAttribute('data-month-label') || '';
      var c = parseInt(current.getAttribute('data-month-count') || '0', 10);
      if (count) count.textContent = c === 0 ? 'Keine Termine' : c + ' Tag' + (c === 1 ? '' : 'e') + ' mit Terminen';
      if (prev) prev.disabled = (idx <= 0);
      if (next) next.disabled = (idx >= totalMonths - 1);
      if (today) today.disabled = (idx === currentIndex);
    }

    // Wenn der aktuell sichtbare Monat nicht mehr der aktuelle ist, auf Heute umschalten
    if (currentIndex !== serverCurrentIndex){
      show(currentIndex);
    }

    prev && prev.addEventListener('click', function(){ show(idx - 1); });
    next && next.addEventListener('click', function(){ show(idx + 1); });
    today && today.addEventListener('click', function(){ show(currentIndex); });

    // Tag tappen auf Mobile: Events expandieren (nur bei Tagen mit Events)
    document.querySelectorAll('.kl-day').forEach(function(day){
      if (!day.querySelector('.kl-event')) return;
      day.addEventListener('click', function(){
        var wasOpen = day.classList.contains('is-open');
        document.querySelectorAll('.kl-day.is-open').forEach(function(o){ o.classList.remove('is-open'); });
        if (!wasOpen) day.classList.add('is-open');
      });
    });

    // Keyboard-Navigation
    document.addEventListener('keydown', function(e){
      if (e.target && (e.target.tagName === 'INPUT' || e.target.tagName === 'TEXTAREA')) return;
      if (e.key === 'ArrowLeft')  { e.preventDefault(); show(idx - 1); }
      if (e.key === 'ArrowRight') { e.preventDefault(); show(idx + 1); }
    });

    show(idx);
  })();
</script>

<section class="kl-list" aria-label="Liste aller kommenden Termine">
  <div class="container">
    <div class="head">
      <span class="eyebrow">Listenansicht</span>
      <h2>Alle kommenden Termine.</h2>
      <p>Chronologisch sortiert — ab heute und in die Zukunft. Insgesamt {upcoming.length} Einträge.</p>
    </div>

    {upcoming.length === 0 ? (
      <p class="kl-empty">Derzeit sind keine zukünftigen Termine hinterlegt.</p>
    ) : (
      <ul class="kl-items">
        {upcoming.slice(0, 80).map((e) => (
          <li class="kl-item" data-end-date={e.endDate}>
            <div class="date">
              {formatDayNum(e.startDate)}&nbsp;{formatMonthShort(e.startDate)}
              <small>{new Intl.DateTimeFormat("de-DE", { weekday: "long", timeZone: "Europe/Berlin" }).format(new Date(e.startDate + "T12:00:00Z"))}</small>
            </div>
            <div class="title">
              {e.title}
              {e.isMultiDay && <em> · bis {formatDayNum(e.endDate)}&nbsp;{formatMonthShort(e.endDate)}</em>}
            </div>
            <span class={`tag ${e.category}`}>
              {e.category === "exam" ? "Prüfung" :
               e.category === "highlight" ? "Besonders" :
               e.category === "holiday" ? "Ferien" : "Termin"}
            </span>
          </li>
        ))}
      </ul>
    )}
  </div>
</section>

</main>
</BaseLayout>

---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";

// Unterrichts- und Pausenzeiten (Quelle: Schul-ABC)
const schedule = [
  { label: "1. Stunde", time: "08:05 – 08:50", kind: "lesson" },
  { label: "2. Stunde", time: "08:55 – 09:40", kind: "lesson" },
  { label: "1. Große Pause", time: "09:40 – 10:00", kind: "break" },
  { label: "3. Stunde", time: "10:00 – 10:45", kind: "lesson" },
  { label: "4. Stunde", time: "10:50 – 11:35", kind: "lesson" },
  { label: "2. Große Pause", time: "11:35 – 11:55", kind: "break" },
  { label: "5. Stunde", time: "11:55 – 12:40", kind: "lesson" },
  { label: "6. Stunde", time: "12:45 – 13:30", kind: "lesson" },
];

// FAQ-Blöcke
const faqs = [
  {
    q: "Warum der Name UNESCO?",
    a: "Als Weltkulturorganisation tritt die UNESCO für Toleranz, Verantwortung und ein friedliches Miteinander ein — genau die Werte, die wir täglich leben. Deshalb erteilte uns die UNESCO-Kommission die Erlaubnis, diesen Namen zu führen.",
  },
  {
    q: "Welche Fremdsprachen werden angeboten?",
    a: "Ab Klasse 5 beginnt der Unterricht in Englisch. In Klasse 7 kommt Latein als zweite Fremdsprache hinzu, und ab Klasse 9 können die Lernenden Französisch als dritte Fremdsprache wählen.",
  },
  {
    q: "Wie kann ich mein Kind / mich an der UNESCO-Schule anmelden?",
    a: 'Jeder Anmeldung geht ein persönliches Beratungs- und Informationsgespräch voraus. Nehmen Sie hierfür einfach Kontakt mit dem Sekretariat auf. Weitere Informationen finden Sie unter dem Menüpunkt „Anmeldung".',
    link: { label: "Zur Anmeldung", href: "Anmeldung.html" },
  },
  {
    q: "Gibt es eine verlässliche Nachmittagsbetreuung?",
    a: "Ja. Der Unterricht endet in der Regel um 13:30 Uhr, doch auf Wunsch können Kinder täglich bis 15:00 Uhr in unserer betreuten Lern- und Freizeitgruppe bleiben. Dort gibt es Hausaufgabenhilfe, kreative Angebote und Bewegungszeiten.",
  },
  {
    q: "Wie ist die Schule digital ausgestattet?",
    a: 'Alle Klassenräume verfügen über interaktive Displays und WLAN. Ab Klasse 6 arbeiten die Schülerinnen und Schüler regelmäßig mit schuleigenen Tablets, programmieren in der „Hacker School" und lernen einen verantwortungsvollen Umgang mit digitalen Medien.',
  },
  {
    q: "Welche Kurse sind in der Oberstufe wählbar?",
    a: `In der Oberstufe belegbar sind:\n\n**Sprachlich – literarisch – künstlerisch:** Deutsch, Englisch, Latein, Französisch, Kunst.\n\n**Gesellschaftswissenschaftlich:** Literatur, Erdkunde, Geschichte, Sozialwissenschaften, Philosophie, Pädagogik.\n\n**Mathematisch-naturwissenschaftlich:** Mathematik, Biologie, Chemie, Physik.\n\n**Darüber hinaus:** Religionslehre und Sport.`,
    link: { label: "Zur Oberstufe", href: "Oberstufe.html" },
  },
  {
    q: "Welche Leistungskurse sind in der Oberstufe wählbar?",
    a: `Aktuell belegbare LKs:\n\n**Sprachlich – literarisch – künstlerisch:** Deutsch, Englisch.\n\n**Gesellschaftswissenschaftlich:** Geschichte, Sozialwissenschaften, Philosophie.\n\n**Mathematisch-naturwissenschaftlich:** Mathematik, Biologie, Chemie, Physik.\n\nFür Fragen zu möglichen Fächerkombinationen vereinbaren Sie gern einen Beratungstermin mit unserem Oberstufenteam.`,
  },
  {
    q: "Wie sieht ein Schultag aus? Wie lange geht der Unterricht?",
    a: "Der Unterricht beginnt um 08:05 Uhr. Je nach Klassenstufe dauert ein Schultag bis ca. 13:30 Uhr. Für Klassen der Erprobungs- und Mittelstufe bieten wir eine Übermittagsbetreuung bis 15:00 Uhr an.",
  },
  {
    q: "Wird an der UNESCO-Schule Mittagessen angeboten?",
    a: "Ja. Unsere Mensa serviert jeden Schultag ein frisch gekochtes, warmes Mittagessen, das ein erfahrener Caterer zubereitet. Für den kleinen Hunger zwischendurch steht zusätzlich ein schuleigener Kiosk mit belegten Brötchen, Obst, Snacks und Getränken bereit.",
  },
  {
    q: "Gibt es AGs, die man belegen kann?",
    a: "Ja! Jedes Schuljahr werden an der Schule unterschiedliche Arbeitsgemeinschaften angeboten — von Schulsanitätsdienst über Sprach-AGs bis zum Makerspace.",
    link: { label: "Aktuelle AGs ansehen", href: "Arbeitsgemeinschaften.html" },
  },
];
---
<BaseLayout title="Informationen für Eltern — UNESCO-Schule Essen" description="Alle wichtigen Infos für Eltern auf einen Blick: FAQs, Schul-ABC, Unterrichtszeiten und Kontakt.">
<style is:global>
  /* ---------- Eltern-Infos ---------- */
  .el-intro{background:var(--creme);padding:var(--space-section) 0;}
  .el-intro-grid{
    display:grid;grid-template-columns:minmax(0,5fr) minmax(0,7fr);
    gap:56px;align-items:start;
  }
  .el-intro h2{
    font-family:var(--serif);font-weight:500;
    font-size:clamp(30px,3.4vw,44px);line-height:1.1;
    color:var(--petrol);letter-spacing:-0.015em;margin:0;
  }
  .el-intro h2 em{font-style:italic;color:var(--bordeaux);}
  .el-intro p{
    font-family:var(--sans);font-size:17px;line-height:1.7;color:var(--tinte);
    margin:0 0 16px;
  }

  /* Downloads */
  .el-downloads{background:var(--offwhite);padding:var(--space-section) 0;border-top:1px solid var(--hairline);}
  .el-downloads .head{max-width:820px;margin:0 0 40px;}
  .el-downloads .head .eyebrow{display:block;margin-bottom:14px;}
  .el-downloads .head h2{
    font-family:var(--serif);font-weight:500;
    font-size:clamp(28px,3vw,40px);line-height:1.15;letter-spacing:-0.015em;
    color:var(--petrol);margin:0 0 14px;
  }
  .el-downloads .head p{
    font-family:var(--sans);font-size:16.5px;line-height:1.65;color:var(--stein);max-width:640px;margin:0;
  }
  .el-dl-grid{
    display:grid;grid-template-columns:repeat(2, minmax(0, 1fr));gap:24px;
  }
  .el-dl{
    display:grid;grid-template-columns:72px 1fr auto;gap:22px;align-items:center;
    background:#fff;border:1px solid var(--hairline);
    border-left:var(--card-accent-width) solid var(--petrol);
    padding:28px 30px;
    text-decoration:none;color:inherit;
    transition:transform var(--transition), box-shadow var(--transition);
  }
  .el-dl:hover{transform:translateY(-2px);box-shadow:0 16px 40px -24px rgba(14,77,79,0.28);}
  @media (prefers-reduced-motion: reduce){.el-dl:hover{transform:none;}}
  .el-dl .icon{
    width:72px;height:72px;border-radius:50%;
    background:rgba(14,77,79,0.08);color:var(--petrol);
    display:flex;align-items:center;justify-content:center;
  }
  .el-dl.gold .icon{background:rgba(212,165,116,0.2);color:#8a5a20;}
  .el-dl .icon svg{width:28px;height:28px;stroke:currentColor;fill:none;stroke-width:1.8;}
  .el-dl .info{display:flex;flex-direction:column;gap:4px;}
  .el-dl .kicker{
    font-family:var(--sans);font-size:11px;font-weight:600;
    letter-spacing:0.14em;text-transform:uppercase;color:var(--petrol);
  }
  .el-dl.gold .kicker{color:#8a5a20;}
  .el-dl h3{
    font-family:var(--serif);font-weight:500;font-size:22px;line-height:1.2;
    color:var(--petrol);letter-spacing:-0.008em;margin:0;
  }
  .el-dl p{
    font-family:var(--sans);font-size:14.5px;line-height:1.55;color:var(--stein);margin:2px 0 0;
  }
  .el-dl .meta{
    font-family:var(--sans);font-size:12px;font-weight:500;color:var(--stein);
    letter-spacing:0.04em;
    padding:7px 12px;background:var(--creme);
    border:1px solid var(--hairline);
    display:inline-flex;align-items:center;gap:6px;white-space:nowrap;
  }

  /* Schedule */
  .el-schedule{background:var(--creme);padding:var(--space-section) 0;border-top:1px solid var(--hairline);}
  .el-schedule .head{max-width:820px;margin:0 0 40px;}
  .el-schedule .head .eyebrow{display:block;margin-bottom:14px;}
  .el-schedule .head h2{
    font-family:var(--serif);font-weight:500;
    font-size:clamp(28px,3vw,40px);line-height:1.15;letter-spacing:-0.015em;
    color:var(--petrol);margin:0 0 14px;
  }
  .el-schedule .head p{
    font-family:var(--sans);font-size:16.5px;line-height:1.65;color:var(--stein);max-width:640px;margin:0;
  }
  .sched-table{
    background:#fff;border:1px solid var(--hairline);
    border-top:var(--card-accent-width) solid var(--petrol);
    max-width:640px;font-variant-numeric:tabular-nums;
  }
  .sched-row{
    display:grid;grid-template-columns:minmax(0,1fr) minmax(0,1fr);
    border-bottom:1px solid var(--hairline);
  }
  .sched-row:last-child{border-bottom:0;}
  .sched-row .lbl{
    padding:14px 22px;font-family:var(--sans);font-weight:500;font-size:15px;color:var(--tinte);
  }
  .sched-row .time{
    padding:14px 22px;font-family:var(--sans);font-size:15px;color:var(--stein);
    border-left:1px solid var(--hairline);
  }
  .sched-row.break{
    background:var(--creme);
  }
  .sched-row.break .lbl{
    color:var(--petrol);font-weight:600;font-size:13px;
    letter-spacing:0.1em;text-transform:uppercase;
  }
  .sched-row.break .time{color:var(--petrol);font-weight:500;}

  /* FAQ */
  .el-faq{background:var(--offwhite);padding:var(--space-section) 0;border-top:1px solid var(--hairline);}
  .el-faq .head{max-width:820px;margin:0 0 40px;}
  .el-faq .head .eyebrow{display:block;margin-bottom:14px;}
  .el-faq .head h2{
    font-family:var(--serif);font-weight:500;
    font-size:clamp(30px,3.2vw,44px);line-height:1.15;letter-spacing:-0.015em;
    color:var(--petrol);margin:0 0 14px;
  }
  .el-faq .head p{
    font-family:var(--sans);font-size:16.5px;line-height:1.65;color:var(--stein);max-width:640px;margin:0;
  }

  .faq-list{
    display:flex;flex-direction:column;gap:12px;
  }
  .faq-item{
    background:#fff;border:1px solid var(--hairline);
    transition:border-color var(--transition-fast);
  }
  .faq-item[open]{border-color:var(--petrol);}
  .faq-item summary{
    list-style:none;cursor:pointer;
    display:grid;grid-template-columns:1fr auto;gap:20px;align-items:center;
    padding:20px 26px;
    font-family:var(--serif);font-weight:500;font-size:18px;line-height:1.35;
    color:var(--petrol);letter-spacing:-0.005em;
  }
  .faq-item summary::-webkit-details-marker{display:none;}
  .faq-item summary::after{
    content:"";display:inline-block;width:10px;height:10px;
    border-right:1.6px solid var(--petrol);border-bottom:1.6px solid var(--petrol);
    transform:rotate(45deg) translate(-2px,-2px);
    transition:transform .25s ease;
  }
  .faq-item[open] summary::after{
    transform:rotate(-135deg) translate(-4px,-4px);
  }
  .faq-item summary:hover{color:var(--petrol-dark);}
  .faq-item .answer{
    padding:0 26px 22px;
    font-family:var(--sans);font-size:15.5px;line-height:1.7;color:var(--tinte);
  }
  .faq-item .answer p{margin:0 0 14px;}
  .faq-item .answer p:last-child{margin-bottom:0;}
  .faq-item .answer strong{color:var(--petrol);}
  .faq-item .answer a.inline{
    color:var(--bordeaux);text-decoration:underline;text-underline-offset:3px;
    text-decoration-thickness:1px;font-weight:500;
  }
  .faq-item .answer a.inline:hover{color:var(--petrol-dark);}
  .faq-item .followup{
    margin-top:12px;display:inline-flex;align-items:center;gap:6px;
    padding:8px 14px;background:var(--creme);border:1px solid var(--hairline);
    font-family:var(--sans);font-size:13.5px;font-weight:500;color:var(--petrol);
    text-decoration:none;
  }
  .faq-item .followup:hover{background:var(--petrol);color:var(--creme);border-color:var(--petrol);}

  /* CTA */
  .el-cta{background:var(--petrol);color:var(--creme);padding:var(--space-section) 0;border-top:1px solid var(--hairline);}
  .el-cta .container{max-width:860px;text-align:center;}
  .el-cta .eyebrow{color:rgba(245,239,231,0.55);display:block;margin-bottom:14px;}
  .el-cta h2{
    font-family:var(--serif);font-weight:500;font-style:italic;
    font-size:clamp(28px,3.2vw,44px);line-height:1.2;
    color:var(--creme);letter-spacing:-0.015em;margin:0 0 22px;
  }
  .el-cta h2 em{color:var(--gold);font-style:italic;}
  .el-cta p{
    font-family:var(--sans);font-size:17px;line-height:1.7;
    color:rgba(245,239,231,0.9);max-width:640px;margin:0 auto 28px;
  }
  .el-cta .actions{display:flex;gap:14px;flex-wrap:wrap;justify-content:center;}
  .el-cta .btn-primary{background:var(--gold);color:#2a1d08;border-color:var(--gold);}
  .el-cta .btn-primary:hover{background:#e0b68a;color:#2a1d08;}
  .el-cta .btn-secondary{background:transparent;color:var(--creme);border-color:rgba(245,239,231,0.35);}
  .el-cta .btn-secondary:hover{background:rgba(245,239,231,0.1);color:var(--creme);}

  @media (max-width:960px){
    .el-intro-grid{grid-template-columns:1fr;gap:28px;}
    .el-dl-grid{grid-template-columns:1fr;gap:16px;}
    .el-dl{grid-template-columns:56px 1fr;padding:22px 24px;gap:16px;}
    .el-dl .icon{width:56px;height:56px;}
    .el-dl .icon svg{width:22px;height:22px;}
    .el-dl .meta{grid-column:1 / -1;justify-self:start;}
    .el-intro,.el-downloads,.el-schedule,.el-faq,.el-cta{padding:var(--space-section-sm) 0;}
  }
  @media (max-width:640px){
    .faq-item summary{padding:16px 20px;font-size:16.5px;}
    .faq-item .answer{padding:0 20px 18px;font-size:15px;}
  }
</style>

<main id="top">

<PageHero variant="feature">
  <Fragment slot="eyebrow">Informieren · Für Eltern</Fragment>
  <Fragment slot="title">Schule verstehen —<br>bevor das Kind sie <em>erklärt.</em></Fragment>
  <Fragment slot="lede">Alle Antworten, die wir in Anmeldegesprächen immer wieder geben — gesammelt, sortiert, zum Nachlesen. Plus zwei kompakte PDFs für zuhause.</Fragment>
</PageHero>

<section class="el-intro" aria-label="Einordnung">
  <div class="container">
    <div class="el-intro-grid">
      <div>
        <h2>Die Fragen, die wir <em>am häufigsten</em> hören.</h2>
      </div>
      <div>
        <p>Wie lang ist ein Schultag? Was heißt eigentlich „UNESCO-Projektschule"? Gibt es Betreuung nach der sechsten Stunde? Welche Sprachen lernt mein Kind? — In jedem Infogespräch kommen dieselben Themen wieder.</p>
        <p>Deshalb haben wir sie hier versammelt. Kurz, klar, verlinkt mit den passenden Seiten. Fehlt Ihre Frage: Sekretariat anrufen unter <a href="tel:+492012802630" style="color:var(--bordeaux);text-decoration:underline;text-underline-offset:3px;font-weight:500;">0201&nbsp;·&nbsp;280&nbsp;26&nbsp;30</a> oder <a href="Kontakt.html" style="color:var(--bordeaux);text-decoration:underline;text-underline-offset:3px;font-weight:500;">Nachricht schreiben</a> — wir rufen zurück.</p>
      </div>
    </div>
  </div>
</section>

<section class="el-downloads" aria-label="Informationen zum Download">
  <div class="container">
    <div class="head">
      <span class="eyebrow">Zum Mitnehmen</span>
      <h2>Zwei Broschüren für den Einstieg.</h2>
      <p>Das Schul-ABC beantwortet die Alltagsfragen von Tag&nbsp;1. Die Orientierungshilfe zeigt, wo was im Gebäude ist — damit die ersten Wochen leichter werden.</p>
    </div>

    <div class="el-dl-grid">
      <a href="assets/eltern/UNESCO-Schule-Essen_Schul-ABC.pdf" class="el-dl" download>
        <span class="icon" aria-hidden="true">
          <svg viewBox="0 0 24 24"><path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z" stroke-linecap="round" stroke-linejoin="round"/><polyline points="14 2 14 8 20 8" stroke-linecap="round" stroke-linejoin="round"/><line x1="8" y1="13" x2="16" y2="13" stroke-linecap="round"/><line x1="8" y1="17" x2="16" y2="17" stroke-linecap="round"/></svg>
        </span>
        <div class="info">
          <span class="kicker">Broschüre</span>
          <h3>Schul-ABC</h3>
          <p>Von A wie Aula bis W wie Wasser — alle wichtigen Orte und Regeln des Schulalltags.</p>
        </div>
        <span class="meta">PDF · 5&nbsp;Seiten · 185&nbsp;KB</span>
      </a>

      <a href="assets/eltern/UNESCO-Schule-Essen_Was-finde-ich-wo.pdf" class="el-dl gold" download>
        <span class="icon" aria-hidden="true">
          <svg viewBox="0 0 24 24"><path d="M12 22s-8-4.5-8-11.8A8 8 0 0112 2a8 8 0 018 8.2C20 17.5 12 22 12 22z" stroke-linecap="round" stroke-linejoin="round"/><circle cx="12" cy="10" r="3"/></svg>
        </span>
        <div class="info">
          <span class="kicker">Orientierung</span>
          <h3>Was finde ich wo?</h3>
          <p>Raumnummern-Logik, Sekretariat, Fachräume, Turnhallen — damit die ersten Wochen leichter werden.</p>
        </div>
        <span class="meta">PDF · 2&nbsp;Seiten · 186&nbsp;KB</span>
      </a>
    </div>
  </div>
</section>

<section class="el-schedule" aria-label="Unterrichtszeiten">
  <div class="container">
    <div class="head">
      <span class="eyebrow">Tagesstruktur</span>
      <h2>So läuft der Schultag.</h2>
      <p>Sechs Stunden à 45 Minuten, dazwischen zwei große Pausen zum Durchatmen. Nachmittagsunterricht und Betreuung für die Jüngeren folgen ab 13:50&nbsp;Uhr.</p>
    </div>

    <div class="sched-table" role="table" aria-label="Unterrichtsplan">
      {schedule.map((row) => (
        <div class={`sched-row ${row.kind}`}>
          <span class="lbl">{row.label}</span>
          <span class="time">{row.time}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<section class="el-faq" aria-label="Häufig gestellte Fragen">
  <div class="container">
    <div class="head">
      <span class="eyebrow">Fragen und Antworten</span>
      <h2>Fragen, die wir oft hören.</h2>
      <p>Tippen Sie auf eine Frage, um die Antwort zu sehen.</p>
    </div>

    <div class="faq-list">
      {faqs.map((f) => (
        <details class="faq-item">
          <summary>{f.q}</summary>
          <div class="answer">
            {f.a.split("\n\n").map((para) => (
              <p set:html={para.replace(/\*\*(.+?)\*\*/g, "<strong>$1</strong>")} />
            ))}
            {f.link && (
              <a class="followup" href={f.link.href}>
                {f.link.label} →
              </a>
            )}
          </div>
        </details>
      ))}
    </div>
  </div>
</section>

<section class="el-cta" aria-label="Kontaktaufnahme">
  <div class="container">
    <span class="eyebrow">Antwort fehlt?</span>
    <h2>Dann <em>sprechen wir.</em></h2>
    <p>Ein fünfminütiger Anruf klärt oft mehr als zehn Absätze. Wenn Sie möchten, laden wir Sie auch zu einem Rundgang durchs Haus ein.</p>
    <div class="actions">
      <a href="Kontakt.html" class="btn btn-primary">Zum Kontaktformular <span class="arrow">→</span></a>
      <a href="tel:+492012802630" class="btn btn-secondary">0201 · 280&nbsp;26&nbsp;30</a>
    </div>
  </div>
</section>

</main>
</BaseLayout>

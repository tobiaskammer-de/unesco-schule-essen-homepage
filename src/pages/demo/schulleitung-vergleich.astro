---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHero from "../../components/PageHero.astro";

const BASE = import.meta.env.BASE_URL.replace(/\/$/, "");
const link = (p: string) => `${BASE}/${p.replace(/^\//, "")}`;

const variants = [
  {
    key: "a",
    label: "Variante A",
    title: "Hierarchie sichtbar machen",
    risk: "Niedriges Risiko",
    summary: "Schulleiterin als großes Feature-Kärtchen oben (mit Zitat), Stellvertretung als halbbreite Zeile darunter, drei Koordinationen in einer Reihe, Sekretariat als auffälliger Highlight-Block unten.",
    pros: [
      "Echte Funktionsstruktur wird sichtbar.",
      "Schulleiterin bekommt das visuelle Gewicht, das ihrer Rolle entspricht.",
      "Sekretariat als „erste Anlaufstelle\" sticht hervor — passt zur tatsächlichen Anrufkette.",
      "Funktioniert auch ohne neue Fotos."
    ],
    cons: [
      "Klassisches, eher konservatives Layout.",
      "Lebt davon, dass die Schulleiterin ein Zitat beisteuert."
    ],
    href: link("demo/schulleitung-a.html"),
    recommended: true,
  },
  {
    key: "b",
    label: "Variante B",
    title: "Asymmetrisches Bento",
    risk: "Mittleres Risiko",
    summary: "4-Spalten-Raster mit verschieden großen Zellen: Schulleiterin als 2×2-Hero, Stellvertretung als breite Zeile, drei Koordinationen unterschiedlich groß, Sekretariat in dunklem Petrol-Block mit Gold-Akzent.",
    pros: [
      "Visuell deutlich interessanter als ein gleichförmiges 3×2-Raster.",
      "Vermittelt Vielfalt statt Uniformität.",
      "Bleibt in der bestehenden Designsprache (gleiche Farben, Typografie).",
      "Smart-aufgeräumt — keine Waisen-Box, alle Zellen sind besetzt."
    ],
    cons: [
      "Mobile-Layout muss neu gedacht werden (stapelt zu 1 Spalte).",
      "Hierarchie ist subtiler als bei A — wer schnell scannt, sieht zuerst Größenunterschiede, nicht Funktion."
    ],
    href: link("demo/schulleitung-b.html"),
  },
  {
    key: "c",
    label: "Variante C",
    title: "Story-Layout",
    risk: "Höheres Risiko",
    summary: "Komplett weg vom Karten-Raster. Sechs Personen bekommen je eine Zeile mit großem quadratischem Foto links und einem persönlichen „Wofür ich da bin\"-Satz. Sekretariat steht als „erste Anlaufstelle\" oben, mit Telefon-CTA.",
    pros: [
      "Persönlich, der UNESCO-Haltung entsprechend („wir sind Menschen, keine Funktionsträger\").",
      "Gibt jeder Person den Raum, eine Funktion in eigene Worte zu fassen.",
      "Hervorragend für das spätere SEO/Snippets („Wer ist Ansprechperson für …\")."
    ],
    cons: [
      "Braucht echte O-Töne von allen sechs Personen — höherer redaktioneller Aufwand.",
      "Nimmt deutlich mehr vertikalen Platz ein. Mobile-Scroll länger.",
      "Stellt höhere Anforderungen an die Foto-Qualität (große Portraits sind unverzeihlich)."
    ],
    href: link("demo/schulleitung-c.html"),
  },
];
---
<BaseLayout title="Demo · Schulleitung Layout-Varianten">
<style is:global>
  .compare-banner{
    background:rgba(212,165,116,0.12);
    border-bottom:1px solid rgba(212,165,116,0.3);
    padding:14px 0;text-align:center;
  }
  .compare-banner .label{
    font-family:var(--sans);font-size:11.5px;font-weight:600;
    letter-spacing:0.14em;text-transform:uppercase;color:#7a5120;
  }
  .compare-banner .title{
    font-family:var(--serif);font-style:italic;font-size:16px;color:var(--petrol);margin-left:12px;
  }

  .variants{background:var(--offwhite);padding:var(--space-section) 0;}
  .variants .head{max-width:760px;margin:0 0 56px;}
  .variants .head h2{
    font-family:var(--serif);font-weight:500;
    font-size:clamp(28px,3vw,40px);line-height:1.15;
    color:var(--petrol);letter-spacing:-0.015em;margin:0 0 16px;
  }
  .variants .head p{
    font-family:var(--sans);font-size:17px;line-height:1.65;color:var(--stein);margin:0;
  }

  .variant-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:24px;}
  .variant-card{
    background:#fff;border:1px solid var(--hairline);
    border-top:4px solid var(--petrol);
    padding:32px 32px 28px;
    display:flex;flex-direction:column;gap:14px;position:relative;
  }
  .variant-card.is-recommended{
    border-top-color:var(--gold);
    box-shadow:0 14px 36px -22px rgba(212,165,116,0.4);
  }
  .variant-card .badge{
    position:absolute;top:-12px;right:24px;
    padding:6px 12px;background:var(--gold);color:#2a1d08;
    font-family:var(--sans);font-size:11px;font-weight:700;
    letter-spacing:0.1em;text-transform:uppercase;
  }
  .variant-card .label{
    font-family:var(--sans);font-size:11px;font-weight:600;
    letter-spacing:0.14em;text-transform:uppercase;color:var(--bordeaux);
  }
  .variant-card h3{
    font-family:var(--serif);font-weight:500;font-size:24px;line-height:1.2;
    color:var(--petrol);margin:0;letter-spacing:-0.008em;
  }
  .variant-card .risk{
    font-family:var(--sans);font-style:italic;font-size:13px;color:var(--stein);
  }
  .variant-card .summary{
    font-family:var(--sans);font-size:14.5px;line-height:1.6;color:var(--tinte);margin:0;
  }
  .variant-card .lists{display:grid;grid-template-columns:1fr;gap:12px;margin-top:8px;}
  .variant-card .list-title{
    font-family:var(--sans);font-size:11px;font-weight:600;
    letter-spacing:0.12em;text-transform:uppercase;color:var(--petrol);margin:0 0 6px;
  }
  .variant-card ul{
    list-style:none;margin:0;padding:0;
    font-family:var(--sans);font-size:13.5px;line-height:1.55;color:var(--tinte);
  }
  .variant-card ul li{padding:3px 0 3px 16px;position:relative;}
  .variant-card ul.pros li::before{
    content:"+";position:absolute;left:0;top:3px;color:var(--petrol);font-weight:700;
  }
  .variant-card ul.cons li::before{
    content:"–";position:absolute;left:0;top:3px;color:var(--bordeaux);font-weight:700;
  }
  .variant-card .open{
    margin-top:auto;align-self:flex-start;
    display:inline-flex;align-items:center;gap:8px;
    padding:11px 18px;background:var(--petrol);color:var(--creme);
    font-family:var(--sans);font-weight:500;font-size:14px;text-decoration:none;
  }
  .variant-card .open:hover{background:var(--petrol-dark);}
  .variant-card.is-recommended .open{background:var(--gold);color:#2a1d08;}
  .variant-card.is-recommended .open:hover{background:#e0b68a;}

  .compare-meta{
    margin-top:48px;padding:28px 32px;
    background:#fff;border:1px solid var(--hairline);
    border-left:3px solid var(--gold);
  }
  .compare-meta h3{
    font-family:var(--serif);font-weight:500;font-size:20px;color:var(--petrol);margin:0 0 8px;
  }
  .compare-meta p{
    font-family:var(--sans);font-size:15px;line-height:1.6;color:var(--tinte);margin:0;
  }
  .compare-meta .ref{
    margin-top:14px;font-family:var(--sans);font-size:13.5px;color:var(--stein);
  }
  .compare-meta .ref a{color:var(--bordeaux);text-decoration:none;border-bottom:1px solid currentColor;}

  @media (max-width:960px){
    .variant-grid{grid-template-columns:1fr;gap:16px;}
  }
</style>

<main id="top">

<div class="compare-banner">
  <div class="container">
    <span class="label">Demo · Vergleichsübersicht</span>
    <span class="title">Schulleitung — drei Layout-Vorschläge</span>
  </div>
</div>

<PageHero variant="page">
  <Fragment slot="eyebrow">Designentscheidung · Schulleitungs-Seite</Fragment>
  <Fragment slot="title">Drei Layouts. <em>Eine Entscheidung.</em></Fragment>
  <Fragment slot="lede">Die aktuelle 3×2-Karten-Anordnung wirkt monoton — alle sechs Personen sehen visuell gleich wichtig aus, obwohl sie hierarchisch und funktional klar gestuft sind. Hier drei Vorschläge zum Vergleichen, vom konservativen Klassiker bis zum mutigen Story-Layout.</Fragment>
</PageHero>

<section class="variants" aria-label="Vergleichsübersicht">
  <div class="container">
    <div class="head">
      <h2>Klick eine Variante an, um sie live zu sehen.</h2>
      <p>Alle drei nutzen dieselben Daten aus der Lehrkraft-Datenbank. Inhalte sind identisch, nur die Anordnung unterscheidet sich. Mein Vorschlag ist mit „Empfehlung" markiert — die Entscheidung liegt aber bei dir.</p>
    </div>

    <div class="variant-grid">
      {variants.map((v) => (
        <article class={`variant-card ${v.recommended ? "is-recommended" : ""}`}>
          {v.recommended && <span class="badge">Empfehlung</span>}
          <span class="label">{v.label}</span>
          <h3>{v.title}</h3>
          <p class="risk">{v.risk}</p>
          <p class="summary">{v.summary}</p>
          <div class="lists">
            <div>
              <p class="list-title">Stärken</p>
              <ul class="pros">{v.pros.map((p) => <li>{p}</li>)}</ul>
            </div>
            <div>
              <p class="list-title">Trade-offs</p>
              <ul class="cons">{v.cons.map((c) => <li>{c}</li>)}</ul>
            </div>
          </div>
          <a class="open" href={v.href}>Variante {v.key.toUpperCase()} live ansehen →</a>
        </article>
      ))}
    </div>

    <div class="compare-meta">
      <h3>Zur Erinnerung: was diese Demos NICHT sind</h3>
      <p>Diese drei Seiten ersetzen die echte <a href={link("Schulleitung.html")} style="color:var(--bordeaux);">Schulleitung-Seite</a> nicht — sie sind nur unter <code>/demo/</code> erreichbar und werden im Header oder Footer nicht verlinkt. Sobald du dich für eine Variante entscheidest, baue ich sie als Ersatz auf der echten Seite ein und entferne die Demos.</p>
      <p class="ref">Hintergrund: <a href={link("Schulleitung.html")}>Aktuelle Schulleitungs-Seite</a> &nbsp;·&nbsp; Stand-Layout für Vergleich</p>
    </div>
  </div>
</section>

</main>
</BaseLayout>

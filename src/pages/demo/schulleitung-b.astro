---
import BaseLayout from "../../layouts/BaseLayout.astro";
import PageHero from "../../components/PageHero.astro";
import { getTeacherByRole, ROLES } from "../../lib/roles";
import { displayName, initials } from "../../lib/teachers";

const [
  schulleiterin,
  stellv,
  koordOberstufe,
  koordMittelstufe,
  koordEprob,
  sekretariat,
] = await Promise.all([
  getTeacherByRole(ROLES.SCHULLEITUNG),
  getTeacherByRole(ROLES.STELLV_SCHULLEITUNG),
  getTeacherByRole(ROLES.KOORD_OBERSTUFE),
  getTeacherByRole(ROLES.KOORD_MITTELSTUFE),
  getTeacherByRole(ROLES.KOORD_ERPROBUNGSSTUFE),
  getTeacherByRole(ROLES.SEKRETARIAT),
]);

const BASE = import.meta.env.BASE_URL.replace(/\/$/, "");
function asset(p?: string | null) {
  if (!p) return undefined;
  if (/^https?:\/\//.test(p)) return p;
  if (p.startsWith(BASE + "/") || p.startsWith(BASE)) return p;
  if (p.startsWith("/")) return BASE && !p.startsWith(BASE) ? BASE + p : p;
  return BASE + "/" + p;
}
---
<BaseLayout title="Demo · Schulleitung Option B — Bento">
<style is:global>
  .sl-demo-banner{
    background:rgba(212,165,116,0.18);
    border-bottom:1px solid rgba(212,165,116,0.35);
    padding:14px 0;text-align:center;
  }
  .sl-demo-banner .label{
    font-family:var(--sans);font-size:11.5px;font-weight:600;
    letter-spacing:0.14em;text-transform:uppercase;color:#7a5120;
  }
  .sl-demo-banner .title{
    font-family:var(--serif);font-style:italic;font-size:16px;color:var(--petrol);margin-left:12px;
  }
  .sl-demo-banner a{
    margin-left:18px;color:var(--bordeaux);font-family:var(--sans);font-size:13px;font-weight:500;
    border-bottom:1px solid currentColor;padding-bottom:1px;
  }

  /* Layout B: Asymmetrisches Bento */
  .sl-b{background:var(--offwhite);padding:var(--space-section) 0;}
  .sl-b .head{max-width:760px;margin:0 0 48px;}
  .sl-b .head .eyebrow{display:block;margin-bottom:14px;}
  .sl-b .head h2{
    font-family:var(--serif);font-weight:500;
    font-size:clamp(30px,3.2vw,44px);line-height:1.15;letter-spacing:-0.015em;
    color:var(--petrol);margin:0;
  }

  .sl-b-grid{
    display:grid;
    grid-template-columns:repeat(4,minmax(0,1fr));
    grid-auto-rows:minmax(180px,auto);
    gap:1px;
    background:var(--hairline);border:1px solid var(--hairline);
  }
  .sl-b-tile{
    background:#fff;padding:28px 28px 26px;
    display:flex;flex-direction:column;gap:12px;justify-content:flex-end;
    position:relative;
  }
  .sl-b-tile .avatar{
    border-radius:50%;overflow:hidden;background:var(--petrol);
    display:flex;align-items:center;justify-content:center;
    font-family:var(--serif);font-weight:500;color:var(--creme);
    width:80px;height:80px;font-size:28px;
  }
  .sl-b-tile .avatar img{width:100%;height:100%;object-fit:cover;display:block;}
  .sl-b-tile .role{
    font-family:var(--sans);font-size:11px;font-weight:600;
    letter-spacing:0.12em;text-transform:uppercase;color:var(--bordeaux);
  }
  .sl-b-tile .name{
    font-family:var(--serif);font-weight:500;font-size:20px;line-height:1.2;
    color:var(--petrol);margin:0;
  }
  .sl-b-tile .mail{
    font-family:var(--sans);font-size:13px;color:var(--petrol);text-decoration:none;
    border-bottom:1px solid var(--hairline);padding-bottom:2px;align-self:flex-start;
    margin-top:4px;
  }

  /* Tile 1: Schulleiterin (2x2) */
  .sl-b-tile--lead{
    grid-column:span 2;grid-row:span 2;
    background:linear-gradient(135deg, rgba(14,77,79,0.06), #fff 60%);
    border-left:4px solid var(--petrol);
    padding:40px 36px;justify-content:flex-end;
  }
  .sl-b-tile--lead .avatar{width:140px;height:140px;font-size:48px;}
  .sl-b-tile--lead .name{font-size:32px;letter-spacing:-0.015em;}
  .sl-b-tile--lead blockquote{
    font-family:var(--serif);font-style:italic;font-size:17px;line-height:1.5;
    color:var(--tinte);margin:6px 0 0;padding-left:14px;border-left:3px solid var(--gold);
  }

  /* Tile 2: Stellv (2x1) */
  .sl-b-tile--stellv{grid-column:span 2;}
  .sl-b-tile--stellv{flex-direction:row;align-items:center;gap:24px;justify-content:flex-start;}
  .sl-b-tile--stellv .avatar{width:88px;height:88px;font-size:30px;flex-shrink:0;}
  .sl-b-tile--stellv .body{display:flex;flex-direction:column;gap:6px;}

  /* Tiles 3-5: Koordinationen (1x1 each) */
  .sl-b-tile--coord{}
  .sl-b-tile--coord .avatar{
    background:var(--gold);color:#2a1d08;width:64px;height:64px;font-size:22px;
  }
  .sl-b-tile--coord .role{color:var(--gold);}

  /* Tile 6 + 7: Erprobungs (2x1) + Sekr (2x1) */
  .sl-b-tile--erprob{
    grid-column:span 2;background:#fff;
    flex-direction:row;align-items:center;gap:24px;justify-content:flex-start;
  }
  .sl-b-tile--erprob .avatar{width:88px;height:88px;font-size:30px;flex-shrink:0;background:var(--gold);color:#2a1d08;}
  .sl-b-tile--erprob .body{display:flex;flex-direction:column;gap:6px;}
  .sl-b-tile--erprob .role{color:var(--bordeaux);}

  .sl-b-tile--sekr{
    grid-column:span 2;
    background:var(--petrol);color:var(--creme);
    border-left:4px solid var(--gold);
    flex-direction:row;align-items:center;gap:24px;justify-content:flex-start;
  }
  .sl-b-tile--sekr .avatar{width:88px;height:88px;font-size:30px;background:var(--gold);color:#2a1d08;flex-shrink:0;}
  .sl-b-tile--sekr .body{display:flex;flex-direction:column;gap:6px;flex:1;}
  .sl-b-tile--sekr .role{color:var(--gold);}
  .sl-b-tile--sekr .name{color:var(--creme);}
  .sl-b-tile--sekr .phone{
    display:inline-flex;align-items:center;gap:8px;
    padding:11px 16px;background:var(--gold);color:#2a1d08;
    font-family:var(--sans);font-weight:600;font-size:14px;
    text-decoration:none;align-self:center;white-space:nowrap;
  }
  .sl-b-tile--sekr .phone:hover{background:#e0b68a;}

  @media (max-width:1080px){
    .sl-b-grid{grid-template-columns:repeat(2,minmax(0,1fr));}
    .sl-b-tile--lead{grid-column:span 2;grid-row:span 1;}
    .sl-b-tile--stellv,.sl-b-tile--erprob,.sl-b-tile--sekr{grid-column:span 2;}
    .sl-b-tile--coord{grid-column:span 1;}
  }
  @media (max-width:560px){
    .sl-b-grid{grid-template-columns:1fr;}
    .sl-b-tile,.sl-b-tile--lead,.sl-b-tile--stellv,.sl-b-tile--erprob,.sl-b-tile--sekr,.sl-b-tile--coord{grid-column:span 1;}
    .sl-b-tile--stellv,.sl-b-tile--erprob,.sl-b-tile--sekr{flex-direction:column;align-items:flex-start;}
  }
</style>

<main id="top">

<div class="sl-demo-banner">
  <div class="container">
    <span class="label">Demo · Variante B</span>
    <span class="title">Asymmetrisches Bento</span>
    <a href={`${BASE}/demo/schulleitung-vergleich.html`}>Alle Varianten vergleichen →</a>
  </div>
</div>

<PageHero variant="page">
  <Fragment slot="eyebrow">Über Uns · Schulleitung und Sekretariat</Fragment>
  <Fragment slot="title">Ihre Ansprechpartner in <em>Schulleitung und Sekretariat</em>.</Fragment>
  <Fragment slot="lede">Das Team, das unsere Schule trägt — mit offenen Türen für Schülerinnen und Schüler, Eltern und Kolleginnen und Kollegen.</Fragment>
</PageHero>

<section class="sl-b" aria-label="Das Team">
  <div class="container">
    <div class="head">
      <span class="eyebrow">Unser Team</span>
      <h2>Schulleitung, Koordination, Sekretariat.</h2>
    </div>

    <div class="sl-b-grid">
      {schulleiterin && (
        <article class="sl-b-tile sl-b-tile--lead">
          <div class="avatar">
            {asset(schulleiterin.data.photo)
              ? <img src={asset(schulleiterin.data.photo)} alt="" loading="lazy" width="140" height="140" />
              : initials(schulleiterin)}
          </div>
          <p class="role">Schulleiterin</p>
          <h3 class="name">{displayName(schulleiterin)}</h3>
          <blockquote>„Schule ist erst dann gut, wenn Kinder, Eltern und Kolleginnen sich darin gesehen fühlen."</blockquote>
          <a class="mail" href={`mailto:${schulleiterin.data.email}`}>{schulleiterin.data.email}</a>
        </article>
      )}

      {stellv && (
        <article class="sl-b-tile sl-b-tile--stellv">
          <div class="avatar">
            {asset(stellv.data.photo)
              ? <img src={asset(stellv.data.photo)} alt="" loading="lazy" width="88" height="88" />
              : initials(stellv)}
          </div>
          <div class="body">
            <p class="role">Stellvertretende Schulleitung</p>
            <h3 class="name">{displayName(stellv)}</h3>
            <a class="mail" href={`mailto:${stellv.data.email}`}>{stellv.data.email}</a>
          </div>
        </article>
      )}

      {koordMittelstufe && (
        <article class="sl-b-tile sl-b-tile--coord">
          <div class="avatar">
            {asset(koordMittelstufe.data.photo)
              ? <img src={asset(koordMittelstufe.data.photo)} alt="" loading="lazy" width="64" height="64" />
              : initials(koordMittelstufe)}
          </div>
          <p class="role">Koordination · Mittelstufe</p>
          <h3 class="name">{displayName(koordMittelstufe)}</h3>
          <a class="mail" href={`mailto:${koordMittelstufe.data.email}`}>{koordMittelstufe.data.email}</a>
        </article>
      )}

      {koordOberstufe && (
        <article class="sl-b-tile sl-b-tile--coord">
          <div class="avatar">
            {asset(koordOberstufe.data.photo)
              ? <img src={asset(koordOberstufe.data.photo)} alt="" loading="lazy" width="64" height="64" />
              : initials(koordOberstufe)}
          </div>
          <p class="role">Koordination · Oberstufe</p>
          <h3 class="name">{displayName(koordOberstufe)}</h3>
          <a class="mail" href={`mailto:${koordOberstufe.data.email}`}>{koordOberstufe.data.email}</a>
        </article>
      )}

      {koordEprob && (
        <article class="sl-b-tile sl-b-tile--erprob">
          <div class="avatar">
            {asset(koordEprob.data.photo)
              ? <img src={asset(koordEprob.data.photo)} alt="" loading="lazy" width="88" height="88" />
              : initials(koordEprob)}
          </div>
          <div class="body">
            <p class="role">Koordination · Erprobungsstufe</p>
            <h3 class="name">{displayName(koordEprob)}</h3>
            <a class="mail" href={`mailto:${koordEprob.data.email}`}>{koordEprob.data.email}</a>
          </div>
        </article>
      )}

      {sekretariat && (
        <article class="sl-b-tile sl-b-tile--sekr">
          <div class="avatar">
            {asset(sekretariat.data.photo)
              ? <img src={asset(sekretariat.data.photo)} alt="" loading="lazy" width="88" height="88" />
              : initials(sekretariat)}
          </div>
          <div class="body">
            <p class="role">Erste Anlaufstelle · Sekretariat</p>
            <h3 class="name">{displayName(sekretariat)}</h3>
          </div>
          <a class="phone" href="tel:+492012802630">0201 · 280 26 30</a>
        </article>
      )}
    </div>
  </div>
</section>

</main>
</BaseLayout>

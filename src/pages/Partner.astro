      },
    ],
  },
  {
    label: "Stiftungen & Förderer",
    intro: "Private Stiftungen und Service-Clubs, deren Förderung vieles möglich macht.",
    items: [
      {
        name: "Goldschmidt Stiftung",
        url: "https://goldschmidt-stiftung.de",

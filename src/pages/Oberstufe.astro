---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="Oberstufe (EF · Q1 · Q2) — UNESCO-Schule Essen">
<style is:global>
/* ---------- Oberstufe ---------- */
  .ob-hero{
    position:relative;min-height:540px;
    display:flex;align-items:flex-end;padding:96px 0 72px;
    color:var(--creme);overflow:hidden;isolation:isolate;
  }
  .ob-hero::before{
    content:"";position:absolute;inset:0;z-index:-2;
    background:
      linear-gradient(135deg, rgba(110,38,57,0.85) 0%, rgba(78,26,40,0.90) 50%, rgba(10,54,56,0.92) 100%),
      url("/unesco-schule-essen-homepage/assets/pillar-abitur.jpg") center/cover no-repeat;
  }
  .ob-hero::after{
    content:"";position:absolute;inset:0;z-index:-1;
    background-image:
      radial-gradient(circle at 20% 30%, rgba(212,165,116,0.14) 1.5px, transparent 2px),
      radial-gradient(circle at 70% 60%, rgba(245,239,231,0.06) 1px, transparent 1.5px);
    background-size:44px 44px, 60px 60px;opacity:0.85;
  }
  .ob-hero .eyebrow{color:var(--gold);display:block;margin-bottom:18px;}
  .ob-hero h1{
    font-family:var(--serif);font-weight:500;
    font-size:clamp(40px,5.4vw,76px);line-height:1.05;
    letter-spacing:-0.02em;color:var(--creme);max-width:1040px;margin:0 0 22px;
  }
  .ob-hero h1 em{font-style:italic;color:var(--gold);}
  .ob-hero p.lede{
    font-family:var(--sans);font-size:19px;line-height:1.6;
    color:rgba(245,239,231,0.9);max-width:700px;margin:0 0 34px;
  }
  .ob-download{
    display:inline-flex;align-items:center;gap:12px;
    padding:14px 22px;border-radius:4px;
    background:var(--gold);color:#2a1d08;
    font-family:var(--sans);font-size:15px;font-weight:600;text-decoration:none;
    transition:background .2s, transform .2s;
  }
  .ob-download:hover{background:#e0b68a;transform:translateY(-1px);color:#2a1d08;}
  .ob-download .icon{width:18px;height:18px;fill:currentColor;}
  .ob-download .meta{
    font-family:var(--sans);font-size:12px;font-weight:500;color:#5e3f12;letter-spacing:0.04em;
  }

  /* DU/WIR split */
  .ob-duwir{background:var(--creme);padding:96px 0;}
  .duwir-grid{display:grid;grid-template-columns:1fr 1fr;gap:48px;}
  .duwir{padding:40px 36px;background:#fff;border:1px solid var(--hairline);}
  .duwir-du{border-top:4px solid var(--bordeaux);}
  .duwir-wir{border-top:4px solid var(--petrol);background:var(--petrol);color:var(--creme);border-color:var(--petrol);}
  .duwir .label{
    font-family:var(--serif);font-weight:500;font-size:48px;line-height:1;
    color:var(--bordeaux);letter-spacing:-0.02em;margin:0 0 6px;
  }
  .duwir-wir .label{color:var(--gold);}
  .duwir h3{
    font-family:var(--serif);font-weight:500;font-size:24px;line-height:1.2;
    color:var(--petrol);letter-spacing:-0.01em;margin:0 0 18px;
  }
  .duwir-wir h3{color:var(--creme);}
  .duwir ul{list-style:none;margin:0;padding:0;}
  .duwir li{
    position:relative;padding:10px 0 10px 22px;
    font-family:var(--sans);font-size:15.5px;line-height:1.6;color:var(--tinte);
    border-bottom:1px solid var(--hairline);
  }
  .duwir li::before{
    content:"";position:absolute;left:0;top:19px;width:12px;height:1px;background:var(--bordeaux);
  }
  .duwir li:last-child{border-bottom:0;}
  .duwir-wir li{color:rgba(245,239,231,0.92);border-bottom-color:rgba(245,239,231,0.16);}
  .duwir-wir li::before{background:var(--gold);}
  .duwir .oder{
    text-align:center;padding:18px 0;
    font-family:var(--serif);font-style:italic;font-size:22px;color:var(--stein);
  }
  .duwir-wir .oder{color:rgba(245,239,231,0.7);}

  /* Stats band */
  .ob-stats{background:var(--offwhite);padding:64px 0;}
  .stats-row{
    display:grid;grid-template-columns:repeat(4,minmax(0,1fr));gap:0;
    border:1px solid var(--hairline);
  }
  .ob-stat{
    padding:28px 24px;border-right:1px solid var(--hairline);
    display:flex;flex-direction:column;gap:6px;
  }
  .ob-stat:last-child{border-right:0;}
  .ob-stat .n{
    font-family:var(--serif);font-weight:500;font-size:clamp(32px,3.4vw,44px);line-height:1;
    color:var(--bordeaux);letter-spacing:-0.02em;
  }
  .ob-stat .label{
    font-family:var(--sans);font-size:12.5px;color:var(--stein);line-height:1.5;
    letter-spacing:0.02em;
  }

  /* Generic section pattern */
  .ob-sect{padding:88px 0;border-top:1px solid var(--hairline);}
  .ob-sect.alt{background:var(--creme);}
  .ob-sect .head{max-width:780px;margin:0 0 40px;}
  .ob-sect .head .eyebrow{display:block;margin-bottom:14px;}
  .ob-sect .head h2{
    font-family:var(--serif);font-weight:500;
    font-size:clamp(28px,3vw,40px);line-height:1.15;letter-spacing:-0.015em;
    color:var(--petrol);margin:0 0 12px;
  }
  .ob-sect .head p{
    font-family:var(--sans);font-size:16.5px;line-height:1.65;color:var(--stein);margin:0;
  }
  .ob-check{
    list-style:none;margin:0;padding:0;
    display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:2px 32px;
    border-top:1px solid var(--hairline);
  }
  .ob-check li{
    padding:16px 0 16px 28px;border-bottom:1px solid var(--hairline);
    position:relative;
    font-family:var(--sans);font-size:15.5px;line-height:1.55;color:var(--tinte);
  }
  .ob-check li::before{
    content:"✓";position:absolute;left:0;top:16px;
    color:var(--sage);font-weight:600;font-size:16px;
  }
  .ob-check li strong{color:var(--petrol);}

  /* Six steps */
  .ob-steps{background:var(--petrol);color:var(--creme);padding:96px 0;}
  .ob-steps .head{max-width:780px;margin:0 0 48px;}
  .ob-steps .head .eyebrow{color:var(--gold);display:block;margin-bottom:14px;}
  .ob-steps .head h2{
    font-family:var(--serif);font-weight:500;
    font-size:clamp(32px,3.6vw,48px);line-height:1.12;letter-spacing:-0.015em;
    color:var(--creme);margin:0;
  }
  .steps-list{
    list-style:none;margin:0;padding:0;
    display:flex;flex-direction:column;gap:2px;
    background:rgba(245,239,231,0.15);
    border:1px solid rgba(245,239,231,0.15);
  }
  .steps-list li{
    background:var(--petrol);padding:26px 32px;
    display:grid;grid-template-columns:72px 1fr auto;gap:28px;align-items:center;
  }
  .steps-list .num{
    font-family:var(--serif);font-weight:500;font-size:40px;line-height:1;
    color:var(--gold);letter-spacing:-0.025em;
  }
  .steps-list .body h3{
    font-family:var(--serif);font-weight:500;font-size:22px;line-height:1.2;
    color:var(--creme);letter-spacing:-0.008em;margin:0 0 4px;
  }
  .steps-list .body p{
    font-family:var(--sans);font-size:14.5px;line-height:1.55;
    color:rgba(245,239,231,0.82);margin:0;
  }
  .steps-list .when{
    font-family:var(--sans);font-size:12px;letter-spacing:0.1em;text-transform:uppercase;
    color:rgba(245,239,231,0.7);text-align:right;min-width:140px;
  }

  /* Contact */
  .ob-contact{background:var(--offwhite);padding:88px 0 104px;}
  .contact-duo{display:grid;grid-template-columns:1fr 1fr;gap:28px;}
  .contact-person{
    padding:32px 32px 30px;background:#fff;border:1px solid var(--hairline);
    display:flex;flex-direction:column;gap:8px;
  }
  .contact-person .role{
    font-family:var(--sans);font-size:11px;font-weight:600;
    letter-spacing:0.14em;text-transform:uppercase;color:var(--bordeaux);
  }
  .contact-person .name{
    font-family:var(--serif);font-weight:500;font-size:24px;line-height:1.2;
    color:var(--petrol);margin:2px 0;
  }
  .contact-person .title{
    font-family:var(--sans);font-size:14.5px;color:var(--stein);margin-bottom:8px;
  }
  .contact-person a{
    font-family:var(--sans);font-size:15px;color:var(--petrol);display:block;padding:2px 0;
  }
  .contact-person a:hover{text-decoration:underline;}


  .ob-welcome{
    position:relative;padding:120px 0;isolation:isolate;overflow:hidden;
  }
  .ob-welcome::before{
    content:"";position:absolute;inset:0;z-index:-2;
    background:url("/unesco-schule-essen-homepage/assets/sp-persoenlich.jpg") center 35%/cover no-repeat;
  }
  .ob-welcome::after{
    content:"";position:absolute;inset:0;z-index:-1;
    background:linear-gradient(180deg, rgba(14,77,79,0.82) 0%, rgba(14,77,79,0.92) 100%);
  }
  .ob-welcome .container{max-width:880px;text-align:center;color:var(--creme);}
  .ob-welcome .eyebrow{color:var(--gold);display:block;margin-bottom:16px;}
  .ob-welcome h2{
    font-family:var(--serif);font-weight:500;font-style:italic;
    font-size:clamp(32px,3.6vw,52px);line-height:1.15;
    color:var(--creme);letter-spacing:-0.015em;margin:0 0 20px;
  }
  .ob-welcome p{
    font-family:var(--sans);font-size:17px;line-height:1.65;
    color:rgba(245,239,231,0.9);max-width:620px;margin:0 auto;
  }
  .ob-welcome .cred{
    position:absolute;bottom:16px;left:32px;
    padding:5px 10px;background:rgba(14,77,79,0.78);
    color:rgba(255,255,255,0.95);
    font-family:var(--sans);font-size:10px;font-weight:500;
    letter-spacing:0.12em;text-transform:uppercase;border-radius:2px;
  }
  @media (max-width:780px){.ob-welcome{padding:72px 0;}}

  @media (max-width:960px){
    .duwir-grid{grid-template-columns:1fr;gap:18px;}
    .stats-row{grid-template-columns:1fr 1fr;}
    .ob-stat:nth-child(2){border-right:0;}
    .ob-stat:nth-child(-n+2){border-bottom:1px solid var(--hairline);}
    .ob-check{grid-template-columns:1fr;}
    .steps-list li{grid-template-columns:48px 1fr;gap:16px;padding:20px 24px;}
    .steps-list .when{grid-column:1 / -1;text-align:left;margin-top:6px;}
    .steps-list .num{font-size:30px;}
    .contact-duo{grid-template-columns:1fr;gap:14px;}
    .ob-hero{min-height:420px;padding:56px 0 48px;}
    .ob-duwir,.ob-sect,.ob-steps,.ob-contact{padding:56px 0;}
  }

  /* ---------- Photo placeholders (to be replaced by real photos) ---------- */
  .photo{position:relative;overflow:hidden;background:var(--creme);border-radius:2px;}
  .photo > img{width:100%;height:100%;object-fit:cover;display:block;transition:transform .5s ease;}
  .photo .cred{
    position:absolute;bottom:10px;left:12px;
    padding:5px 10px;background:rgba(14,77,79,0.78);
    color:rgba(255,255,255,0.95);
    font-family:var(--sans);font-size:10px;font-weight:500;
    letter-spacing:0.12em;text-transform:uppercase;border-radius:2px;
    backdrop-filter:blur(4px);
  }
</style>

<main id="top">

<section class="ob-hero" aria-label="Oberstufe">
  <div class="container">
    <span class="eyebrow">Unterricht · Oberstufe · EF · Q1 · Q2</span>
    <h1>Gemeinsam lernen —<br>den <em>eigenen Weg</em> finden.</h1>
    <p class="lede">Die gymnasiale Oberstufe der UNESCO-Schule Essen. Für alle, die nach Klasse 10 zum Abitur oder zur Fachhochschulreife führen wollen — besonders für Schulwechslerinnen und Schulwechsler.</p>
    <a href="assets/GO2026.pdf" class="ob-download" download>
      <svg class="icon" viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3v12m0 0l-4-4m4 4l4-4M5 21h14" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
      Informationsbroschüre herunterladen
      <span class="meta">PDF · 2,2&#8239;MB</span>
    </a>
  </div>
</section>

<section class="ob-duwir" aria-label="Für wen ist die Oberstufe gedacht">
  <div class="container">
    <div class="duwir-grid">
      <article class="duwir duwir-du">
        <span class="label">DU</span>
        <h3>… wenn du dich fragst, wie es weitergeht.</h3>
        <ul>
          <li>besuchst zurzeit die 10. Klasse einer <strong>Realschule</strong>, <strong>Sekundarschule</strong>, <strong>Hauptschule</strong> oder eines <strong>Berufskollegs</strong> und machst am Ende dieses Schuljahres deine <strong>Fachoberschulreife mit Qualifikation</strong> zum Besuch der gymnasialen Oberstufe</li>
          <li>überlegst dir, weiter zur Schule zu gehen und ein <strong>Abitur</strong> oder die <strong>Fachhochschulreife</strong> zu erlangen, um zu studieren oder einen Beruf zu ergreifen</li>
        </ul>
        <div class="oder">— oder —</div>
        <ul>
          <li>möchtest an einer anderen Schule deine Schullaufbahn in der <strong>gymnasialen Oberstufe</strong> fortsetzen</li>
        </ul>
      </article>
      <article class="duwir duwir-wir">
        <span class="label">WIR</span>
        <h3>… warten genau auf dich.</h3>
        <ul>
          <li>sind ein Gymnasium mit <strong>jahrzehntelanger Erfahrung</strong> mit Schulwechslerinnen und Schulwechslern</li>
          <li>haben unsere gymnasiale Oberstufe gezielt auf Schülerinnen und Schüler ausgerichtet, die bis Klasse 10 <strong>eine andere Schulform</strong> besucht haben</li>
          <li>sind eine Schule, die dich <strong>intensiv begleitet</strong>, deinen eigenen Weg zu finden</li>
          <li>bilden in der EF <strong>Klassenverbände</strong> in Deutsch, Mathematik, Englisch und Sport — als weicher Übergang in den Kurs­betrieb</li>
        </ul>
      </article>
    </div>
  </div>
</section>

<section class="ob-stats" aria-label="Die Schule in Zahlen">
  <div class="container">
    <div class="stats-row">
      <div class="ob-stat"><span class="n">~550</span><span class="label">Schülerinnen und Schüler aus fast 45 Nationen</span></div>
      <div class="ob-stat"><span class="n">~350</span><span class="label">Schülerinnen und Schüler in der Oberstufe</span></div>
      <div class="ob-stat"><span class="n">48</span><span class="label">Lehrerinnen und Lehrer</span></div>
      <div class="ob-stat"><span class="n">1:1</span><span class="label">Schul­sozial­arbeit, Schul­psychologie, Berufs- und Studienberatung, Arbeits­agentur</span></div>
    </div>
  </div>
</section>

<section class="ob-sect" aria-label="Wir nehmen auf">
  <div class="container">
    <div class="head">
      <span class="eyebrow">Wer bei uns aufgenommen wird</span>
      <h2>Wir nehmen in die gymnasiale Oberstufe auf.</h2>
      <p>Für die Aufnahme ist es unerheblich, welcher Notendurchschnitt dabei erreicht wurde. Alle Schülerinnen und Schüler erhalten bei uns die Chance auf den Erwerb der Allgemeinen Hochschulreife (Abitur) oder auf den Erwerb des schulischen Teils der Fachhochschulreife.</p>
    </div>
    <ul class="ob-check">
      <li>Schülerinnen und Schüler, die an einer <strong>Realschule, Sekundarschule, Hauptschule</strong> oder an einem <strong>Berufskolleg</strong> ihre Fachoberschulreife mit Qualifikationsvermerk erworben haben</li>
      <li>Schülerinnen und Schüler, die an einem <strong>anderen Gymnasium</strong> die Berechtigung zum Eintritt in die gymnasiale Oberstufe erworben haben oder die Jahrgangsstufe EF wiederholen</li>
      <li>Schülerinnen und Schüler, die an einem anderen Gymnasium am Ende des Schuljahres 2025/26 die Jahrgangsstufe <strong>EF wiederholen</strong> müssen oder möchten</li>
      <li>Schülerinnen und Schüler in die Jahrgangsstufen <strong>Q1 oder Q2</strong></li>
    </ul>
  </div>
</section>

<section class="ob-sect alt" aria-label="Wir bieten in der Oberstufe">
  <div class="container">
    <div class="head">
      <span class="eyebrow">Unser Angebot</span>
      <h2>Wir bieten in der Oberstufe.</h2>
    </div>
    <ul class="ob-check">
      <li><strong>Erhaltung eines Klassenverbandes</strong> in der Einführungsphase in Mathematik, Deutsch, Englisch und Sport</li>
      <li><strong>Klassenbildung gemäß den bisher besuchten Schulformen</strong> — Schülergruppen aus ein und derselben Schule können zusammen­bleiben</li>
      <li><strong>Vertiefungskurse</strong> in Mathematik, Deutsch und Englisch</li>
      <li><strong>Anfängerkurse</strong> für Französisch und Latein (ggf. Erwerb des Kleinen Latinums)</li>
      <li><strong>Fortsetzung</strong> der Fremdsprache Französisch aus der Sekundarstufe I</li>
      <li><strong>Leistungskurse</strong> in Deutsch, Englisch, Mathematik, Pädagogik, Sozialwissenschaft, Biologie, Chemie, Erdkunde, Geschichte</li>
    </ul>
  </div>
</section>

<section class="ob-sect" aria-label="Wir unterstützen und fördern">
  <div class="container">
    <div class="head">
      <span class="eyebrow">Unterstützung &amp; Förderung</span>
      <h2>Wir lassen niemanden allein.</h2>
    </div>
    <ul class="ob-check">
      <li>Orientierung der Unterrichtsgestaltung an den Voraussetzungen der Schülerinnen und Schüler</li>
      <li>Progressive (stetig ansteigende) Anforderungsprofile in Klausuren und Prüfungen</li>
      <li>Einrichtung von <strong>Schülertutorien</strong> in Deutsch, Mathematik und Englisch</li>
      <li>Intensive individuelle Beratung durch die Stufenleitungen</li>
      <li>Initiierung und Betreuung von Lerngruppen</li>
      <li>Förderung besonderer Stärken</li>
      <li>Vermittlung von Stipendien</li>
      <li>Unterstützung bei Beantragung von Mitteln zur Bildung und Teilhabe</li>
      <li>Kennenlern- und Methodentage zu Beginn des Schuljahres</li>
    </ul>
  </div>
</section>

<section class="ob-sect alt" aria-label="Zusätzliches Angebot">
  <div class="container">
    <div class="head">
      <span class="eyebrow">Zusätzlich an unserer Schule</span>
      <h2>Mehr als Unterricht.</h2>
    </div>
    <ul class="ob-check">
      <li><strong>Schülerbetriebspraktikum</strong> oder duales Praktikum in der Einführungs­phase</li>
      <li>Berufs- und Laufbahnberatung in der Schule — wöchentliche Sprechstunden mit der Berufs-/Studienberatung</li>
      <li>Individuelle Beratung durch Mitarbeiter des <strong>BIZ</strong> (Berufs­informations­zentrum)</li>
      <li>Beratung und Information durch <strong>Firmen und Institutionen</strong></li>
      <li>Teilnahme an Informationstagen — schulintern oder an den Universitäten</li>
    </ul>
  </div>
</section>

<section class="ob-steps" aria-label="Dein Weg zu uns in 6 Schritten">
  <div class="container">
    <div class="head">
      <span class="eyebrow">Dein Weg zu uns</span>
      <h2>In sechs Schritten<br>in die Oberstufe.</h2>
    </div>
    <ol class="steps-list">
      <li>
        <span class="num">01</span>
        <div class="body">
          <h3>Vor der Anmeldung</h3>
          <p>Tag der offenen Tür, Informationsveranstaltung in der Aula und Schnuppertage. Ein Tag am Unterricht teilnehmen — mit einem „Stundenplan", der deinen Interessen entspricht.</p>
        </div>
        <div class="when">29.11.2025 · 20.01.2026 · 19.01.–27.02.2026</div>
      </li>
      <li>
        <span class="num">02</span>
        <div class="body">
          <h3>Die Anmeldung</h3>
          <p>Anmeldung online über <strong>www.schueleranmeldung.de</strong>. Danach persönlich mit unterschriebenem Anmeldebogen, Ausweis und Halbjahreszeugnis bei uns vorbeikommen. Nach der Anmeldung bist du zunächst aufgenommen.</p>
        </div>
        <div class="when">02.02.–06.03.2026</div>
      </li>
      <li>
        <span class="num">03</span>
        <div class="body">
          <h3>Die Fächerwahl</h3>
          <p>Pflicht­belegungen (Deutsch, Mathematik, Englisch, Sport), zweite Fremdsprache (Französisch oder Latein als Anfänger, wenn bisher keine zweite Fremdsprache), Religion/Philosophie, Kunst/Musik, Natur- und Gesellschafts­wissenschaften. Infoabend und Abgabe des Wahlzettels.</p>
        </div>
        <div class="when">21.04.2026 · Abgabe 13.05.2026</div>
      </li>
      <li>
        <span class="num">04</span>
        <div class="body">
          <h3>Deine besonderen Wünsche</h3>
          <p>In der EF bilden wir Klassenverbände in Deutsch, Englisch, Mathematik und Sport. Auf dem Wahlzettel gibst du an, mit wem du gerne in eine „Klasse" möchtest — wir versuchen, deine Wünsche zu berücksichtigen.</p>
        </div>
        <div class="when">Mit der Fächerwahl</div>
      </li>
      <li>
        <span class="num">05</span>
        <div class="body">
          <h3>Die endgültige Aufnahme</h3>
          <p>Mit Erhalt des Abschlusszeugnisses (Fachoberschulreife mit Qualifikationsvermerk oder Gymnasialzeugnis) schnellstmöglich vor den Sommerferien in Kopie vorlegen — und du bist endgültig UNESCO-Gymnasium.</p>
        </div>
        <div class="when">Vor den Sommerferien</div>
      </li>
      <li>
        <span class="num">06</span>
        <div class="body">
          <h3>Der erste Schultag</h3>

---
const RAW_BASE = import.meta.env.BASE_URL;
const BASE = RAW_BASE.endsWith("/") ? RAW_BASE.slice(0, -1) : RAW_BASE;
function link(path: string): string {
  const clean = path.startsWith("/") ? path.slice(1) : path;
  return BASE + "/" + clean;
}

const variants = [
  {
    label: "Variante A — Original",
    sub: "Aktuelle Live-Version mit Logo links und Menü daneben.",
    href: link("test-original.html"),
  },
  {
    label: "Variante B — Neuer Header",
    sub: "Logo zentriert oben, Menü und Buttons darunter, Logo schrumpft beim Scrollen.",
    href: link("test-header.html"),
  },
  {
    label: "Variante C — Neuer Header eingefärbt",
    sub: "Wie Variante B, zusätzlich Petrol-Akzentstreifen oben und sanfter Scroll-Schatten.",
    href: link("test-header-color.html"),
  },
];
---
<!DOCTYPE html>
<html lang="de">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="robots" content="noindex" />
  <title>Demo: Header-Varianten · UNESCO-Schule Essen</title>
  <link rel="icon" type="image/png" href={link("assets/logo-mark.png")} />
  <style>
    :root{
      --petrol:#0E4D4F;
      --petrol-dark:#0A3638;
      --bordeaux:#6E2639;
      --creme:#F5EFE7;
      --offwhite:#FAF7F1;
      --stein:#6A6A68;
      --tinte:#1A1A1A;
      --hairline:#E8E0D1;
    }
    *,*::before,*::after{box-sizing:border-box;}
    html,body{margin:0;padding:0;}
    body{
      font-family:-apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
      background:#EFE9DD;
      color:var(--tinte);
      -webkit-font-smoothing:antialiased;
    }

    .demo-head{
      background:var(--petrol);
      color:var(--creme);
      padding:36px 28px 28px;
      border-bottom:4px solid var(--bordeaux);
    }
    .demo-head .inner{max-width:1320px;margin:0 auto;}
    .demo-head h1{
      font-family:Georgia, "Times New Roman", serif;
      font-weight:500;font-size:30px;line-height:1.15;
      margin:0 0 8px;letter-spacing:-0.01em;
    }
    .demo-head p{
      margin:0;font-size:15px;line-height:1.55;
      color:rgba(245,239,231,0.85);max-width:760px;
    }
    .demo-head .meta{
      margin-top:18px;font-size:12px;letter-spacing:0.12em;
      text-transform:uppercase;color:rgba(245,239,231,0.6);
    }

    .stage{max-width:1320px;margin:0 auto;padding:36px 28px 64px;}
    .variant + .variant{margin-top:48px;}

    .v-head{
      display:flex;align-items:baseline;justify-content:space-between;
      gap:18px;flex-wrap:wrap;
      margin-bottom:14px;
    }
    .v-title{
      display:flex;align-items:baseline;gap:14px;flex-wrap:wrap;
    }
    .v-letter{
      font-family:Georgia, serif;font-weight:600;font-size:22px;
      color:var(--bordeaux);letter-spacing:-0.01em;
    }
    .v-title h2{
      margin:0;font-family:Georgia, serif;font-weight:500;
      font-size:22px;color:var(--petrol);letter-spacing:-0.005em;
      line-height:1.2;
    }
    .v-sub{
      font-size:14px;color:var(--stein);line-height:1.5;
      max-width:640px;margin:0;
    }
    .v-link{
      font-size:13px;font-weight:500;color:var(--petrol);
      text-decoration:underline;text-underline-offset:3px;
      text-decoration-thickness:1px;
    }
    .v-link:hover{color:var(--bordeaux);}

    .frame-wrap{
      position:relative;
      background:#fff;
      border:1px solid var(--hairline);
      border-radius:6px;
      overflow:hidden;
      box-shadow:0 18px 48px -28px rgba(14,77,79,0.28),
                 0 4px 12px -8px rgba(14,77,79,0.12);
    }
    .frame-wrap iframe{
      display:block;width:100%;height:920px;border:0;background:#fff;
    }
    .frame-foot{
      padding:10px 16px;
      border-top:1px solid var(--hairline);
      background:var(--offwhite);
      font-size:12px;color:var(--stein);
      display:flex;justify-content:space-between;align-items:center;gap:14px;flex-wrap:wrap;
    }
    .frame-foot kbd{
      font-family:ui-monospace, SFMono-Regular, Menlo, monospace;
      font-size:11px;background:#fff;border:1px solid var(--hairline);
      padding:2px 6px;border-radius:3px;color:var(--tinte);
    }

    @media (max-width:780px){
      .demo-head{padding:24px 18px 20px;}
      .demo-head h1{font-size:24px;}
      .stage{padding:22px 16px 48px;}
      .frame-wrap iframe{height:760px;}
    }
  </style>
</head>
<body>

<header class="demo-head">
  <div class="inner">
    <div class="meta">Interner Vergleich · nicht öffentlich</div>
    <h1>Header-Varianten im direkten Vergleich</h1>
    <p>
      Drei Versionen des oberen Seitenbereichs nebeneinander. Innerhalb jedes Rahmens kann
      gescrollt werden, um den Shrink-Effekt des Logos und das Verhalten des Headers zu sehen.
    </p>
  </div>
</header>

<main class="stage">
  {variants.map((v, i) => {
    const letter = ["A", "B", "C"][i];
    return (
      <section class="variant" id={`variante-${letter.toLowerCase()}`}>
        <div class="v-head">
          <div class="v-title">
            <span class="v-letter">{letter}</span>
            <h2>{v.label.replace(/^Variante [A-Z] — /, "")}</h2>
          </div>
          <a href={v.href} class="v-link" target="_blank" rel="noopener">
            In neuem Tab öffnen ↗
          </a>
        </div>
        <p class="v-sub">{v.sub}</p>
        <div class="frame-wrap">
          <iframe
            src={v.href}
            title={v.label}
            loading={i === 0 ? "eager" : "lazy"}
          ></iframe>
          <div class="frame-foot">
            <span>Innerhalb des Rahmens scrollen, um den Effekt zu sehen.</span>
            <span><kbd>↑↓</kbd> Scrollen · <kbd>Tab</kbd> Fokus</span>
          </div>
        </div>
      </section>
    );
  })}
</main>

</body>
</html>

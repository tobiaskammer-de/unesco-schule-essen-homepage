---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="Erprobungsstufe (Klassen 5–6) — UNESCO-Schule Essen">
<style is:global>
/* ---------- Erprobungsstufe ---------- */
  .er-hero{
    position:relative;min-height:520px;
    display:flex;align-items:flex-end;
    padding:96px 0 72px;
    color:var(--creme);overflow:hidden;isolation:isolate;
  }
  .er-hero::before{
    content:"";position:absolute;inset:0;z-index:-2;
    background:
      linear-gradient(140deg, rgba(14,77,79,0.82) 0%, rgba(10,58,60,0.88) 55%, rgba(10,54,56,0.92) 100%),
      url("assets/sp-divers.jpg") center/cover no-repeat;
  }
  .er-hero::after{
    content:"";position:absolute;inset:0;z-index:-1;
    background-image:
      radial-gradient(circle at 20% 30%, rgba(127,176,105,0.18) 1.5px, transparent 2.5px),
      radial-gradient(circle at 75% 70%, rgba(212,165,116,0.14) 1.2px, transparent 2px);
    background-size:52px 52px, 68px 68px;opacity:0.85;
  }
  .er-hero .kicker{
    display:inline-flex;align-items:center;gap:10px;
    padding:7px 16px;border-radius:999px;
    background:rgba(245,239,231,0.10);border:1px solid rgba(245,239,231,0.25);
    color:var(--creme);
    font-family:var(--sans);font-size:12px;font-weight:500;
    letter-spacing:0.12em;text-transform:uppercase;margin-bottom:24px;
  }
  .er-hero .kicker .dot{width:7px;height:7px;border-radius:50%;background:var(--sage);}
  .er-hero h1{
    font-family:var(--serif);font-weight:500;
    font-size:clamp(44px,6vw,80px);line-height:1.02;
    letter-spacing:-0.02em;color:var(--creme);
    max-width:1000px;margin:0 0 20px;
  }
  .er-hero h1 em{font-style:italic;color:var(--sage);}
  .er-hero p.lede{
    font-family:var(--sans);font-size:19px;line-height:1.6;
    color:rgba(245,239,231,0.9);max-width:700px;margin:0;
  }

  /* Intro statement */
  .er-intro{background:var(--creme);padding:96px 0;}
  .er-intro-grid{
    display:grid;grid-template-columns:minmax(0,5fr) minmax(0,7fr);
    gap:64px;align-items:start;
  }
  .er-intro-grid .photo{aspect-ratio:4/5;margin-top:8px;}
  .er-intro h2{
    font-family:var(--serif);font-weight:500;
    font-size:clamp(32px,3.4vw,48px);line-height:1.1;
    color:var(--petrol);letter-spacing:-0.012em;margin:0;
  }
  .er-intro p.lead{
    font-family:var(--sans);font-size:17px;line-height:1.7;color:var(--tinte);margin:0 0 18px;
  }
  .er-intro p + p{margin-top:14px;}

  /* Profile duo */
  .er-profiles{background:var(--offwhite);padding:96px 0;}
  .er-profiles .head{max-width:760px;margin:0 0 56px;}
  .er-profiles .head .eyebrow{display:block;margin-bottom:14px;}
  .er-profiles .head h2{
    font-family:var(--serif);font-weight:500;
    font-size:clamp(30px,3.2vw,44px);line-height:1.15;letter-spacing:-0.015em;
    color:var(--petrol);margin:0 0 14px;
  }
  .er-profiles .head p{
    font-family:var(--sans);font-size:17px;line-height:1.65;color:var(--stein);
    max-width:640px;margin:0;
  }
  .profile-duo{display:grid;grid-template-columns:1fr 1fr;gap:28px;}
  .profile-card{
    position:relative;padding:44px 40px 40px;
    background:#fff;border:1px solid var(--hairline);
    border-top:4px solid var(--bordeaux);
    display:flex;flex-direction:column;gap:18px;
    transition:transform .3s ease, box-shadow .3s ease;
  }
  .profile-card:nth-child(2){border-top-color:var(--sage);}
  .profile-card:hover{transform:translateY(-2px);box-shadow:0 16px 40px -22px rgba(14,77,79,0.3);}
  .profile-card .mark{
    font-family:var(--serif);font-weight:500;font-size:15px;letter-spacing:0.08em;
    text-transform:uppercase;color:var(--bordeaux);
  }
  .profile-card:nth-child(2) .mark{color:#3e6b2a;}
  .profile-card h3{
    font-family:var(--serif);font-weight:500;
    font-size:clamp(32px,3vw,42px);line-height:1.1;
    color:var(--petrol);letter-spacing:-0.015em;margin:0;
  }
  .profile-card .tag{
    font-family:var(--sans);font-size:13.5px;font-weight:500;color:var(--stein);
    letter-spacing:0.02em;margin:-6px 0 0;
  }
  .profile-card p{
    font-family:var(--sans);font-size:16px;line-height:1.7;color:var(--tinte);margin:0;
  }
  .profile-card .photo{aspect-ratio:5/3;margin:-44px -40px 8px;border-radius:0;}
  @media (max-width:960px){.profile-card .photo{margin:-44px -40px 4px;}}

  /* Pillars row */
  .er-pillars{background:var(--creme);padding:96px 0;border-top:1px solid var(--hairline);}
  .er-pillars .head{max-width:760px;margin:0 0 56px;}
  .er-pillars .head .eyebrow{display:block;margin-bottom:14px;}
  .er-pillars .head h2{
    font-family:var(--serif);font-weight:500;
    font-size:clamp(30px,3.2vw,44px);line-height:1.15;letter-spacing:-0.015em;
    color:var(--petrol);margin:0;
  }
  .pillar-row{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:28px;}
  .er-pillar{
    padding:30px 30px 32px;background:#fff;border:1px solid var(--hairline);
    display:flex;flex-direction:column;gap:12px;
  }
  .er-pillar .label{
    font-family:var(--sans);font-size:11px;font-weight:600;
    letter-spacing:0.14em;text-transform:uppercase;color:var(--bordeaux);
  }
  .er-pillar h3{
    font-family:var(--serif);font-weight:500;font-size:22px;line-height:1.2;
    color:var(--petrol);letter-spacing:-0.008em;margin:0;
  }
  .er-pillar p{
    font-family:var(--sans);font-size:15.5px;line-height:1.6;color:var(--stein);margin:0;
  }
  .er-pillar .photo{aspect-ratio:3/2;margin:-30px -30px 14px;border-radius:0;}

  /* Values grid — 7 traits */
  .er-values{background:var(--petrol);color:var(--creme);padding:96px 0;}
  .er-values .head{max-width:760px;margin:0 0 48px;}
  .er-values .head .eyebrow{color:var(--gold);display:block;margin-bottom:14px;}
  .er-values .head h2{
    font-family:var(--serif);font-weight:500;
    font-size:clamp(30px,3.4vw,46px);line-height:1.12;letter-spacing:-0.015em;
    color:var(--creme);margin:0 0 16px;
  }
  .er-values .head p{
    font-family:var(--sans);font-size:17px;line-height:1.65;
    color:rgba(245,239,231,0.85);max-width:640px;margin:0;
  }
  .values-list{
    list-style:none;margin:0;padding:0;
    display:grid;grid-template-columns:repeat(3,minmax(0,1fr));
    gap:1px;background:rgba(245,239,231,0.15);
    border:1px solid rgba(245,239,231,0.15);
  }
  .values-list li{
    background:var(--petrol);padding:28px 28px 32px;
    display:flex;flex-direction:column;gap:8px;
  }
  .values-list .name{
    font-family:var(--serif);font-weight:500;font-size:20px;line-height:1.2;
    color:var(--gold);letter-spacing:-0.005em;
  }
  .values-list .desc{
    font-family:var(--sans);font-size:14.5px;line-height:1.55;
    color:rgba(245,239,231,0.88);
  }

  /* Pull quote */
  .er-quote{
    position:relative;padding:140px 0;isolation:isolate;overflow:hidden;
  }
  .er-quote::before{
    content:"";position:absolute;inset:0;z-index:-2;
    background:url("assets/pillar-quote.jpg") center 30%/cover no-repeat;
  }
  .er-quote::after{
    content:"";position:absolute;inset:0;z-index:-1;
    background:linear-gradient(180deg, rgba(245,239,231,0.72) 0%, rgba(245,239,231,0.92) 70%, var(--offwhite) 100%);
  }
  .er-quote .container{max-width:900px;text-align:center;position:relative;}
  .er-quote .cred-full{
    position:absolute;bottom:-108px;left:32px;
    padding:5px 10px;background:rgba(14,77,79,0.78);
    color:rgba(255,255,255,0.95);
    font-family:var(--sans);font-size:10px;font-weight:500;
    letter-spacing:0.12em;text-transform:uppercase;border-radius:2px;
  }
  .er-quote blockquote{
    margin:0;
    font-family:var(--serif);font-weight:400;font-style:italic;
    font-size:clamp(26px,3vw,40px);line-height:1.25;
    color:var(--petrol);letter-spacing:-0.01em;
  }
  .er-quote blockquote::before{
    content:"\201E";display:block;
    font-family:var(--serif);font-size:88px;line-height:0.3;
    color:var(--bordeaux);opacity:0.6;margin-bottom:20px;
  }
  .er-quote cite{
    display:block;margin-top:24px;
    font-family:var(--sans);font-style:normal;font-size:12px;
    letter-spacing:0.18em;text-transform:uppercase;color:var(--stein);
  }

  /* Contact / CTA */
  .er-cta{background:var(--creme);padding:88px 0 104px;border-top:1px solid var(--hairline);}
  .er-cta-grid{
    display:grid;grid-template-columns:minmax(0,5fr) minmax(0,7fr);
    gap:56px;align-items:center;
  }
  .er-cta h2{
    font-family:var(--serif);font-weight:500;
    font-size:clamp(28px,3vw,40px);line-height:1.15;letter-spacing:-0.015em;
    color:var(--petrol);margin:0;
  }
  .er-cta .lede{
    font-family:var(--sans);font-size:17px;line-height:1.6;color:var(--stein);margin:0 0 20px;
  }
  .er-cta .contact-card{
    background:#fff;border:1px solid var(--hairline);padding:30px 32px;
    display:flex;flex-direction:column;gap:8px;margin-bottom:22px;
  }
  .er-cta .contact-card .role{
    font-family:var(--sans);font-size:11px;font-weight:600;
    letter-spacing:0.14em;text-transform:uppercase;color:var(--bordeaux);
  }
  .er-cta .contact-card .name{
    font-family:var(--serif);font-weight:500;font-size:24px;line-height:1.2;
    color:var(--petrol);margin:0;
  }
  .er-cta .contact-card .title{
    font-family:var(--sans);font-size:14.5px;color:var(--stein);margin:0;
  }
  .er-cta .cta-row{display:flex;gap:14px;flex-wrap:wrap;}

  @media (max-width:960px){
    .er-intro-grid,.er-cta-grid{grid-template-columns:1fr;gap:32px;}
    .profile-duo{grid-template-columns:1fr;gap:18px;}
    .pillar-row{grid-template-columns:1fr;gap:16px;}
    .values-list{grid-template-columns:1fr;}
    .er-hero{min-height:420px;padding:56px 0 48px;}
    .er-intro,.er-profiles,.er-pillars,.er-values,.er-quote,.er-cta{padding:64px 0;}
  }

  /* ---------- Photo placeholders (to be replaced by real photos) ---------- */
  .photo{position:relative;overflow:hidden;background:var(--creme);border-radius:2px;}
  .photo > img{width:100%;height:100%;object-fit:cover;display:block;transition:transform .5s ease;}
  .photo .cred{
    position:absolute;bottom:10px;left:12px;
    padding:5px 10px;background:rgba(14,77,79,0.78);
    color:rgba(255,255,255,0.95);
    font-family:var(--sans);font-size:10px;font-weight:500;
    letter-spacing:0.12em;text-transform:uppercase;border-radius:2px;
    backdrop-filter:blur(4px);
  }
</style>

<main id="top">

<section class="er-hero" aria-label="Erprobungsstufe">
  <div class="container">
    <span class="kicker"><span class="dot"></span>Unterricht · Erprobungsstufe · Klasse 5 – 6</span>
    <h1>Hier wächst Zukunft.<br>Hier <em>wächst du.</em></h1>
    <p class="lede">Ab dem Schuljahr 2026/27 nimmt die UNESCO-Schule Essen erstmals Schülerinnen und Schüler ab Klasse 5 auf — auf einem Weg voller Energie, Gemeinschaft und Herz.</p>
  </div>
</section>

<section class="er-intro" aria-label="Unser Start mit Klasse 5">
  <div class="container">
    <div class="er-intro-grid">
      <div>
        <div class="photo">
          <img src="assets/sp-lernend.jpg" alt="Schülerinnen und Schüler beim gemeinsamen Lernen">
          <span class="cred">Platzhalter · Foto folgt</span>
        </div>
      </div>
      <div>
        <h2 style="margin:0 0 24px;">Unser Start<br>mit Klasse 5.</h2>
        <p class="lead">Schon in den Einführungstagen lernen sich die Kinder kennen, entdecken neue Lernmethoden und finden sich behutsam in den Schulalltag ein. Bereits zum Start wählen sie einen von zwei Profilschwerpunkten, die ihre Stärken früh sichtbar machen.</p>
        <p>Als UNESCO-Projektschule durchziehen Demokratieerziehung, globales Lernen und interkulturelle Kompetenz unseren Unterricht — vertieft durch internationale Austauschprogramme und Kooperationen mit dem Aalto-Theater und der Philharmonie Essen.</p>
        <p>Ein durchdachtes digitales Lernkonzept ab Klasse 6, eine starke Schulgemeinschaft und ein strukturiertes Beratungsangebot sorgen dafür, dass jede Schülerin und jeder Schüler gezielt gefordert und gefördert wird.</p>
      </div>
    </div>
  </div>
</section>

<section class="er-profiles" aria-label="Zwei Profile">
  <div class="container">
    <div class="head">
      <span class="eyebrow">Zwei Profile ab Klasse 5</span>
      <h2>Schwerpunktklassen —<br>früh Stärken entdecken.</h2>
      <p>In Klasse 5 kann jedes Kind eigene Interessen in einem Profilkurs vertiefen. Hier werden Stärken früh entdeckt und gezielt gefördert.</p>
    </div>
    <div class="profile-duo">
      <article class="profile-card">
        <div class="photo">
          <img src="assets/pillar-quote.jpg" alt="Sprache, Ausdruck, darstellendes Spiel">
          <span class="cred">Platzhalter · Foto folgt</span>
        </div>
        <span class="mark">Profil · Sprachlich-kreativ</span>
        <h3>WortArt⁺</h3>
        <p class="tag">Geschichten entwerfen · Sprache erforschen · Ideen in Szene setzen</p>
        <p>Hier zählt die Kraft von Worten, Ausdruck und Musik. Ob Melodie, Theater, Poetry Slam oder Präsentationen: Kreativität wird zur Bühne für Ausdruckskraft und sicheres Auftreten. Das Profil für alle, die Freude an Texten, Sprache und darstellendem Spiel haben.</p>
      </article>
      <article class="profile-card">
        <div class="photo">
          <img src="assets/sp-nachhaltig.jpg" alt="Experimente, Naturwissenschaften, Forschung">
          <span class="cred">Platzhalter · Foto folgt</span>
        </div>
        <span class="mark">Profil · Forschend-naturwissenschaftlich</span>
        <h3>Forscher²</h3>
        <p class="tag">Fragen stellen · Phänomene erforschen · Experimente entwickeln</p>
        <p>Hier führt Neugier tief in Naturwissenschaft, Technik und Umwelt. Experimente und Messungen werden zu Entdeckungsreisen, die Denken schärfen und Problemlösungsfreude wecken. Das Profil für alle, die neugierig auf Experimente und naturwissenschaftliche Phänomene sind.</p>
      </article>
    </div>
  </div>
</section>

<section class="er-pillars" aria-label="Säulen der Erprobungsstufe">
  <div class="container">
    <div class="head">
      <span class="eyebrow">Drei Säulen der Erprobungsstufe</span>
      <h2>Was bei uns zusammenkommt.</h2>
    </div>
    <div class="pillar-row">
      <article class="er-pillar">
        <div class="photo">
          <img src="assets/sp-weltoffen.jpg" alt="Weltoffen, interkulturell, Erasmus+ Paris">
          <span class="cred">Platzhalter · Foto folgt</span>
        </div>
        <span class="label">Gelebte UNESCO-Werte</span>
        <h3>Toleranz, Verantwortung, Respekt.</h3>
        <p>Projekttage, internationale Austausche und diverse Kooperationen fördern interkulturelle Kompetenz und stärken das Miteinander. Mit Erasmus+ öffnen wir den Blick über Grenzen hinweg — unsere Schülerinnen und Schüler besuchten bereits den UNESCO-Hauptsitz in Paris und unsere Partnerschule, das Lycée Professionnel Léonard de Vinci.</p>
      </article>
      <article class="er-pillar">
        <div class="photo">
          <img src="assets/sp-persoenlich.jpg" alt="Gemeinschaft, Klassenfahrt, Zusammenhalt">
          <span class="cred">Platzhalter · Foto folgt</span>
        </div>
        <span class="label">Ankommen &amp; Kennenlernen</span>
        <h3>Zusammenhalt von Anfang an.</h3>
        <p>Klassenfahrten in den Stufen 7 und 9 stärken Zusammenhalt und Selbstständigkeit. In der Streitschlichter-AG übernehmen Schülerinnen und Schüler Verantwortung für ihre Schulgemeinschaft. Sozialarbeit und Berufsorientierung begleiten die gesamte Schullaufbahn.</p>
      </article>
      <article class="er-pillar">
        <div class="photo">
          <img src="assets/sp-digital.jpg" alt="Digitales Lernen, iPads, Informatik">
          <span class="cred">Platzhalter · Foto folgt</span>
        </div>
        <span class="label">Digitale Bildung</span>
        <h3>Sicher, kreativ, verantwortungsvoll.</h3>
        <p>Mit Informatik ab Klasse 6, kreativen Programmierprojekten in der „Hacker School" und moderner technischer Ausstattung lernen unsere Schülerinnen und Schüler, sich sicher, kreativ und verantwortungsbewusst in der digitalen Welt zu bewegen.</p>
      </article>
    </div>
  </div>
</section>

<section class="er-values" aria-label="Werte">
  <div class="container">
    <div class="head">
      <span class="eyebrow">Tiefe Wurzeln, starke Werte</span>
      <h2>Echtes Lernen heißt:<br>verstehen, verankern, weiterdenken.</h2>
      <p>Nicht nur für die nächste Prüfung, sondern langfristig. So wachsen aus Werten echte Kompetenzen.</p>
    </div>
    <ul class="values-list">
      <li><span class="name">Selbstbewusstsein &amp; Persönlichkeit</span><span class="desc">Die eigene Meinung zu vertreten ist schwer — genau, wie sie überhaupt zu entwickeln. Wer seine Stimme findet, kann auch die Welt mitgestalten.</span></li>
      <li><span class="name">Verantwortung &amp; Empathie</span><span class="desc">Gemeinschaft lebt davon, neue Perspektiven einzunehmen und einander zu verstehen — und für andere und sich einzustehen.</span></li>
      <li><span class="name">Gemeinschaft &amp; Teamgeist</span><span class="desc">Der Mensch ist für Zusammenhalt gemacht: Ob im Beruf oder in Familie und Gesellschaft — Kooperation und Austausch bringen den Einzelnen weiter.</span></li>
      <li><span class="name">Resilienz &amp; Mut</span><span class="desc">Fehler? Gehören dazu. Die Kunst liegt darin, weiterzumachen, dranzubleiben — den Willen und das Vertrauen in sich zu stärken.</span></li>
      <li><span class="name">Kritisches Denken &amp; Neugier</span><span class="desc">Fragen stellen, neue Wege suchen — all das ist wichtiger, als fertige Antworten zu übernehmen.</span></li>
      <li><span class="name">Kreativität &amp; Ausdruck</span><span class="desc">Frei gestalten, Dinge anders zu denken als vorgeschrieben — genau das ist Innovation. Und in unserer schnelllebigen Welt unglaublich wichtig.</span></li>
      <li><span class="name">Weltoffenheit &amp; Vielfalt</span><span class="desc">Menschen sind unterschiedlich. Denken anders, leben anders, sehen anders aus — und das ist ein Geschenk.</span></li>
    </ul>
  </div>
</section>

<section class="er-quote" aria-label="Stimme aus dem Kollegium">
  <div class="container">
    <blockquote>Wenn Kinder hier Mut entwickeln, neugierig bleiben und spüren, dass sie ihren Weg selbst gestalten können — das ist für mich das Größte.</blockquote>
    <cite>Lehrkraft der UNESCO-Schule</cite>
    <span class="cred-full">Platzhalter · Foto folgt</span>
  </div>
</section>

<section class="er-cta" aria-label="Kontakt und nächste Schritte">
  <div class="container">
    <div class="er-cta-grid">
      <div>
        <h2>Ihr persönliches<br>Beratungsgespräch.</h2>
        <p class="lede" style="margin-top:20px;">Unser Beratungsteam steht Ihnen zur Verfügung — zu Profilklassen, Schulalltag und dem Weg zum Abitur. Kommen Sie vorbei, rufen Sie an oder schreiben Sie uns.</p>
      </div>
      <div>
        <div class="contact-card">
          <span class="role">Ansprechpartner</span>
          <span class="name">Sven Scheding</span>
          <span class="title">komm. Erprobungsstufenleiter</span>
        </div>
        <p style="font-family:var(--sans);font-size:17px;line-height:1.6;color:var(--petrol);margin:0 0 22px;">
          <a href="tel:+492012802630" style="color:var(--petrol);font-weight:500;">0201 · 280 26 30</a><br>
          <a href="mailto:info@unesco-schule-essen.de" style="color:var(--petrol);font-weight:500;">info@unesco-schule-essen.de</a>
        </p>
        <div class="cta-row">
          <a href="index.html#wegzuuns" class="btn btn-primary">Tag der offenen Tür <span class="arrow">→</span></a>
          <a href="mailto:info@unesco-schule-essen.de" class="btn btn-secondary">Gespräch vereinbaren <span class="arrow">→</span></a>
        </div>
      </div>
    </div>
  </div>
</section>

</main>
</BaseLayout>

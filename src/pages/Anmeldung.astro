---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import ContactCard from "../components/ContactCard.astro";
import { getSingle } from "../lib/pageContent";
import { getTeacherByRole, ROLES } from "../lib/roles";

// Editierbare Inhalte aus src/content/pages/anmeldung.yml (Sveltia)
const an = await getSingle("pageAnmeldung");
const school = await getSingle("siteSchool");

const [koordEprob, koordOberstufe] = await Promise.all([
  getTeacherByRole(ROLES.KOORD_ERPROBUNGSSTUFE),
  getTeacherByRole(ROLES.KOORD_OBERSTUFE),
]);
---
<BaseLayout title="Anmeldung — UNESCO-Schule Essen">
<style is:global>
  /* ---------- Anmeldung ---------- */

  /* Way-chooser: two big entrance cards */
  .an-choose{background:var(--creme);padding:var(--space-section) 0;}
  .an-choose .head{max-width:760px;margin:0 auto 48px;text-align:center;}
  .an-choose .head .eyebrow{display:block;margin-bottom:14px;}
  .an-choose .head h2{
    font-family:var(--serif);font-weight:500;
    font-size:clamp(30px,3.4vw,44px);line-height:1.12;letter-spacing:-0.015em;
    color:var(--petrol);margin:0 0 14px;
  }
  .an-choose .head p{
    font-family:var(--sans);font-size:17px;line-height:1.65;color:var(--stein);
    margin:0;
  }
  .choose-grid{
    display:grid;grid-template-columns:1fr 1fr;gap:28px;
  }
  .choose-card{
    background:#fff;border:1px solid var(--hairline);
    border-top:var(--card-accent-width) solid var(--petrol);
    padding:40px 36px 32px;
    display:flex;flex-direction:column;gap:16px;
    text-decoration:none;color:inherit;
    transition:transform var(--transition), box-shadow var(--transition);
  }
  .choose-card.is-dark{background:var(--petrol);color:var(--creme);border-color:var(--petrol);border-top-color:var(--gold);}
  .choose-card:hover{transform:translateY(-2px);box-shadow:0 18px 44px -24px rgba(14,77,79,0.35);}
  @media (prefers-reduced-motion: reduce){.choose-card:hover{transform:none;}}
  .choose-card .mark{
    font-family:var(--sans);font-size:11px;font-weight:600;
    letter-spacing:0.14em;text-transform:uppercase;color:var(--petrol);
  }
  .choose-card.is-dark .mark{color:var(--gold);}
  .choose-card h3{
    font-family:var(--serif);font-weight:500;
    font-size:clamp(24px,2.4vw,32px);line-height:1.15;
    color:var(--petrol);letter-spacing:-0.01em;margin:0;
  }
  .choose-card.is-dark h3{color:var(--creme);}
  .choose-card h3 .accent{font-style:italic;color:var(--bordeaux);font-weight:500;}
  .choose-card.is-dark h3 .accent{color:var(--gold);}
  .choose-card p{
    font-family:var(--sans);font-size:15.5px;line-height:1.65;color:var(--tinte);
    margin:0;flex:1;
  }
  .choose-card.is-dark p{color:rgba(245,239,231,0.9);}
  .choose-card .go{
    display:inline-flex;align-items:center;gap:8px;
    margin-top:4px;
    font-family:var(--sans);font-size:14px;font-weight:500;
    color:var(--bordeaux);
    border-bottom:1px solid currentColor;align-self:flex-start;padding-bottom:2px;
  }
  .choose-card.is-dark .go{color:var(--gold);}
  .choose-card:hover .go{transform:translateX(0);}

  /* === Klasse 5 block === */
  .an-k5{background:var(--offwhite);padding:var(--space-section) 0;border-top:1px solid var(--hairline);scroll-margin-top:120px;}
  .an-k5 .head{max-width:820px;margin:0 0 48px;}
  .an-k5 .head .eyebrow{display:block;margin-bottom:14px;color:var(--bordeaux);}
  .an-k5 .head h2{
    font-family:var(--serif);font-weight:500;
    font-size:clamp(32px,3.6vw,52px);line-height:1.1;letter-spacing:-0.02em;
    color:var(--petrol);margin:0 0 18px;
  }
  .an-k5 .head h2 em{font-style:italic;color:var(--bordeaux);}
  .an-k5 .head p{
    font-family:var(--sans);font-size:17px;line-height:1.65;color:var(--stein);
    max-width:680px;margin:0;
  }

  /* Termine panel */
  .termine{
    background:#fff;border:1px solid var(--hairline);
    border-top:var(--card-accent-width) solid var(--petrol);
    display:grid;grid-template-columns:minmax(0,4fr) minmax(0,8fr);
    margin-bottom:48px;
  }
  .termine .intro{
    padding:32px 36px;background:var(--creme);
    display:flex;flex-direction:column;gap:10px;
    border-right:1px solid var(--hairline);
  }
  .termine .intro .kicker{
    font-family:var(--sans);font-size:11px;font-weight:600;
    letter-spacing:0.14em;text-transform:uppercase;color:var(--bordeaux);
  }
  .termine .intro h3{
    font-family:var(--serif);font-weight:500;font-size:22px;line-height:1.2;
    color:var(--petrol);letter-spacing:-0.008em;margin:0;
  }
  .termine .intro p{
    font-family:var(--sans);font-size:14.5px;line-height:1.6;color:var(--stein);margin:0;
  }
  .termine ol{
    list-style:none;margin:0;padding:0;
    display:flex;flex-direction:column;
  }
  .termine ol li{
    display:grid;grid-template-columns:auto 1fr auto;gap:20px;align-items:baseline;
    padding:16px 28px;border-bottom:1px solid var(--hairline);
    font-variant-numeric:tabular-nums;
  }
  .termine ol li:last-child{border-bottom:0;}
  .termine ol li .date{
    font-family:var(--serif);font-weight:500;font-size:22px;line-height:1;
    color:var(--petrol);letter-spacing:-0.005em;min-width:110px;
  }
  .termine ol li .day{
    font-family:var(--sans);font-size:14.5px;color:var(--tinte);
  }
  .termine ol li .time{
    font-family:var(--sans);font-size:13.5px;color:var(--stein);
    letter-spacing:0.02em;
  }

  /* Steps */
  .an-steps{margin-bottom:48px;}
  .an-steps .sub{
    font-family:var(--sans);font-size:12px;font-weight:600;
    letter-spacing:0.14em;text-transform:uppercase;color:var(--bordeaux);
    margin-bottom:10px;
  }
  .an-steps h3{
    font-family:var(--serif);font-weight:500;font-size:clamp(24px,2.6vw,32px);
    line-height:1.15;color:var(--petrol);letter-spacing:-0.012em;margin:0 0 28px;
  }
  .steps-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:24px;}
  .step{
    background:#fff;border:1px solid var(--hairline);
    border-top:var(--card-accent-width) solid var(--petrol);
    padding:var(--card-padding);
    display:flex;flex-direction:column;gap:14px;
  }
  .step .n{
    font-family:var(--serif);font-weight:500;font-size:38px;line-height:1;
    color:var(--petrol);letter-spacing:-0.02em;font-variant-numeric:tabular-nums;
  }
  .step h4{
    font-family:var(--serif);font-weight:500;font-size:22px;line-height:1.2;
    color:var(--petrol);letter-spacing:-0.008em;margin:0;
  }
  .step p{
    font-family:var(--sans);font-size:15px;line-height:1.65;color:var(--tinte);margin:0;
  }
  .step p + p{margin-top:10px;}
  .step a.action{
    align-self:flex-start;margin-top:4px;
    font-family:var(--sans);font-size:14px;font-weight:500;color:var(--bordeaux);
    border-bottom:1px solid currentColor;padding-bottom:2px;text-decoration:none;
    display:inline-flex;align-items:center;gap:6px;
  }
  .step a.action:hover{color:var(--petrol-dark);}

  /* Why UNESCO (three cards) */
  .an-why{margin-top:8px;}
  .an-why .sub{
    font-family:var(--sans);font-size:12px;font-weight:600;
    letter-spacing:0.14em;text-transform:uppercase;color:var(--bordeaux);
    margin-bottom:10px;
  }
  .an-why h3{
    font-family:var(--serif);font-weight:500;font-size:clamp(24px,2.6vw,32px);
    line-height:1.15;color:var(--petrol);letter-spacing:-0.012em;margin:0 0 28px;
  }
  .why-grid{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:28px;}
  .why-card{
    background:var(--creme);border:1px solid var(--hairline);
    padding:var(--card-padding);
    display:flex;flex-direction:column;gap:10px;
  }
  .why-card .photo{
    aspect-ratio:4/3;margin:-32px -32px 12px;
    background:var(--offwhite);
    display:flex;align-items:center;justify-content:center;
    font-family:var(--sans);font-size:11.5px;letter-spacing:0.12em;
    text-transform:uppercase;color:var(--stein);
    border-bottom:1px solid var(--hairline);
  }
  .why-card h4{
    font-family:var(--serif);font-weight:500;font-size:20px;line-height:1.2;
    color:var(--petrol);letter-spacing:-0.008em;margin:0;
  }
  .why-card p{
    font-family:var(--sans);font-size:14.5px;line-height:1.6;color:var(--tinte);margin:0;
  }

  /* === Oberstufe block — dark, inverted theme === */
  .an-q{
    background:var(--petrol);color:var(--creme);
    padding:var(--space-section) 0;scroll-margin-top:120px;
    position:relative;
  }
  .an-q .head{max-width:820px;margin:0 0 48px;}
  .an-q .head .eyebrow{display:block;margin-bottom:14px;color:var(--gold);}
  .an-q .head h2{
    font-family:var(--serif);font-weight:500;
    font-size:clamp(32px,3.6vw,52px);line-height:1.1;letter-spacing:-0.02em;
    color:var(--creme);margin:0 0 18px;
  }
  .an-q .head h2 em{font-style:italic;color:var(--gold);}
  .an-q .head p{
    font-family:var(--sans);font-size:17px;line-height:1.65;
    color:rgba(245,239,231,0.88);max-width:680px;margin:0;
  }

  /* For whom */
  .an-q-target{
    background:rgba(245,239,231,0.06);border:1px solid rgba(245,239,231,0.15);
    padding:28px 32px;margin-bottom:40px;
    border-left:var(--card-accent-width) solid var(--gold);
  }
  .an-q-target h3{
    font-family:var(--sans);font-size:11px;font-weight:600;
    letter-spacing:0.14em;text-transform:uppercase;color:var(--gold);margin:0 0 12px;
  }
  .an-q-target ul{list-style:none;margin:0;padding:0;display:grid;grid-template-columns:1fr 1fr;gap:10px 28px;}
  .an-q-target li{
    position:relative;padding-left:22px;
    font-family:var(--sans);font-size:15px;line-height:1.55;color:rgba(245,239,231,0.92);
  }
  .an-q-target li::before{
    content:"";position:absolute;left:0;top:10px;
    width:12px;height:1px;background:var(--gold);
  }

  /* Q-Steps (list) */
  .q-steps{
    list-style:none;margin:0 0 40px;padding:0;
    display:flex;flex-direction:column;gap:2px;
    background:rgba(245,239,231,0.15);
    border:1px solid rgba(245,239,231,0.15);
  }
  .q-steps li{
    background:var(--petrol);
    display:grid;grid-template-columns:72px 1fr;gap:24px;align-items:start;
    padding:24px 28px;
  }
  .q-steps li .num{
    font-family:var(--serif);font-weight:500;font-size:40px;line-height:1;
    color:var(--gold);letter-spacing:-0.025em;font-variant-numeric:tabular-nums;
  }
  .q-steps li h4{
    font-family:var(--serif);font-weight:500;font-size:20px;line-height:1.2;
    color:var(--creme);letter-spacing:-0.008em;margin:0 0 6px;
  }
  .q-steps li p{
    font-family:var(--sans);font-size:14.5px;line-height:1.6;
    color:rgba(245,239,231,0.82);margin:0;
  }
  .q-steps li p a{color:var(--gold);border-bottom:1px solid currentColor;}

  /* Download + contact */
  .an-q-foot{
    display:grid;grid-template-columns:minmax(0,1fr) minmax(0,1fr);gap:24px;
  }
  .q-download{
    background:var(--gold);color:#2a1d08;
    display:flex;align-items:center;gap:14px;
    padding:24px 28px;text-decoration:none;
    transition:background var(--transition-fast), transform var(--transition-fast);
  }
  .q-download:hover{background:#e0b68a;transform:translateY(-1px);color:#2a1d08;}
  @media (prefers-reduced-motion: reduce){.q-download:hover{transform:none;}}
  .q-download .icon{
    width:40px;height:40px;flex-shrink:0;
    display:flex;align-items:center;justify-content:center;
    background:rgba(42,29,8,0.12);border-radius:50%;
  }
  .q-download .icon svg{width:20px;height:20px;fill:currentColor;}
  .q-download .txt{display:flex;flex-direction:column;gap:2px;}
  .q-download .title{font-family:var(--sans);font-weight:600;font-size:15px;}
  .q-download .meta{font-family:var(--sans);font-size:12px;color:#5e3f12;letter-spacing:0.04em;}

  /* Klasse-5-Ansprechpartner-Block */
  .an-k5-contact{
    margin-top:48px;display:grid;grid-template-columns:minmax(0,5fr) minmax(0,7fr);
    gap:32px;align-items:center;
    padding-top:40px;border-top:1px solid var(--hairline);
  }
  .an-k5-contact .lead h3{
    font-family:var(--serif);font-weight:500;
    font-size:clamp(24px,2.4vw,32px);line-height:1.2;
    color:var(--petrol);letter-spacing:-0.01em;margin:0 0 12px;
  }
  .an-k5-contact .lead p{
    font-family:var(--sans);font-size:16px;line-height:1.6;color:var(--stein);margin:0;
  }
  @media (max-width:960px){
    .an-k5-contact{grid-template-columns:1fr;gap:20px;}
  }

  /* Closing CTA */
  .an-closing{background:var(--creme);padding:var(--space-section) 0;border-top:1px solid var(--hairline);}
  .an-closing-grid{
    display:grid;grid-template-columns:minmax(0,5fr) minmax(0,7fr);gap:56px;align-items:center;
  }
  .an-closing h2{
    font-family:var(--serif);font-weight:500;
    font-size:clamp(28px,3vw,40px);line-height:1.15;
    color:var(--petrol);letter-spacing:-0.015em;margin:0;
  }
  .an-closing p{
    font-family:var(--sans);font-size:17px;line-height:1.65;color:var(--stein);
    margin:0 0 20px;
  }
  .an-closing .cta-row{display:flex;gap:14px;flex-wrap:wrap;}

  @media (max-width:960px){
    .choose-grid{grid-template-columns:1fr;gap:16px;}
    .termine{grid-template-columns:1fr;}
    .termine .intro{border-right:0;border-bottom:1px solid var(--hairline);}
    .termine ol li{grid-template-columns:auto 1fr;gap:10px 16px;}
    .termine ol li .time{grid-column:1 / -1;}
    .steps-grid{grid-template-columns:1fr;gap:14px;}
    .why-grid{grid-template-columns:1fr;gap:14px;}
    .an-q-target ul{grid-template-columns:1fr;}
    .q-steps li{grid-template-columns:48px 1fr;gap:14px;padding:20px 22px;}
    .q-steps li .num{font-size:30px;}
    .an-q-foot{grid-template-columns:1fr;}
    .an-closing-grid{grid-template-columns:1fr;gap:24px;}
    .an-choose,.an-k5,.an-q,.an-closing{padding:var(--space-section-sm) 0;}
  }
</style>

<main id="top">

<PageHero variant="feature">
  <Fragment slot="eyebrow">{an.hero.eyebrow}</Fragment>
  <Fragment slot="title">{an.hero.title}{an.hero.titleHighlight && <><br /><em>{an.hero.titleHighlight}</em></>}</Fragment>
  <Fragment slot="lede">{an.hero.lede}</Fragment>
</PageHero>

<section class="an-choose" aria-label="Welcher Weg passt für Sie">
  <div class="container">
    <div class="head">
      <span class="eyebrow">Zwei Wege</span>
      <h2>Wählen Sie Ihren Weg.</h2>
      <p>Sie möchten Ihr Kind neu anmelden — oder in die Oberstufe wechseln? Hier finden Sie alles Wichtige auf einen Blick.</p>
    </div>

    <div class="choose-grid">
      <a href="#klasse-5" class="choose-card">
        <span class="mark">Weg A · Für Eltern</span>
        <h3>Anmeldung zur <span class="accent">Klasse&nbsp;5.</span></h3>
        <p>Ihr Kind kommt aus der Grundschule und startet bei uns ins Gymnasium — mit einem Profilkurs ab dem ersten Tag.</p>
        <span class="go">Zu den Anmeldeterminen →</span>
      </a>

      <a href="#oberstufe" class="choose-card is-dark">
        <span class="mark">Weg B · Für Schulwechsel</span>
        <h3>Wechsel in die <span class="accent">Oberstufe.</span></h3>
        <p>Sie haben die Klasse&nbsp;10 abgeschlossen und wollen bei uns Abitur machen — wir beraten Sie persönlich.</p>
        <span class="go">Zum Ablauf →</span>
      </a>
    </div>
  </div>
</section>

<!-- =================== KLASSE 5 =================== -->
<section class="an-k5" id="klasse-5" aria-label="Anmeldung Klasse 5">
  <div class="container">
    <div class="head">
      <span class="eyebrow">{an.klasse5.eyebrow}</span>
      <h2>{an.klasse5.title}{an.klasse5.titleHighlight && <><br /><em>{an.klasse5.titleHighlight}</em></>}</h2>
      <p>{an.klasse5.intro}</p>
    </div>

    <!-- Termine -->
    <div class="termine">
      <div class="intro">
        <span class="kicker">{an.termine.kicker}</span>
        <h3>{an.termine.title}</h3>
        <p>{an.termine.intro}</p>
      </div>
      <ol>
        {an.termine.list.map((t) => (
          <li><span class="date">{t.date}</span><span class="day">{t.day}</span><span class="time">{t.time}</span></li>
        ))}
      </ol>
    </div>

    <!-- Steps -->
    <div class="an-steps">
      <div class="sub">So läuft die Anmeldung</div>
      <h3>Drei Schritte zum Anmeldegespräch.</h3>
      <div class="steps-grid">
        <article class="step">
          <span class="n">01</span>
          <h4>Termin vereinbaren</h4>
          <p>Rufen Sie uns an oder buchen Sie online einen verbindlichen Termin im Koordinierungsverfahren.</p>
          <p><a href="tel:+492012802630" class="action">0201 · 280&nbsp;26&nbsp;30 →</a></p>
        </article>
        <article class="step">
          <span class="n">02</span>
          <h4>Formular ausfüllen</h4>
          <p>Bitte laden Sie das Anmeldeformular hier herunter und bringen Sie es ausgefüllt und ausgedruckt mit.</p>
          <a href="#" class="action" aria-disabled="true">Anmeldeformular (PDF, folgt) →</a>
        </article>
        <article class="step">
          <span class="n">03</span>
          <h4>Gemeinsam zum Gespräch</h4>
          <p>Kommen Sie mit Ihrem Kind. Das persönliche Gespräch ist uns wichtig — wir möchten Ihr Kind kennenlernen und besprechen, wie wir es am besten fordern und fördern.</p>
        </article>
      </div>
    </div>

    <!-- Why UNESCO -->
    <div class="an-why">
      <div class="sub">Was Ihr Kind bei uns erwartet</div>
      <h3>Drei Gründe für die UNESCO-Schule.</h3>
      <div class="why-grid">
        <article class="why-card">
          <div class="photo" role="img" aria-label="Platzhalter: Profilkurs">Foto · folgt</div>
          <h4>Zwei Profilklassen ab Klasse&nbsp;5</h4>
          <p>Ihr Kind wählt ab dem ersten Tag einen Schwerpunkt — naturwissenschaftlich oder sprachlich-künstlerisch. So entsteht ein Lernumfeld, das fordert und fördert.</p>
        </article>
        <article class="why-card">
          <div class="photo" role="img" aria-label="Platzhalter: Werte">Foto · folgt</div>
          <h4>Klare Werte, klare Haltung</h4>
          <p>Kulturelle Bildung, globales Denken und demokratisches Handeln sind an unserer Schule selbstverständlicher Teil des Unterrichts. Wer hier Abitur macht, nimmt mehr mit als einen Abschluss.</p>
        </article>
        <article class="why-card">
          <div class="photo" role="img" aria-label="Platzhalter: International">Foto · folgt</div>
          <h4>International unterwegs</h4>
          <p>Austauschprogramme nach Paris und Estland, dazu Model United Nations: Ihre Kinder erleben globales Lernen vor Ort — und entwickeln die Kompetenz, sich in einer vernetzten Welt sicher zu bewegen.</p>
        </article>
      </div>
    </div>

    <!-- Persönlicher Ansprechpartner Klasse 5 -->
    <div class="an-k5-contact">
      <div class="lead">
        <h3>Ihr Ansprechpartner für die Anmeldung in Klasse 5.</h3>
        <p>Persönliche Beratung zu Profilklassen, Schulalltag und Anmeldung. Rufen Sie an oder schreiben Sie eine E-Mail, wir nehmen uns Zeit.</p>
      </div>
      <ContactCard
        teacher={koordEprob}
        roleLabel="Ihr Ansprechpartner · Erprobungsstufenkoordination"
        subline="Klassen 5 und 6"
        variant="compact"
      />
    </div>
  </div>
</section>

<!-- =================== OBERSTUFE =================== -->
<section class="an-q" id="oberstufe" aria-label="Anmeldung zur Oberstufe">
  <div class="container">
    <div class="head">
      <span class="eyebrow">Weg B · Oberstufe</span>
      <h2>Wechsel in die<br><em>gymnasiale Oberstufe.</em></h2>
      <p>Sie möchten nach Klasse&nbsp;10 zu uns wechseln und Ihren Weg zum Abitur oder zur Fachhochschulreife mit uns gehen? Wir begleiten Sie individuell — von der ersten Kontaktaufnahme bis zum Schuljahresbeginn.</p>
    </div>

    <!-- For whom -->
    <div class="an-q-target">
      <h3>Für wen ist dieser Weg gedacht?</h3>
      <ul>
        <li>Schülerinnen und Schüler mit Versetzung in Klasse&nbsp;10 (oder gleichwertig)</li>
        <li>Wechsel von anderen Schulformen — Realschule, Gesamtschule, Gymnasium</li>
        <li>Seiteneinsteigerinnen und Seiteneinsteiger mit mittlerem Schulabschluss</li>
        <li>Interessierte am Abitur oder an der Fachhochschulreife (schulischer Teil)</li>
      </ul>
    </div>

    <!-- Steps -->
    <ol class="q-steps" aria-label="Ablauf der Aufnahme in die Oberstufe">
      <li>
        <span class="num">01</span>
        <div>
          <h4>Kontakt aufnehmen</h4>
          <p>Rufen Sie uns an oder schreiben Sie uns. Wir klären mit Ihnen in wenigen Minuten, ob und wann ein Beratungsgespräch sinnvoll ist.</p>
        </div>
      </li>
      <li>
        <span class="num">02</span>
        <div>
          <h4>Beratungsgespräch</h4>
          <p>Im persönlichen Gespräch mit der Oberstufenkoordination besprechen wir Bildungsweg, Fächerwahl und individuelle Perspektiven — verbindlich, aber ohne Verpflichtung.</p>
        </div>
      </li>
      <li>
        <span class="num">03</span>
        <div>
          <h4>Unterlagen einreichen</h4>
          <p>Zeugniskopie, Lebenslauf und eine Kopie des Personalausweises oder der Geburtsurkunde — das war's im Kern. Alle Details erhalten Sie im Beratungsgespräch.</p>
        </div>
      </li>
      <li>
        <span class="num">04</span>
        <div>
          <h4>Aufnahme und Start in der EF</h4>
          <p>Nach Prüfung der Unterlagen erhalten Sie eine verbindliche Aufnahmebestätigung. Den Start erleichtert unsere Kennenlern- und Methodenfahrt zu Beginn der Einführungsphase.</p>
        </div>
      </li>
    </ol>

    <!-- Download + Contact -->
    <div class="an-q-foot">
      <a href="assets/GO2026.pdf" class="q-download" download>
        <span class="icon">
          <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M12 3v12m0 0l-4-4m4 4l4-4M5 21h14" stroke="currentColor" stroke-width="2" fill="none" stroke-linecap="round" stroke-linejoin="round"/></svg>
        </span>
        <span class="txt">
          <span class="title">Informationsbroschüre Oberstufe</span>
          <span class="meta">PDF · 2,2&#8239;MB · Alle Details zum Bildungsgang</span>
        </span>
      </a>

      <ContactCard
        teacher={koordOberstufe}
        roleLabel="Ihr Ansprechpartner · Oberstufenkoordination"
        subline="Persönliche Beratung zu Aufnahme, Fächerwahl und Bildungsweg"
        variant="dark"
      />
    </div>
  </div>
</section>


---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import ContactCard from "../components/ContactCard.astro";
import { getTeacherByRole, ROLES } from "../lib/roles";
import { getSingle } from "../lib/pageContent";

const page: any = await getSingle("pageSchulleitung");

// Zentrale Datenbindung: alle Personen kommen aus src/content/teachers/.
const [
  schulleiterin,
  stellv,
  koordOberstufe,
  koordMittelstufe,
  koordEprob,
  sekretariat,
] = await Promise.all([
  getTeacherByRole(ROLES.SCHULLEITUNG),
  getTeacherByRole(ROLES.STELLV_SCHULLEITUNG),
  getTeacherByRole(ROLES.KOORD_OBERSTUFE),
  getTeacherByRole(ROLES.KOORD_MITTELSTUFE),
  getTeacherByRole(ROLES.KOORD_ERPROBUNGSSTUFE),
  getTeacherByRole(ROLES.SEKRETARIAT),
]);
---
<BaseLayout title="Schulleitung und Sekretariat · UNESCO-Schule Essen">
<style is:global>
  /* People */
  .sl-team{background:var(--offwhite);padding:var(--space-section) 0;}
  .sl-team .head{max-width:760px;margin:0 0 48px;}
  .sl-team .head .eyebrow{display:block;margin-bottom:14px;}
  .sl-team .head h2{
    font-family:var(--serif);font-weight:500;
    font-size:clamp(30px,3.2vw,44px);line-height:1.15;letter-spacing:-0.015em;
    color:var(--petrol);margin:0;
  }
  .sl-people{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:24px;}

  @media (max-width:960px){
    .sl-people{grid-template-columns:1fr;gap:16px;}
    .sl-team{padding:48px 0;}
  }
</style>

<main id="top">

<PageHero variant="page">
  <Fragment slot="eyebrow">{page.hero.eyebrow}</Fragment>
  <Fragment slot="title">{page.hero.title}</Fragment>
  <Fragment slot="lede">{page.hero.lede}</Fragment>
</PageHero>

<section class="sl-team" aria-label="Das Team">
  <div class="container">
    <div class="head">
      <span class="eyebrow">{page.team.eyebrow}</span>
      <h2>{page.team.title}</h2>
    </div>
    <div class="sl-people">
      <ContactCard teacher={schulleiterin} roleLabel="Schulleiterin" />
      <ContactCard teacher={stellv} roleLabel="Stellvertretende Schulleitung" />
      <ContactCard teacher={koordOberstufe} roleLabel="Koordination · Oberstufe" />
      <ContactCard teacher={koordMittelstufe} roleLabel="Koordination · Mittelstufe" />
      <ContactCard teacher={koordEprob} roleLabel="Koordination · Erprobungsstufe" />
      <ContactCard teacher={sekretariat} roleLabel="Sekretariat" />
    </div>
  </div>
</section>

</main>
</BaseLayout>

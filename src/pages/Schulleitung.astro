---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
---
<BaseLayout title="Schulleitung und Sekretariat — UNESCO-Schule Essen">
<style is:global>
  /* Office info card */
  .sl-office{background:var(--offwhite);padding:var(--space-section) 0 var(--space-section-sm);}
  .office-card{
    background:#fff;border:1px solid var(--hairline);
    border-top:3px solid var(--petrol);
    padding:36px 40px;
    display:grid;grid-template-columns:auto 1fr 1fr 1fr;gap:32px;align-items:center;
  }
  .office-card .brand{
    font-family:var(--serif);font-weight:500;font-size:20px;
    color:var(--petrol);letter-spacing:-0.005em;max-width:220px;
  }
  .office-card .col{display:flex;flex-direction:column;gap:4px;}
  .office-card .col .lbl{
    font-family:var(--sans);font-size:10.5px;font-weight:600;
    letter-spacing:0.14em;text-transform:uppercase;color:var(--stein);
  }
  .office-card .col a, .office-card .col span.val{
    font-family:var(--sans);font-size:16px;font-weight:500;color:var(--petrol);line-height:1.35;
  }
  .office-card .col a:hover{text-decoration:underline;}

  /* People */
  .sl-team{background:var(--offwhite);padding:24px 0 var(--space-section);}
  .sl-team .head{max-width:760px;margin:0 0 48px;}
  .sl-team .head .eyebrow{display:block;margin-bottom:14px;}
  .sl-team .head h2{
    font-family:var(--serif);font-weight:500;
    font-size:clamp(30px,3.2vw,44px);line-height:1.15;letter-spacing:-0.015em;
    color:var(--petrol);margin:0;
  }
  .people{display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:24px;}
  .person{
    background:#fff;border:1px solid var(--hairline);
    border-top:var(--card-accent-width) solid var(--petrol);
    padding:var(--card-padding);
    display:flex;flex-direction:column;gap:16px;
    transition:transform var(--transition), box-shadow var(--transition);
  }
  .person:hover{transform:translateY(-2px);box-shadow:0 16px 36px -22px rgba(14,77,79,0.3);}
  @media (prefers-reduced-motion: reduce){.person:hover{transform:none;}}
  .avatar{
    width:100px;height:100px;border-radius:50%;
    display:flex;align-items:center;justify-content:center;
    font-family:var(--serif);font-weight:500;font-size:36px;line-height:1;
    letter-spacing:-0.02em;color:var(--creme);
    background:var(--petrol);
    position:relative;
  }
  .avatar::after{
    content:"Platzhalter";
    position:absolute;bottom:-6px;right:-6px;
    font-family:var(--sans);font-size:8px;font-weight:500;
    letter-spacing:0.1em;text-transform:uppercase;
    padding:3px 6px;border-radius:2px;
    background:var(--gold);color:#3a2a10;
  }
  .person.lead .avatar{background:var(--bordeaux);}
  .person.deputy .avatar{background:#8f3a4e;}
  .person.coord .avatar{background:var(--petrol);}
  .person.office .avatar{background:#4a6b20;}
  .person .name{
    font-family:var(--serif);font-weight:500;font-size:22px;line-height:1.15;
    color:var(--petrol);letter-spacing:-0.008em;margin:0;
  }
  .person .role{
    font-family:var(--sans);font-size:12px;font-weight:600;
    letter-spacing:0.12em;text-transform:uppercase;color:var(--bordeaux);margin:0;
  }
  .person .contact{
    font-family:var(--sans);font-size:14.5px;line-height:1.6;color:var(--stein);
    padding-top:12px;border-top:1px solid var(--hairline);
  }
  .person .contact a{color:var(--petrol);}

  /* Note about Erprobungsstufe */
  .sl-note{
    background:var(--creme);padding:var(--space-section-sm) 0;border-top:1px solid var(--hairline);
  }
  .sl-note .inner{
    display:grid;grid-template-columns:auto 1fr;gap:36px;align-items:center;
    padding:32px 40px;background:#fff;border:1px solid var(--hairline);
    border-left:3px solid var(--gold);
  }
  .sl-note .icon{
    width:64px;height:64px;border-radius:50%;
    background:rgba(212,165,116,0.2);color:#8a5a20;
    display:flex;align-items:center;justify-content:center;
    font-family:var(--serif);font-weight:500;font-size:28px;
  }
  .sl-note h3{
    font-family:var(--serif);font-weight:500;font-size:24px;line-height:1.2;
    color:var(--petrol);letter-spacing:-0.008em;margin:0 0 6px;
  }
  .sl-note p{
    font-family:var(--sans);font-size:15.5px;line-height:1.6;color:var(--stein);margin:0;
  }

  @media (max-width:960px){
    .office-card{grid-template-columns:1fr;gap:16px;}
    .people{grid-template-columns:1fr;gap:16px;}
    .sl-note .inner{grid-template-columns:1fr;gap:16px;padding:24px 28px;}
    .sl-team,.sl-office,.sl-note{padding:48px 0;}
  }
</style>


---
import BaseLayout from "../layouts/BaseLayout.astro";
---
<BaseLayout title="Schulprogramm — UNESCO-Schule Essen">
<style is:global>
/* ---------- Schulprogramm page ---------- */
  .sp-hero{
    position:relative;
    min-height:520px;
    display:flex;align-items:flex-end;
    padding:72px 0 64px;
    color:var(--creme);
    overflow:hidden;
    isolation:isolate;
  }
  .sp-hero::before{
    content:"";position:absolute;inset:0;z-index:-2;
    background:url('assets/sp-hero.jpg') center/cover no-repeat;
  }
  .sp-hero::after{
    content:"";position:absolute;inset:0;z-index:-1;
    background:linear-gradient(180deg, rgba(14,77,79,0.55) 0%, rgba(14,77,79,0.85) 80%);
  }
  .sp-hero .eyebrow{
    color:rgba(245,239,231,0.75);display:block;margin-bottom:18px;
  }
  .sp-hero h1{
    font-family:var(--serif);font-weight:500;
    font-size:clamp(44px,6vw,84px);line-height:1.02;
    letter-spacing:-0.02em;
    max-width:1000px;margin:0 0 20px;
    color:var(--creme);
  }
  .sp-hero p.lede{
    font-family:var(--sans);font-size:18px;line-height:1.6;
    color:rgba(245,239,231,0.9);
    max-width:640px;margin:0;
  }

  /* ---------- Intro ---------- */
  .sp-intro{
    background:var(--creme);
    padding:96px 0;
  }
  .sp-intro-grid{
    display:grid;grid-template-columns:minmax(0,5fr) minmax(0,7fr);
    gap:72px;align-items:start;
  }
  .sp-intro h2{
    font-family:var(--serif);font-weight:500;
    font-size:clamp(32px,3.4vw,48px);line-height:1.1;
    color:var(--petrol);letter-spacing:-0.012em;margin:0;
  }
  .sp-intro .lead{
    font-family:var(--sans);font-size:17px;line-height:1.7;color:var(--tinte);
    margin:0 0 18px;
  }
  .sp-intro p + p{margin-top:14px;}
  .sp-intro p em{font-style:italic;color:var(--bordeaux);}

  /* ---------- Pledge (Selbstverpflichtung) ---------- */
  .sp-pledge{
    background:var(--petrol);color:var(--creme);
    padding:96px 0;position:relative;overflow:hidden;
  }
  .sp-pledge .eyebrow{
    color:rgba(245,239,231,0.6);display:block;margin-bottom:16px;
  }
  .sp-pledge h2{
    font-family:var(--serif);font-weight:500;
    font-size:clamp(30px,3.2vw,44px);line-height:1.12;
    color:var(--creme);margin:0 0 36px;max-width:780px;letter-spacing:-0.012em;
  }
  .sp-pledge .intro{
    font-family:var(--sans);font-size:17px;line-height:1.65;
    color:rgba(245,239,231,0.9);max-width:760px;margin:0 0 40px;
  }
  .pledge-list{
    list-style:none;margin:0;padding:0;
    display:grid;grid-template-columns:repeat(2,minmax(0,1fr));
    gap:1px;
    background:rgba(245,239,231,0.15);
    border:1px solid rgba(245,239,231,0.15);
  }
  .pledge-list li{
    background:var(--petrol);
    padding:26px 28px;
    display:flex;gap:18px;align-items:flex-start;
  }
  .pledge-list .num{
    font-family:var(--serif);font-weight:500;font-size:32px;line-height:1;
    color:var(--gold);flex-shrink:0;letter-spacing:-0.02em;
  }
  .pledge-list .text{
    font-family:var(--sans);font-size:15px;line-height:1.55;
    color:rgba(245,239,231,0.95);
  }
  .pledge-outro{
    font-family:var(--sans);font-size:15px;line-height:1.7;color:rgba(245,239,231,0.8);
    max-width:780px;margin:40px 0 0;font-style:italic;
  }

  /* ---------- Leitsätze Intro ---------- */
  .sp-pillars-intro{
    background:var(--offwhite);
    padding:96px 0 48px;
  }
  .sp-pillars-intro .eyebrow{display:block;margin-bottom:16px;}
  .sp-pillars-intro h2{
    font-family:var(--serif);font-weight:500;font-size:clamp(30px,3.2vw,42px);
    line-height:1.12;color:var(--petrol);margin:0 0 20px;letter-spacing:-0.012em;
    max-width:760px;
  }
  .sp-pillars-intro p{
    font-family:var(--sans);font-size:16.5px;line-height:1.7;color:var(--stein);
    max-width:72ch;margin:0 0 14px;
  }
  .sp-pillars-intro .two-cols{
    display:grid;grid-template-columns:1fr 1fr;gap:48px;margin-top:32px;
  }
  .sp-pillars-intro .two-cols .card{
    padding:28px 30px;background:#fff;border:1px solid var(--hairline);
    border-top:3px solid var(--bordeaux);
  }
  .sp-pillars-intro .two-cols .card:last-child{border-top-color:var(--gold);}
  .sp-pillars-intro .two-cols h3{
    font-family:var(--serif);font-weight:500;font-size:22px;color:var(--petrol);
    margin:0 0 10px;letter-spacing:-0.01em;
  }
  .sp-pillars-intro .two-cols p{font-size:15px;margin:0;}

  /* ---------- 8 Leitsätze ---------- */
  .sp-leitsaetze{
    background:var(--offwhite);
    padding:24px 0 120px;
  }
  .leitsatz{
    display:grid;
    grid-template-columns:minmax(0,5fr) minmax(0,7fr);
    gap:56px;
    padding:56px 0;
    border-top:1px solid var(--hairline);
    align-items:start;
  }
  .leitsatz:last-child{border-bottom:1px solid var(--hairline);}
  .leitsatz.flip{grid-template-columns:minmax(0,7fr) minmax(0,5fr);}
  .leitsatz.flip .media{order:2;}
  .leitsatz .media{
    aspect-ratio:5/4;overflow:hidden;background:var(--creme);
    border-radius:2px;position:relative;
  }
  .leitsatz .media img{width:100%;height:100%;object-fit:cover;display:block;transition:transform .5s ease;}
  .leitsatz:hover .media img{transform:scale(1.02);}
  .leitsatz .media .num-badge{
    position:absolute;top:16px;left:16px;
    width:48px;height:48px;border-radius:50%;
    background:var(--creme);color:var(--petrol);
    display:flex;align-items:center;justify-content:center;
    font-family:var(--serif);font-weight:500;font-size:22px;
    letter-spacing:-0.02em;
    box-shadow:0 4px 12px -4px rgba(0,0,0,0.2);
  }
  .leitsatz h3{
    font-family:var(--serif);font-weight:500;font-size:clamp(26px,2.6vw,36px);
    line-height:1.15;color:var(--petrol);letter-spacing:-0.012em;
    margin:0 0 20px;
  }
  .leitsatz .claim{
    font-family:var(--sans);font-size:16.5px;line-height:1.65;
    color:var(--tinte);margin:0 0 24px;max-width:60ch;
  }
  .leitsatz ul{
    list-style:none;margin:0 0 24px;padding:0;
  }
  .leitsatz ul li{
    position:relative;padding:8px 0 8px 22px;
    font-family:var(--sans);font-size:15px;line-height:1.55;color:var(--stein);
    border-bottom:1px solid var(--hairline);
  }
  .leitsatz ul li:first-child{border-top:1px solid var(--hairline);}
  .leitsatz ul li::before{
    content:"";position:absolute;left:0;top:16px;
    width:10px;height:1px;background:var(--bordeaux);
  }
  .leitsatz .future{
    margin-top:18px;padding:16px 18px;
    background:rgba(212,165,116,0.14);
    border-left:3px solid var(--gold);
  }
  .leitsatz .future h4{
    font-family:var(--sans);font-weight:600;font-size:11px;
    letter-spacing:0.14em;text-transform:uppercase;color:#8a5a20;
    margin:0 0 8px;
  }
  .leitsatz .future ul{margin:0;}
  .leitsatz .future li{
    border:0;padding:4px 0 4px 18px;font-size:14px;color:var(--tinte);
  }
  .leitsatz .future li::before{
    top:13px;background:var(--gold);
  }

  @media (max-width:980px){
    .sp-intro-grid{grid-template-columns:1fr;gap:32px;}
    .pledge-list{grid-template-columns:1fr;}
    .sp-pillars-intro .two-cols{grid-template-columns:1fr;gap:24px;}
    .leitsatz, .leitsatz.flip{grid-template-columns:1fr;gap:24px;}
    .leitsatz.flip .media{order:-1;}
    .leitsatz .media{order:-1;aspect-ratio:16/10;}
  }
  @media (max-width:620px){
    .sp-hero{min-height:420px;padding:48px 0 40px;}
    .sp-intro,.sp-pledge,.sp-pillars-intro{padding:56px 0;}
    .sp-leitsaetze{padding:12px 0 72px;}
    .leitsatz{padding:36px 0;}
  }
</style>

<main id="top">

<section class="sp-hero" aria-label="Schulprogramm">
  <div class="container">
    <span class="eyebrow">Profil · Schulprogramm</span>
    <h1>Gemeinsam lernen,<br>den eigenen Weg finden.</h1>
    <p class="lede">Unser Schulprogramm — das, was uns trägt. Ein Leitbild, das aus einer Überzeugung wächst: Schule muss beides sein — ein Ort der Sicherheit für die Zukunft und ein Freiraum, in dem junge Menschen heute schon ganz sie selbst sein dürfen.</p>
  </div>
</section>


<section class="sp-intro">
  <div class="container">
    <div class="sp-intro-grid">
      <div>
        <h2>Mehr als gute Noten.</h2>
      </div>
      <div>
        <p class="lead">Gute Noten, fundiertes Wissen und ein starkes Abitur sind für uns selbstverständlich. Doch als UNESCO-Projektschule blicken wir darüber hinaus: Wir sind Teil eines weltweiten Netzwerks, das sich für Frieden, Menschenrechte, kulturelle Vielfalt und nachhaltige Entwicklung einsetzt.</p>
        <p>Unsere Schule lebt diese Ziele im Alltag — mit Projekten zu Demokratie, nachhaltigem Handeln und kulturellem Austausch, und mit einer Haltung, die junge Menschen zu verantwortungsvollen Gestaltern von morgen macht.</p>
        <p>Wir sehen Kinder und Jugendliche als <em>ganze Persönlichkeiten</em>. Darum schaffen wir Raum für Musik und Kreativität, für Verantwortung und echtes Miteinander. Unser Ziel ist klar: junge Menschen zu stärken — für das Leben, das vor ihnen liegt.</p>
      </div>
    </div>
  </div>
</section>


<section class="sp-pledge">
  <div class="container">
    <span class="eyebrow">Selbstverpflichtung des Kollegiums</span>
    <h2>Unser Auftrag: Schülerinnen und Schüler auf ihren Lern- und Lebenswegen zu begleiten.</h2>
    <p class="intro">Wir, das Kollegium der UNESCO-Schule Essen, empfinden es als unseren Auftrag, alle Schülerinnen und Schüler unserer Schule bestmöglich auf ein Leben in unserer demokratischen Gesellschaft vorzubereiten. Deswegen wollen wir …</p>
    <ol class="pledge-list">
      <li><span class="num">01</span><span class="text">Vielfalt leben, Gemeinschaft stiften und Möglichkeiten der persönlichen Entfaltung bieten.</span></li>
      <li><span class="num">02</span><span class="text">Vorbildlich handeln.</span></li>
      <li><span class="num">03</span><span class="text">Auf gewaltfreie und respektvolle Kommunikation achten.</span></li>
      <li><span class="num">04</span><span class="text">Fähigkeiten fördern und helfen, aus Fehlern zu lernen.</span></li>
      <li><span class="num">05</span><span class="text">Allen Schülerinnen und Schülern fair, gerecht und wertschätzend begegnen.</span></li>
      <li><span class="num">06</span><span class="text">Durch Transparenz und Konsequenz im Handeln verlässlich sein.</span></li>
      <li><span class="num">07</span><span class="text">Mit Eltern und Betreuenden zusammenarbeiten, um junge Menschen gemeinsam ins Erwachsenenleben zu begleiten.</span></li>
      <li><span class="num">08</span><span class="text">Uns an den Verhaltenskodex unserer Schule im Rahmen des Schutzkonzeptes halten.</span></li>
    </ol>
    <p class="pledge-outro">Wir betrachten es als Selbstverständlichkeit, unsere Schülerinnen und Schüler als Menschen wahrzunehmen, die Stärken und Schwächen haben — und möchten sie im Rahmen ihrer spezifischen Lebenswirklichkeiten begleiten.</p>
  </div>
</section>


<section class="sp-pillars-intro">
  <div class="container">
    <span class="eyebrow">Leitsätze und Ziele</span>
    <h2>Zwei Säulen, acht Leitsätze.</h2>
    <p>Unser Schulprogramm stützt sich entsprechend unseres Leitbildes auf zwei Säulen: das individuelle, akademische Lernen und die sozial-affektive Persönlichkeitsentwicklung innerhalb einer gesellschaftsrelevanten Gemeinschaft.</p>
    <div class="two-cols">
      <div class="card">
        <h3>Gemeinsam lernen</h3>
        <p>Individuelles, akademisches Lernen — mit hohem fachlichen Anspruch und enger pädagogischer Begleitung auf dem Weg zum Abitur.</p>
      </div>
      <div class="card">
        <h3>Den eigenen Weg finden</h3>
        <p>Sozial-affektive Persönlichkeitsentwicklung innerhalb einer demokratischen, weltoffenen und vielfältigen Schulgemeinschaft.</p>
      </div>
    </div>
  </div>
</section>


<section class="sp-leitsaetze">
  <div class="container">
    
      <article class="leitsatz">
        <div class="media">
          <img src="assets/sp-lernend.jpg" alt="">
          <span class="num-badge">01</span>
        </div>
        <div class="body">
          <h3>Lernende Schule</h3>
          <p class="claim">Unabhängig von der bisherigen Schullaufbahn erhalten unsere Schülerinnen und Schüler bei entsprechender Qualifizierung die individuell bestmögliche gymnasiale Ausbildung — mit enger Unterstützung auf dem Weg dorthin.</p>
          <ul>
          <li>In Klasse 5 Wahl zwischen zwei neigungsdifferenzierten Ergänzungsfächern: Forscher² (naturwissenschaftlich-experimentell) und WortArt+ (sprachlich-künstlerisch)</li>
          <li>Behutsamer Aufbau von Schulformwechselnden in Sek II durch gestaffelte, progressive Annäherung an gymnasiale Standards</li>
          <li>Kennenlern- und Methodenfahrt für Neuzugänge in der EF</li>
          <li>Regelmäßige pädagogische Konferenzen (zusätzlich zu Notenkonferenzen) pro Klasse und Jahrgang</li>
          <li>Intensive Förderung durch den Rotary Club Essen (Arbeitsmaterialien, Schulhofgestaltung, Auslandsaufenthalte)</li>
          </ul>
        <div class="future">
          <h4>Schulentwicklungsziele</h4>
          <ul>
            <li>Auszeichnung als „MINT-freundliche Schule" (in Arbeit)</li>
          </ul>
        </div>
        </div>
      </article>

      <article class="leitsatz flip">
        <div class="media">
          <img src="assets/sp-persoenlich.jpg" alt="">
          <span class="num-badge">02</span>
        </div>
        <div class="body">
          <h3>Diskriminierungsfreie Schule</h3>
          <p class="claim">In einem wertschätzenden, sicheren Umfeld können sich unsere Schülerinnen und Schüler frei von rassistischer, sexualisierter oder kulturell-religiöser Diskriminierung entwickeln und unbelastet lernen.</p>
          <ul>
          <li>Regelmäßige UNESCO-Projekttage (2 × pro Schuljahr)</li>
          <li>Kooperation mit der Polizei Essen und dem Franz-Sales-Haus Essen</li>
          <li>Kooperation mit dem CSE Ruhr und Together Education</li>
          <li>Selbstverpflichtung zum Verhaltenskodex als Bestandteil des Schutzkonzeptes</li>
          <li>Enges Beratungskonzept mit Vertrauenslehrern und Schulsozialarbeitern</li>
          <li>Schuleigenes Schutzkonzept</li>
          </ul>
        <div class="future">
          <h4>Schulentwicklungsziele</h4>
          <ul>
            <li>Auszeichnung „Schule ohne Rassismus – Schule mit Courage"</li>
          </ul>
        </div>
        </div>
      </article>

      <article class="leitsatz">
        <div class="media">
          <img src="assets/sp-divers.jpg" alt="">
          <span class="num-badge">03</span>
        </div>
        <div class="body">
          <h3>Diverse Schule</h3>
          <p class="claim">Unsere Schülerinnen und Schüler kommunizieren mit großer Selbstverständlichkeit in vielerlei Sprachen und bringen ihre jeweilige kulturelle Lebens- und Erfahrungswelt kreativ in den Schulalltag ein.</p>
          <ul>
          <li>Internationale Schülerschaft</li>
          <li>Darstellung kultureller Identitäten bei Veranstaltungen und Projekten (Tanz, Theater, Musik, Kochkunst)</li>
          <li>Bilinguale Alltagskommunikation (Schulradio, Schülerzeitung), schulinterne Dolmetscher</li>
          <li>Kooperation mit dem „Freundeskreis Theater und Philharmonie" (Opernprojekte, Konzert-Sponsoring)</li>
          <li>Erasmus-Plus-Programm</li>
          <li>„Arche Noah"-Projekt · KokoRu in der Sek I · Kooperation mit Together Education</li>
          </ul>
        <div class="future">
          <h4>Schulentwicklungsziele</h4>
          <ul>
            <li>Englisches Theater und Schülerzeitung</li>
          </ul>
        </div>
        </div>
      </article>

      <article class="leitsatz flip">
        <div class="media">
          <img src="assets/sp-demokratie.jpg" alt="">
          <span class="num-badge">04</span>
        </div>
        <div class="body">
          <h3>Demokratische Schule</h3>
          <p class="claim">Unsere Schülerinnen und Schüler können Ideen und gesellschaftliche Entwicklungen als gefestigte und mündige Persönlichkeiten innerhalb demokratischer Grundstrukturen entwerfen, umsetzen und bewerten.</p>
          <ul>
          <li>Klassenrat und Lion's Quest</li>
          <li>Aktive Schülervertretung</li>
          <li>Schülerpartizipation in Gremien (Fachkonferenzen, Steuergruppe, Arbeitskreise) und bei der Unterrichtsgestaltung</li>
          <li>Gedenkstättenfahrt in der Q2 (Geschichtskurs)</li>
          <li>Regelmäßige UNESCO-Projekttage zur Demokratieerziehung</li>
          <li>Teilnahme am Projekt „Juniorwahl" · Streitschlichterprogramm im Aufbau · Schülerpatenschaften</li>
          </ul>
        <div class="future">
          <h4>Schulentwicklungsziele</h4>
          <ul>
            <li>Auszeichnung „Schule der Zukunft"</li>
          </ul>
        </div>
        </div>
      </article>

      <article class="leitsatz">
        <div class="media">
          <img src="assets/sp-nachhaltig.jpg" alt="">
          <span class="num-badge">05</span>
        </div>
        <div class="body">
          <h3>Nachhaltige Schule</h3>
          <p class="claim">Unsere Schülerinnen und Schüler entwickeln ein Bewusstsein für ein auf Nachhaltigkeit angelegtes Leben und übernehmen Verantwortung für Umwelt und Gesellschaft.</p>
          <ul>
          <li>Schulgarten-AG</li>
          <li>Fachübergreifende Nutzung des Schulgartens</li>
          <li>UNESCO-Projekttage zu „Umwelt/Klimawandel" und „Zukunft"</li>
          <li>Differenzierungskurs „Nachhaltige Gesellschaft"</li>
          <li>Bücherschrank</li>
          </ul>
        <div class="future">
          <h4>Schulentwicklungsziele</h4>
          <ul>
            <li>Auszeichnung „Schule der Zukunft"</li>
            <li>Dachbegrünung</li>
          </ul>
        </div>
        </div>
      </article>

      <article class="leitsatz flip">
        <div class="media">
          <img src="assets/sp-weltoffen.jpg" alt="">
          <span class="num-badge">06</span>
        </div>
        <div class="body">
          <h3>Weltoffene Schule</h3>
          <p class="claim">Lernende und Lehrende orientieren sich im Schulalltag an den Zielen und Werten der UNESCO sowie den 17 Zielen für nachhaltige Entwicklung (SDGs) und setzen sich für Frieden, Nachhaltigkeit und Weltoffenheit ein.</p>
          <ul>
          <li>Thematisch wechselnde Ausstellungen zu Welttagen der Vereinten Nationen (2–3 pro Monat) in Eigenverantwortung der EF-Kurse und LKs in Q1/Q2</li>
          <li>UNESCO-Führerschein in der Sek I</li>
          <li>Organisation von UNESCO-Projekttagen (2 × pro Jahr) und Netzwerkpflege durch den UNESCO-Beauftragten</li>
          <li>UNESCO ist Namensgeber der Schule — Orientierung an ihren Zielen und Werten</li>
          </ul>
        </div>
      </article>

      <article class="leitsatz">
        <div class="media">
          <img src="assets/sp-digital.jpg" alt="">
          <span class="num-badge">07</span>
        </div>
        <div class="body">
          <h3>Digitale Schule</h3>
          <p class="claim">Unsere Schülerinnen und Schüler erleben, erproben und bewerten aktuelle Entwicklungen ihrer digitalen Lebensrealität bei einem zunehmend selbstverständlichen Umgang mit digitalen Medien im Unterricht.</p>
          <ul>
          <li>UNESCO-Projekttage zu „Internet/Hatespeech"</li>
          <li>Vollausstattung der Schülerschaft und des Lehrkollegiums mit iPads</li>
          <li>Kabellose Kommunikations- und Präsentationsmöglichkeiten in allen Klassenräumen (Beamer / Whiteboards)</li>
          <li>Handy- und Tabletkonzept der UNESCO-Schule</li>
          <li>Kooperation mit Hacker School</li>
          </ul>
        <div class="future">
          <h4>Schulentwicklungsziele</h4>
          <ul>
            <li>Auszeichnung „Digitale Schule"</li>
            <li>Digitales Klassenbuch</li>
          </ul>
        </div>
        </div>
      </article>

      <article class="leitsatz flip">
        <div class="media">
          <img src="assets/sp-hero.jpg" alt="">
          <span class="num-badge">08</span>
        </div>
        <div class="body">
          <h3>Persönlichkeitsentwickelnde Schule</h3>
          <p class="claim">Lernende und Lehrende nehmen sich gegenseitig als Individuum und als integrativer Teil einer größeren Gemeinschaft wahr — und bilden in vielfältiger Form ihre Persönlichkeit aus.</p>
          <ul>
          <li>Klassen- und Kursfahrten in Klasse 9 und Stufe Q1</li>
          <li>Zahlreiche Projekttage und gemeinsame Schulveranstaltungen</li>
          <li>Enges Beratungskonzept bei kleinen Lerngruppen („Schüler im Blick")</li>
          <li>Klassenleiterteams · Theaterprojekte</li>
          <li>Durchgängige Studien- und Berufsberatung, Kooperation mit Jugendberufsagentur (Jobcenter & Bundesagentur)</li>
          <li>Kooperation mit dem Talentscouting der Universität Duisburg-Essen</li>
          <li>Aufenthaltsräume (SV) · Schülerpatenschaften · bewegte Pause</li>
          </ul>
        <div class="future">
          <h4>Schulentwicklungsziele</h4>
          <ul>
            <li>Ausbau der Lerninseln / freie Sitzmöglichkeiten</li>

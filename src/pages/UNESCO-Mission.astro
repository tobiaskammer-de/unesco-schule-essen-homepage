---
import BaseLayout from "../layouts/BaseLayout.astro";
import PageHero from "../components/PageHero.astro";
import { getSingle } from "../lib/pageContent";

const page: any = await getSingle("pageUnescoMission");
---
<BaseLayout title="UNESCO – Name und Mission · UNESCO-Schule Essen">
<style is:global>
  /* ---------- UNESCO-Mission page ---------- */
  .un-statement{
    background:var(--creme);
    padding:var(--space-section) 0;
  }
  .un-statement .container{max-width:960px;}
  .un-statement h2{
    font-family:var(--serif);font-weight:500;
    font-size:clamp(32px,4vw,56px);line-height:1.12;
    color:var(--petrol);letter-spacing:-0.018em;margin:0 0 28px;
  }
  .un-statement h2 em{font-style:italic;color:var(--bordeaux);}
  .un-statement p{
    font-family:var(--sans);font-size:18px;line-height:1.7;color:var(--tinte);
    max-width:72ch;margin:0 0 18px;
  }
  .un-statement p.highlight{
    font-family:var(--serif);font-style:italic;font-weight:400;
    font-size:22px;line-height:1.5;color:var(--bordeaux);
    border-left:3px solid var(--bordeaux);padding:6px 0 6px 24px;
    margin-top:32px;
  }

  .un-aspnet{ background:var(--offwhite); padding:var(--space-section) 0; }
  .un-aspnet .head{max-width:780px;margin:0 0 56px;}
  .un-aspnet .head .eyebrow{display:block;margin-bottom:14px;}
  .un-aspnet .head h2{
    font-family:var(--serif);font-weight:500;
    font-size:clamp(30px,3.2vw,44px);line-height:1.15;letter-spacing:-0.015em;
    color:var(--petrol);margin:0 0 18px;
  }
  .un-aspnet .head p{
    font-family:var(--sans);font-size:17px;line-height:1.65;color:var(--stein);
    max-width:640px;margin:0;
  }
  .stats{
    display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:0;
    border-top:1px solid var(--hairline);border-bottom:1px solid var(--hairline);
  }
  .stat{ padding:40px 32px;border-right:1px solid var(--hairline); display:flex;flex-direction:column;gap:10px; }
  .stat:last-child{border-right:0;}
  .stat .n{ font-family:var(--serif);font-weight:500; font-size:clamp(38px,4.2vw,60px);line-height:1; color:var(--petrol);letter-spacing:-0.025em; font-variant-numeric:tabular-nums; }
  .stat .label{ font-family:var(--sans);font-size:13px;color:var(--stein);line-height:1.55; }

  .un-tiers{ background:var(--creme); padding:var(--space-section) 0; }
  .un-tiers .head{max-width:780px;margin:0 0 56px;}
  .un-tiers .head .eyebrow{display:block;margin-bottom:14px;}
  .un-tiers .head h2{
    font-family:var(--serif);font-weight:500;
    font-size:clamp(30px,3.2vw,44px);line-height:1.15;letter-spacing:-0.015em;
    color:var(--petrol);margin:0 0 18px;
  }
  .un-tiers .head p{ font-family:var(--sans);font-size:17px;line-height:1.65;color:var(--stein); max-width:640px;margin:0; }
  .tier-list{ list-style:none;margin:0;padding:0; display:flex;flex-direction:column;gap:18px; }
  .tier{ display:grid;grid-template-columns:80px 1fr auto;gap:28px;align-items:center; padding:28px 32px;background:#fff;border:1px solid var(--hairline); position:relative; }
  .tier .step{ font-family:var(--serif);font-weight:500;font-size:42px;line-height:1; color:var(--stein);letter-spacing:-0.025em;opacity:0.45; }
  .tier .body h3{ font-family:var(--serif);font-weight:500;font-size:22px;line-height:1.2; color:var(--petrol);letter-spacing:-0.008em;margin:0 0 6px; }
  .tier .body p{ font-family:var(--sans);font-size:15px;line-height:1.55;color:var(--stein);margin:0; }
  .tier .marker{ font-family:var(--sans);font-size:11px;font-weight:600; letter-spacing:0.14em;text-transform:uppercase;color:var(--stein); }
  .tier.is-us{ background:var(--petrol);color:var(--creme);border-color:var(--petrol); }
  .tier.is-us .step{color:var(--gold);opacity:0.85;}
  .tier.is-us h3{color:var(--creme);}
  .tier.is-us p{color:rgba(245,239,231,0.85);}
  .tier.is-us .marker{ color:var(--petrol);background:var(--gold); padding:5px 12px;border-radius:999px;letter-spacing:0.1em; }

  .un-themes{ background:var(--offwhite); padding:var(--space-section) 0; }
  .un-themes .head{max-width:780px;margin:0 0 56px;}
  .un-themes .head .eyebrow{display:block;margin-bottom:14px;}
  .un-themes .head h2{ font-family:var(--serif);font-weight:500; font-size:clamp(30px,3.2vw,44px);line-height:1.15;letter-spacing:-0.015em; color:var(--petrol);margin:0; }
  .themes-grid{ display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:28px; }
  .theme{ padding:var(--card-padding);background:#fff;border:1px solid var(--hairline); display:flex;flex-direction:column;gap:12px; border-left:var(--card-accent-width) solid var(--petrol); }
  .theme .n{ font-family:var(--serif);font-weight:500;font-size:22px;line-height:1; color:var(--petrol);letter-spacing:-0.015em; }
  .theme h3{ font-family:var(--serif);font-weight:500;font-size:21px;line-height:1.25; color:var(--petrol);letter-spacing:-0.008em;margin:0; }
  .theme p{ font-family:var(--sans);font-size:15px;line-height:1.6;color:var(--stein);margin:0; }

  .un-alltag{ background:var(--creme); padding:var(--space-section) 0;border-top:1px solid var(--hairline); }
  .un-alltag .head{max-width:780px;margin:0 0 48px;}
  .un-alltag .head .eyebrow{display:block;margin-bottom:14px;}
  .un-alltag .head h2{ font-family:var(--serif);font-weight:500; font-size:clamp(30px,3.2vw,44px);line-height:1.15;letter-spacing:-0.015em; color:var(--petrol);margin:0 0 18px; }
  .un-alltag .head p{ font-family:var(--sans);font-size:17px;line-height:1.65;color:var(--stein);margin:0; }
  .alltag-list{ list-style:none;margin:0;padding:0; display:grid;grid-template-columns:repeat(2,minmax(0,1fr));gap:14px 32px; border-top:1px solid var(--hairline); }
  .alltag-list li{ display:grid;grid-template-columns:28px 1fr;gap:12px;align-items:start; padding:18px 0;border-bottom:1px solid var(--hairline); font-family:var(--sans);font-size:15.5px;line-height:1.55;color:var(--tinte); }
  .alltag-list li::before{ content:"✦";color:var(--gold);font-size:16px;line-height:1.55; grid-column:1; }

  .un-pledge{ background:var(--petrol);color:var(--creme); padding:var(--space-section) 0; }
  .un-pledge .container{max-width:880px;text-align:center;}
  .un-pledge .eyebrow{color:rgba(245,239,231,0.55);display:block;margin-bottom:16px;}
  .un-pledge h2{ font-family:var(--serif);font-weight:500; font-size:clamp(28px,3.4vw,44px);line-height:1.18; color:var(--creme);margin:0 0 28px;letter-spacing:-0.015em; }
  .un-pledge p{ font-family:var(--sans);font-size:17.5px;line-height:1.65; color:rgba(245,239,231,0.9);max-width:720px;margin:0 auto 16px; }
  .un-pledge .sig{ margin-top:36px;padding-top:28px; border-top:1px solid rgba(245,239,231,0.18); font-family:var(--sans);font-size:13px;letter-spacing:0.1em; text-transform:uppercase;color:rgba(245,239,231,0.55); }

  @media (max-width:960px){
    .stats{grid-template-columns:1fr;}
    .stat{border-right:0;border-bottom:1px solid var(--hairline);}
    .stat:last-child{border-bottom:0;}
    .tier{grid-template-columns:56px 1fr;gap:18px;padding:22px 24px;}
    .tier .marker{grid-column:1 / -1;margin-top:8px;}
    .tier .step{font-size:32px;}
    .themes-grid{grid-template-columns:1fr;gap:16px;}
    .alltag-list{grid-template-columns:1fr;}
    .un-statement,.un-aspnet,.un-tiers,.un-themes,.un-alltag,.un-pledge{padding:var(--space-section-sm) 0;}
  }
</style>

<main id="top">

<PageHero variant="feature">
  {page.hero.badge && <Fragment slot="badge">{page.hero.badge}</Fragment>}
  <Fragment slot="eyebrow">{page.hero.eyebrow}</Fragment>
  <Fragment slot="title">{page.hero.title}{page.hero.titleHighlight && <> <em>{page.hero.titleHighlight}</em></>}</Fragment>
  <Fragment slot="lede">{page.hero.lede}</Fragment>
</PageHero>

<section class="un-statement" aria-label="Unser Selbstverständnis">
  <div class="container">
    <h2>{page.statement.title}</h2>
    {page.statement.body.split(/\n\n+/).map((para: string) => (
      <p set:html={para.replace(/\*\*(.+?)\*\*/g, "<strong>$1</strong>")} />
    ))}
    {page.statement.highlight && <p class="highlight">{page.statement.highlight}</p>}
  </div>
</section>

<section class="un-aspnet" aria-label="Was ist eine UNESCO-Projektschule">
  <div class="container">
    <div class="head">
      <span class="eyebrow">{page.aspnet.eyebrow}</span>
      <h2>{page.aspnet.title}</h2>
      <p>{page.aspnet.body}</p>
    </div>
    <div class="stats">
      {page.aspnet.stats.map((s: any) => (
        <div class="stat">
          <span class="n">{s.n}</span>
          <span class="label">{s.label}</span>
        </div>
      ))}
    </div>
  </div>
</section>

<section class="un-tiers" aria-label="Die drei Stufen">
  <div class="container">
    <div class="head">
      <span class="eyebrow">{page.tiers.eyebrow}</span>
      <h2>{page.tiers.title}</h2>
      <p>{page.tiers.body}</p>
    </div>
    <ol class="tier-list">
      {page.tiers.list.map((t: any) => (
        <li class={`tier ${t.isUs ? "is-us" : ""}`}>
          <span class="step">{t.step}</span>
          <div class="body">
            <h3>{t.title}</h3>
            <p>{t.body}</p>
          </div>
          <span class="marker">{t.marker}</span>
        </li>
      ))}
    </ol>
  </div>
</section>

<section class="un-themes" aria-label="Die fünf Themenfelder">
  <div class="container">
    <div class="head">
      <span class="eyebrow">{page.themes.eyebrow}</span>
      <h2>{page.themes.title}</h2>
    </div>
    <div class="themes-grid">
      {page.themes.list.map((t: any) => (
        <article class="theme">
          <span class="n">{t.n}</span>
          <h3>{t.title}</h3>
          <p>{t.body}</p>
        </article>
      ))}
    </div>
  </div>
</section>

<section class="un-alltag" aria-label="UNESCO im Alltag">
  <div class="container">
    <div class="head">
      <span class="eyebrow">{page.alltag.eyebrow}</span>
      <h2>{page.alltag.title}</h2>
      <p>{page.alltag.body}</p>
    </div>
    <ul class="alltag-list">
      {page.alltag.items.map((it: string) => <li>{it}</li>)}
    </ul>
  </div>
</section>

<section class="un-pledge" aria-label="Unsere Selbstverpflichtung">
  <div class="container">
    <span class="eyebrow">{page.pledge.eyebrow}</span>
    <h2>{page.pledge.title}</h2>
    {page.pledge.body.split(/\n\n+/).map((para: string) => <p>{para}</p>)}
    <div class="sig">{page.pledge.signature}</div>
  </div>
</section>

</main>
</BaseLayout>

<script>
  const hamburger = document.getElementById('hamburgerBtn');
  const mainNav   = document.getElementById('mainNav');
  const backdrop  = document.getElementById('navBackdrop');
  const body      = document.body;

  function openMenu(){
    hamburger.classList.add('active');
    mainNav.classList.add('open');
    backdrop.classList.add('is-visible');
    body.classList.add('nav-open');
    hamburger.setAttribute('aria-expanded','true');
    hamburger.setAttribute('aria-label','Menü schließen');
  }
  function closeMenu(){
    hamburger.classList.remove('active');
    mainNav.classList.remove('open');
    backdrop.classList.remove('is-visible');
    body.classList.remove('nav-open');
    hamburger.setAttribute('aria-expanded','false');
    hamburger.setAttribute('aria-label','Menü öffnen');
    // Alle geöffneten Dropdowns einklappen
    document.querySelectorAll('.nav-item.has-dropdown.open').forEach(i=>i.classList.remove('open'));
  }

  if(hamburger){
    hamburger.addEventListener('click',()=>{
      if(mainNav.classList.contains('open')) closeMenu(); else openMenu();
    });
  }
  if(backdrop){
    backdrop.addEventListener('click', closeMenu);
  }

  // Escape-Taste schließt das Menü
  document.addEventListener('keydown', e=>{
    if(e.key === 'Escape' && mainNav.classList.contains('open')) closeMenu();
  });

  // Klick auf einen Link (kein Dropdown-Trigger) schließt das Menü
  document.querySelectorAll('#mainNav a').forEach(a=>{
    a.addEventListener('click', e=>{
      // Dropdown-Trigger mit href="#" nicht schließen — die sollen aufklappen
      const parent = a.parentElement;
      const isDropdownTrigger = parent && parent.classList.contains('has-dropdown') && a.getAttribute('href') === '#';
      if(!isDropdownTrigger && window.innerWidth <= 1080) closeMenu();
    });
  });

  // Dropdown-Akkordeon innerhalb des Mobile-Menüs
  document.querySelectorAll('.nav-item.has-dropdown > .nav-link').forEach(link=>{
    link.addEventListener('click',e=>{
      if(window.innerWidth <= 1080){
        e.preventDefault();
        const parent = link.parentElement;
        const wasOpen = parent.classList.contains('open');
        document.querySelectorAll('.nav-item.has-dropdown').forEach(i=>i.classList.remove('open'));
        if(!wasOpen) parent.classList.add('open');
      }
    });
  });

  // Wenn Fenster auf Desktop-Größe resized wird: Mobile-Menü sauber zurücksetzen
  window.addEventListener('resize', ()=>{
    if(window.innerWidth > 1080 && mainNav.classList.contains('open')) closeMenu();
  });

  // Scroll-Shrink: Logo schrumpft auf 50 %, sobald gescrollt wird
  const siteHeader = document.getElementById('siteHeader');
  const SHRINK_AT = 40;
  let lastShrunk = null;
  function updateScrolled(){
    const shrunk = window.scrollY > SHRINK_AT;
    if(shrunk !== lastShrunk){
      siteHeader.dataset.scrolled = shrunk ? 'true' : 'false';
      lastShrunk = shrunk;
    }
  }
  updateScrolled();
  window.addEventListener('scroll', updateScrolled, { passive:true });
</script>


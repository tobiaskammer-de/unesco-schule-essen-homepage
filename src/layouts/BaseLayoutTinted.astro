---
import "@fontsource/inter/400.css";
import "@fontsource/inter/500.css";
import "@fontsource/inter/600.css";
import "@fontsource/inter/700.css";
import "@fontsource/fraunces/400.css";
import "@fontsource/fraunces/500.css";
import "@fontsource/fraunces/600.css";
import "@fontsource/fraunces/400-italic.css";
import "@fontsource/fraunces/500-italic.css";
import AccessibilityToolbar from "../components/AccessibilityToolbar.astro";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "UNESCO-Schule Essen — Gymnasium",
  description = "UNESCO-Projektschule in Essen. Gymnasium mit Profil ab Klasse 5. Gemeinsam lernen, den eigenen Weg finden.",
} = Astro.props;

// Base-URL-Helper: sorgt dafür, dass alle Links + Assets auch aus
// Unterordnern wie /aktuelles/foo.html korrekt auflösen.
const RAW_BASE = import.meta.env.BASE_URL;
const BASE = RAW_BASE.endsWith("/") ? RAW_BASE.slice(0, -1) : RAW_BASE;
function link(path: string): string {
  const clean = path.startsWith("/") ? path.slice(1) : path;
  return BASE + "/" + clean;
}
---
<!DOCTYPE html>
<html lang="de">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>{title}</title>
<meta name="description" content={description}>
<meta name="theme-color" content="#0E4D4F">
<link rel="icon" type="image/png" href={link("assets/logo-mark.png")}>
<style is:global>
:root{
    color-scheme: light;
    --petrol:       #0E4D4F;
    --petrol-dark:  #0A3638;
    --bordeaux:     #6E2639;
    --sage:         #7FB069;
    --gold:         #D4A574;
    --creme:        #F5EFE7;
    --offwhite:     #FAF7F1;
    --stein:        #6A6A68;
    --tinte:        #1A1A1A;
    --hairline:     #E8E0D1;

    --container: 1280px;
    --pad-desk: 32px;
    --pad-mob:  20px;

    /* Section rhythm */
    --space-section:    96px;
    --space-section-sm: 64px;

    /* Card system */
    --card-padding:       32px;
    --card-padding-sm:    24px;
    --card-radius:        4px;
    --card-accent-width:  3px;

    /* Hero */
    --hero-min-h: 520px;

    /* Motion */
    --transition-fast: .2s ease;
    --transition:      .3s ease;
    --ease-out:        cubic-bezier(0.2, 0.8, 0.2, 1);

    /* Focus */
    --focus-ring: 0 0 0 3px rgba(14,77,79,0.35);

    --sans: "Inter", -apple-system, BlinkMacSystemFont, "Segoe UI", Helvetica, Arial, sans-serif;
    --serif: "Fraunces", Georgia, "Times New Roman", serif;
  }

  *,*::before,*::after{box-sizing:border-box;}
  html,body{margin:0;padding:0;}
  html{scroll-behavior:smooth;}
  body{
    font-family:var(--sans);
    color:var(--tinte);
    background:var(--offwhite);
    font-size:16px;
    line-height:1.65;
    -webkit-font-smoothing:antialiased;
    -moz-osx-font-smoothing:grayscale;
    text-rendering:optimizeLegibility;
  }
  img{max-width:100%;display:block;}
  a{color:var(--petrol);text-decoration:none;}

  /* Focus */
  :focus{outline:none;}
  :focus-visible{
    outline:2px solid var(--petrol);
    outline-offset:2px;
    border-radius:2px;
  }

  /* Heading anchor offset for sticky header */
  h1[id], h2[id], h3[id]{scroll-margin-top:120px;}

  /* Skip link — erscheint über dem Sticky-Header bei Tab-Fokus */
  .skip-link{
    position:fixed;left:16px;top:16px;
    transform:translateY(-200%);
    background:var(--petrol);color:#fff;
    padding:12px 18px;font-family:var(--sans);font-weight:500;
    z-index:3000;border-radius:4px;
    box-shadow:0 6px 18px -6px rgba(14,77,79,0.45);
    transition:transform .2s ease;
  }
  .skip-link:focus{transform:translateY(0);}

  /* Respect user motion preferences */
  @media (prefers-reduced-motion: reduce){
    *,*::before,*::after{
      animation-duration:.001ms !important;
      animation-iteration-count:1 !important;
      transition-duration:.001ms !important;
      scroll-behavior:auto !important;
    }
  }

  .container{
    max-width:var(--container);
    margin:0 auto;
    padding:0 var(--pad-desk);
  }

  /* ---------- Typography ---------- */
  h1,h2,h3,h4{margin:0;font-weight:500;color:var(--petrol);text-wrap:balance;}
  h1{font-family:var(--serif);font-weight:500;letter-spacing:-0.015em;}
  h2{font-family:var(--serif);font-weight:500;font-size:30px;letter-spacing:-0.01em;line-height:1.15;}
  h3{font-family:var(--sans);font-weight:600;font-size:19px;line-height:1.3;}
  p{text-wrap:pretty;}
  p{margin:0;}
  .caption{
    font-family:var(--sans);
    font-weight:500;
    font-size:12px;
    letter-spacing:0.09em;
    text-transform:uppercase;
    color:var(--stein);
  }
  .eyebrow{
    font-family:var(--sans);
    font-weight:500;
    font-size:12px;
    letter-spacing:0.12em;
    text-transform:uppercase;
    color:var(--bordeaux);
  }
  .lead{font-family:var(--serif);font-style:italic;font-weight:400;color:var(--stein);font-size:21px;line-height:1.45;}
  .inline-link{
    color:var(--bordeaux);
    font-weight:500;
    text-decoration:underline;
    text-decoration-thickness:1px;
    text-underline-offset:3px;
  }
  .inline-link:hover{color:var(--petrol-dark);}

  /* ---------- Buttons ---------- */
  .btn{
    display:inline-flex;align-items:center;gap:8px;
    font-family:var(--sans);font-weight:500;font-size:15px;
    padding:12px 20px;border-radius:4px;
    text-decoration:none;border:1.5px solid transparent;
    transition:background-color .2s, color .2s, border-color .2s;
    cursor:pointer;
  }
  .btn-primary{background:var(--petrol);color:#fff;}
  .btn-primary:hover{background:var(--petrol-dark);}
  .btn-secondary{background:transparent;color:var(--petrol);border-color:var(--petrol);}
  .btn-secondary:hover{background:var(--creme);}

  .btn .arrow{display:inline-block;transition:transform .2s;}
  .btn:hover .arrow{transform:translateX(3px);}
  .btn:focus-visible{outline:2px solid var(--petrol);outline-offset:3px;}
  .btn-primary:focus-visible{outline-color:var(--bordeaux);}

  /* ---------- Shared Section system ---------- */
  .section{
    padding:var(--space-section) 0;
  }
  .section--creme{background:var(--creme);}
  .section--offwhite{background:var(--offwhite);}
  .section--petrol{background:var(--petrol);color:var(--creme);}
  .section--petrol h1,
  .section--petrol h2,
  .section--petrol h3,
  .section--petrol h4{color:var(--creme);}

  /* ---------- Shared Card system ---------- */
  .card{
    background:#fff;
    border:1px solid var(--hairline);
    border-radius:var(--card-radius);
    padding:var(--card-padding);
    transition:transform var(--transition), box-shadow var(--transition);
  }
  .card--accent{
    border-top:var(--card-accent-width) solid var(--petrol);
  }
  .card--accent-left{
    border-top:1px solid var(--hairline);
    border-left:var(--card-accent-width) solid var(--petrol);
  }
  .card--hover:hover{
    transform:translateY(-2px);
    box-shadow:0 14px 36px -22px rgba(14,77,79,0.3);
  }
  @media (prefers-reduced-motion: reduce){
    .card--hover:hover{transform:none;}
  }

  /* ---------- Shared Page Hero ---------- */
  .page-hero{
    position:relative;
    min-height:var(--hero-min-h);
    display:flex;align-items:flex-end;
    padding:96px 0 72px;
    overflow:hidden;
    isolation:isolate;
    background:var(--petrol-dark);
    color:var(--creme);
  }
  .page-hero::before{
    content:"";position:absolute;inset:0;z-index:-2;
    background-image:var(--hero-bg, linear-gradient(135deg,var(--petrol-dark) 0%, var(--petrol) 55%, #156063 100%));
    background-size:cover;background-position:center;
  }
  .page-hero::after{
    content:"";position:absolute;inset:0;z-index:-1;
    background:linear-gradient(180deg, rgba(10,54,56,0.25) 0%, rgba(10,54,56,0.72) 100%);
  }
  .page-hero.page-hero--no-image::after{background:linear-gradient(180deg, rgba(10,54,56,0) 0%, rgba(10,54,56,0.25) 100%);}
  .page-hero .container{position:relative;width:100%;}
  .page-hero .eyebrow{
    color:var(--gold);
    margin-bottom:18px;display:block;
  }
  .page-hero h1{
    font-family:var(--serif);font-weight:500;
    font-size:clamp(42px, 5.4vw, 76px);
    line-height:1.04;letter-spacing:-0.02em;
    color:var(--creme);
    text-wrap:balance;
    margin:0 0 22px;
    max-width:22ch;
  }
  .page-hero h1 em, .page-hero h1 .accent{
    font-style:italic;color:var(--gold);
  }
  .page-hero .lede{
    font-family:var(--sans);font-weight:400;
    font-size:19px;line-height:1.55;
    color:rgba(245,239,231,0.9);
    max-width:720px;margin:0;
    text-wrap:pretty;
  }
  .page-hero .hero-actions{
    display:flex;flex-wrap:wrap;gap:14px;margin-top:32px;
  }
  .page-hero .cred{
    position:absolute;bottom:14px;right:18px;
    color:rgba(255,255,255,0.72);
    font-family:var(--sans);font-size:10.5px;letter-spacing:0.1em;
    text-transform:uppercase;z-index:1;
  }
  @media (max-width:960px){
    .page-hero{min-height:420px;padding:72px 0 56px;}
    .page-hero h1{font-size:clamp(34px, 7vw, 56px);}
    .page-hero .lede{font-size:17px;}
  }

  /* ---------- Header (TINTED: Akzentstreifen + sanfter Cremeton) ---------- */
  .site-header{
    position:sticky;top:0;z-index:1000;
    background:rgba(245,239,231,0.96);
    backdrop-filter:saturate(140%) blur(8px);
    -webkit-backdrop-filter:saturate(140%) blur(8px);
    border-bottom:1px solid var(--hairline);
    box-shadow:0 1px 0 rgba(14,77,79,0) inset;
    transition:box-shadow .3s ease, border-color .3s ease;
  }
  /* Dünner Akzentstreifen oben in Petrol */
  .site-header::before{
    content:"";display:block;height:4px;width:100%;
    background:linear-gradient(90deg, var(--petrol) 0%, var(--petrol) 65%, var(--bordeaux) 100%);
  }
  /* Sanfter Schatten beim Scrollen statt harter Hairline */
  .site-header[data-scrolled="true"]{
    border-bottom-color:transparent;
    box-shadow:0 8px 24px -16px rgba(14,77,79,0.28);
  }

  .header-inner{
    max-width:var(--container);
    margin:0 auto;
    padding:22px var(--pad-desk) 0;
    display:flex;flex-direction:column;align-items:center;gap:18px;
    transition:padding .3s ease;
  }
  .logo{
    display:flex;align-items:center;justify-content:center;
    text-decoration:none;flex-shrink:0;
    margin:0 auto;
  }
  /* Logo: 126 px Default */
  .logo .logo-stack{
    position:relative;display:block;height:126px;
    transition:transform .3s ease, height .35s ease;
  }
  .logo .logo-stack img{
    display:block;height:126px;width:auto;max-width:100%;
    transition:opacity .35s ease, height .35s ease;
  }
  .logo .logo-color{position:absolute;inset:0;opacity:0;}
  .logo:hover .logo-stack{transform:scale(1.02);}
  .logo:hover .logo-bw{opacity:0;}
  .logo:hover .logo-color{opacity:1;}

  /* Scroll-Shrink: Logo halbiert sich beim Scrollen (126 → 63 px) */
  .site-header[data-scrolled="true"] .header-inner{padding-top:12px;gap:12px;}
  .site-header[data-scrolled="true"] .logo .logo-stack,
  .site-header[data-scrolled="true"] .logo .logo-stack img{height:63px;}

  /* Nav-Row: Menü + Kalender/Kontakt-Buttons als zentrierte Gruppe */
  .nav-row{
    width:100%;
    display:flex;
    align-items:center;
    justify-content:center;
    gap:18px;
  }
  .main-nav{
    display:flex;align-items:center;justify-content:center;
  }
  .nav-list{list-style:none;display:flex;gap:4px;margin:0;padding:0;}
  .nav-item{position:relative;display:flex;align-items:center;}
  .nav-link{
    display:flex;align-items:center;
    padding:14px 18px;
    font-family:var(--sans);font-size:17px;font-weight:500;
    color:var(--tinte);text-decoration:none;
    border-bottom:3px solid transparent;
    transition:color .2s, border-color .2s;
  }
  .nav-link:hover, .nav-item:focus-within > .nav-link, .nav-item:hover > .nav-link{
    color:var(--petrol);
    border-bottom-color:var(--petrol);
  }

  .dropdown-mega{
    position:absolute;top:100%;left:50%;transform:translate(-50%,8px);
    background:#fff;
    border:1px solid var(--hairline);
    border-top:2px solid var(--petrol);
    width:max-content;max-width:min(780px,calc(100vw - 40px));
    padding:28px 28px 24px;
    display:grid;grid-template-columns:1fr 1fr 1fr;gap:36px;
    opacity:0;visibility:hidden;pointer-events:none;
    transition:opacity .2s, transform .2s, visibility .2s;
    border-radius:2px;
  }
  .nav-item:hover > .dropdown-mega,
  .nav-item:focus-within > .dropdown-mega{
    opacity:1;visibility:visible;pointer-events:auto;
    transform:translate(-50%,0);
  }
  .mega-col h4{
    font-family:var(--sans);font-size:11px;font-weight:600;
    letter-spacing:0.12em;text-transform:uppercase;color:var(--bordeaux);
    padding-bottom:10px;margin-bottom:10px;
    border-bottom:1px solid var(--hairline);
  }
  .mega-col ul{list-style:none;margin:0;padding:0;}
  .mega-col li a{
    display:block;padding:7px 0;
    color:var(--tinte);font-size:14.5px;font-family:var(--sans);font-weight:400;
    border-left:2px solid transparent;padding-left:10px;margin-left:-10px;
    transition:color .15s, border-color .15s;
  }
  .mega-col li a:hover{color:var(--petrol);border-left-color:var(--petrol);}



  .header-actions{
    display:flex;align-items:center;justify-content:flex-end;gap:10px;
  }
  .header-actions a{
    font-family:var(--sans);font-size:13.5px;font-weight:500;
    color:var(--petrol);
    padding:9px 16px;border-radius:4px;
    border:1.5px solid var(--petrol);
    text-decoration:none;
    transition:color .2s, background-color .2s, border-color .2s;
  }
  .header-actions a:hover{color:#fff;background:var(--petrol);border-color:var(--petrol);}
  .header-actions .sep{display:none;}

  .hamburger{
    display:none;background:none;border:0;cursor:pointer;padding:8px;
    position:absolute;top:14px;right:var(--pad-mob);
  }
  .hamburger span{display:block;width:26px;height:2px;background:var(--petrol);margin:6px 0;transition:.3s;}
  .hamburger.active span:nth-child(1){transform:translateY(8px) rotate(45deg);}
  .hamburger.active span:nth-child(2){opacity:0;}
  .hamburger.active span:nth-child(3){transform:translateY(-8px) rotate(-45deg);}

  /* ---------- HERO ---------- */
  .hero{padding:72px 0 108px;}
  .hero-grid{
    display:grid;grid-template-columns:1fr 1fr;gap:64px;align-items:center;
  }
  .hero-photo{
    position:relative;aspect-ratio:4/5;overflow:hidden;border-radius:2px;
    background:var(--creme);
  }
  .hero-photo img{width:100%;height:100%;object-fit:cover;}
  .hero-photo .cred{
    position:absolute;bottom:12px;left:14px;
    color:rgba(255,255,255,0.82);
    font-family:var(--sans);font-size:10.5px;letter-spacing:0.1em;
    text-transform:uppercase;
  }
  .hero-text .eyebrow{margin-bottom:20px;display:block;}
  .hero-claim{
    font-family:var(--serif);font-weight:500;
    font-size:clamp(40px,4.6vw,64px);
    line-height:1.04;letter-spacing:-0.02em;
    color:var(--petrol);
    margin-bottom:28px;
  }
  .hero-claim em{font-style:italic;color:var(--petrol);}
  .hero-sub{
    font-family:var(--serif);font-style:italic;
    color:var(--stein);
    font-size:21px;line-height:1.5;
    max-width:520px;margin-bottom:40px;
  }
  .hero-cta-row{display:flex;align-items:center;gap:20px;flex-wrap:wrap;}
  .hero-open-day{
    display:inline-flex;align-items:center;gap:6px;
    color:var(--bordeaux);font-family:var(--sans);font-weight:500;font-size:14px;
    text-decoration:none;
  }
  .hero-open-day .dot{
    width:6px;height:6px;border-radius:50%;background:var(--bordeaux);
    display:inline-block;
  }
  .hero-open-day span.label{
    text-decoration:underline;text-underline-offset:3px;text-decoration-thickness:1px;
  }
  .hero-open-day:hover{color:var(--petrol-dark);}

  /* ---------- Section framing ---------- */
  section{padding:54px 0;}
  .section-head{display:flex;align-items:baseline;justify-content:space-between;margin-bottom:40px;gap:24px;flex-wrap:wrap;}
  .section-head h2{max-width:620px;}
  .section-head .all-link{
    font-family:var(--sans);font-size:14px;font-weight:500;
    color:var(--bordeaux);
    text-decoration:underline;text-underline-offset:4px;text-decoration-thickness:1px;
    white-space:nowrap;
  }
  .section-head .all-link:hover{color:var(--petrol-dark);}

  /* ---------- News + Dates ---------- */
  .news-dates{
    display:grid;grid-template-columns:minmax(0,6fr) minmax(0,4fr);gap:48px;
  }
  .news-dates > div, .news-dates > aside{
    background:rgba(245,239,231,0.55);
    border:1px solid var(--hairline);
    border-radius:6px;
    padding:40px 40px 44px;
    box-shadow:0 12px 32px -18px rgba(14,77,79,0.22), 0 2px 6px -2px rgba(14,77,79,0.06);
  }
  .news-list{display:grid;grid-template-columns:1fr 1fr;gap:32px 28px;}
  .news-card{display:flex;flex-direction:column;gap:14px;text-decoration:none;color:inherit;}
  .news-card .thumb{
    aspect-ratio:4/3;overflow:hidden;background:var(--creme);
    border-radius:2px;
  }
  .news-card .thumb img{width:100%;height:100%;object-fit:cover;transition:transform .5s ease;}
  .news-card:hover .thumb img{transform:scale(1.03);}
  .news-meta{display:flex;align-items:center;gap:10px;}
  .badge{
    font-family:var(--sans);font-weight:500;font-size:10.5px;
    letter-spacing:0.1em;text-transform:uppercase;
    padding:3px 9px;border-radius:2px;display:inline-block;
  }
  .badge-aktuell{background:var(--bordeaux);color:var(--creme);}
  .badge-news{background:rgba(110,38,57,0.10);color:var(--bordeaux);}
  .badge-unesco{background:rgba(127,176,105,0.18);color:#3e6b2a;}
  .badge-kunst{background:rgba(212,165,116,0.22);color:#7a5120;}
  .badge-sport{background:rgba(14,77,79,0.10);color:var(--petrol);}
  .news-card h3{
    color:var(--petrol);font-size:19px;line-height:1.3;
    font-family:var(--sans);font-weight:600;
    margin:0;
  }
  .news-card:hover h3{color:var(--petrol-dark);}
  .news-card .excerpt{
    color:var(--stein);font-size:15px;line-height:1.55;
    display:-webkit-box;-webkit-line-clamp:2;-webkit-box-orient:vertical;overflow:hidden;
  }
  .news-card .date{color:var(--stein);}

  /* Featured news (first card) */
  .news-list .news-card.featured{grid-column:1/-1;display:grid;grid-template-columns:1.2fr 1fr;gap:28px;align-items:center;}
  .news-list .news-card.featured .thumb{aspect-ratio:5/4;}
  .news-list .news-card.featured h3{font-size:24px;font-family:var(--serif);font-weight:500;letter-spacing:-0.01em;}
  .news-list .news-card.featured .excerpt{-webkit-line-clamp:3;font-size:16px;}

  /* Dates */
  .dates-list{list-style:none;margin:0;padding:0;border-top:1px solid var(--hairline);}
  .date-row{
    display:grid;grid-template-columns:84px 1fr;gap:20px;
    padding:22px 0;
    border-bottom:1px solid var(--hairline);
  }
  .date-row .date-main{
    font-family:var(--serif);font-weight:500;font-size:26px;
    color:var(--petrol);line-height:1;letter-spacing:-0.01em;
  }
  .date-row .date-sub{
    font-family:var(--sans);font-size:12px;color:var(--stein);
    letter-spacing:0.08em;text-transform:uppercase;margin-top:4px;
  }
  .date-row .date-body h3{
    font-family:var(--sans);font-weight:500;font-size:16px;color:var(--tinte);
    margin:0 0 4px;
  }
  .date-row .date-cat{
    font-family:var(--sans);font-weight:500;font-size:11px;
    letter-spacing:0.1em;text-transform:uppercase;color:var(--stein);
  }
  .date-row.highlight .date-main{color:var(--bordeaux);}

  /* ---------- Was uns auszeichnet (Collage) ---------- */
  .pillars-section{
    background:
      radial-gradient(ellipse at 15% 10%, rgba(127,176,105,0.08), transparent 45%),
      radial-gradient(ellipse at 85% 90%, rgba(212,165,116,0.10), transparent 50%),
      var(--creme);
    padding:60px 0 70px;
    position:relative;
    overflow:hidden;
  }
  .pillars-section::before{
    content:"";position:absolute;inset:0;
    background-image:
      radial-gradient(circle at 25% 30%, rgba(14,77,79,0.025) 1px, transparent 1px),
      radial-gradient(circle at 75% 70%, rgba(110,38,57,0.02) 1px, transparent 1px);
    background-size:24px 24px, 32px 32px;
    pointer-events:none;opacity:0.6;
  }
  .pillars-head{text-align:center;max-width:760px;margin:0 auto 72px;position:relative;}
  .pillars-head .eyebrow{display:block;margin-bottom:16px;}
  .pillars-head h2{
    font-family:var(--serif);font-weight:500;font-size:42px;line-height:1.15;
    letter-spacing:-0.02em;color:var(--petrol);
  }
  .pillars-collage{
    position:relative;max-width:1100px;margin:0 auto;
    display:grid;
    grid-template-columns:1fr 1fr;
    gap:28px;
  }
  .pillar-card{
    position:relative;overflow:hidden;isolation:isolate;
    background:var(--offwhite);
    border:1px solid var(--hairline);
    border-radius:24px;
    padding:40px 36px;
    display:flex;flex-direction:column;gap:20px;
    box-shadow:0 10px 30px -20px rgba(14,77,79,0.22);
    transition:transform .3s ease, box-shadow .3s ease;
    min-height:280px;
  }
  /* Background image overlay — driven by Tweaks */
  .pillars-section[data-bg-images="on"] .pillar-card::before{
    content:"";position:absolute;inset:0;z-index:-1;
    background-image:var(--card-bg, none);
    background-size:cover;background-position:center;
    opacity:var(--card-bg-opacity, 0.15);
    transition:opacity .3s ease;
    pointer-events:none;
  }
  .pillars-section[data-bg-images="on"] .pillar-card > *{position:relative;}
  /* Assign per-card image */
  .pillar-unesco{--card-bg:url("/unesco-schule-essen-homepage/assets/pillar-unesco.jpg");}
  .pillar-profile{--card-bg:url("/unesco-schule-essen-homepage/assets/pillar-profil.jpg");}
  .pillar-abitur{--card-bg:url("/unesco-schule-essen-homepage/assets/pillar-abitur.jpg");}
  .pillar-quote{--card-bg:url("/unesco-schule-essen-homepage/assets/pillar-quote.jpg");}
  /* Quote card: when bg image is on, darken slightly so text stays readable */
  .pillars-section[data-bg-images="on"] .pillar-quote::after{
    content:"";position:absolute;inset:0;z-index:-1;
    background:rgba(250,247,241,0.55);
    pointer-events:none;
  }
  .pillar-card:hover{
    transform:translateY(-2px);
    box-shadow:0 18px 40px -22px rgba(14,77,79,0.3);
  }
  .pillar-card .icon{width:36px;height:36px;color:var(--bordeaux);}
  .pillar-card h3{
    font-family:var(--serif);font-weight:500;font-size:24px;line-height:1.2;
    color:var(--petrol);letter-spacing:-0.005em;margin:0 0 10px;
  }
  .pillar-card p{font-size:15px;color:var(--stein);line-height:1.6;}

  .pillar-profile{background:var(--petrol);color:var(--creme);border-color:var(--petrol);}
  .pillar-profile h3{color:var(--creme);}
  .pillar-profile p{color:rgba(245,239,231,0.82);}
  .pillar-profile .icon{color:var(--gold);}

  .pillar-quote{
    background:var(--creme);
    border:1px solid var(--hairline);
    display:flex;align-items:center;justify-content:center;
    text-align:center;padding:40px 36px;
    transform:rotate(-1.2deg);
  }
  .pillar-quote:hover{transform:rotate(-1.2deg) translateY(-2px);}
  .pillar-quote blockquote{
    margin:0;
    font-family:var(--serif);font-weight:400;font-style:italic;
    font-size:clamp(22px,2vw,28px);line-height:1.25;letter-spacing:-0.01em;
    color:var(--petrol);
  }
  .pillar-quote blockquote::before{
    content:"\201E";
    display:block;font-family:var(--serif);font-size:72px;line-height:0.4;
    color:var(--bordeaux);opacity:0.5;margin-bottom:14px;
  }
  .pillar-quote cite{
    display:block;margin-top:16px;
    font-family:var(--sans);font-style:normal;font-size:11px;
    letter-spacing:0.2em;text-transform:uppercase;color:var(--stein);
  }

  @media (max-width:680px){
    .pillars-collage{grid-template-columns:1fr;}
    .pillar-quote{transform:none;}
  }

  /* ---------- Voice (Quote) ---------- */
  .voice-section{padding:30px 0;}
  .voice-grid{
    display:grid;grid-template-columns:minmax(0,5fr) minmax(0,7fr);gap:72px;align-items:center;
  }
  .voice-photo{
    aspect-ratio:4/5;overflow:hidden;background:var(--creme);border-radius:2px;
    filter:grayscale(100%) contrast(1.02);
  }
  .voice-photo img{width:100%;height:100%;object-fit:cover;}
  .voice-text .eyebrow{display:block;margin-bottom:24px;}
  .voice-quote{
    font-family:var(--serif);font-style:italic;font-weight:400;
    font-size:clamp(26px,2.2vw,32px);line-height:1.35;
    color:var(--petrol);
    letter-spacing:-0.005em;
    margin-bottom:32px;
  }
  .voice-quote .mark{color:var(--bordeaux);font-style:normal;}
  .voice-attrib{
    border-left:2px solid var(--bordeaux);padding-left:16px;
  }
  .voice-attrib .name{
    font-family:var(--sans);font-weight:600;font-size:14px;color:var(--tinte);
  }
  .voice-attrib .role{
    font-family:var(--sans);font-weight:500;font-size:11.5px;
    letter-spacing:0.1em;text-transform:uppercase;color:var(--stein);margin-top:3px;
  }

  /* ---------- Dein Weg zu uns ---------- */
  .path-section{background:var(--creme);padding:120px 0 60px;}
  .path-head{margin-bottom:56px;max-width:620px;}
  .path-head .eyebrow{display:block;margin-bottom:14px;}
  .path-head h2{font-size:36px;}
  .path-head p{font-size:17px;color:var(--stein);margin-top:16px;line-height:1.55;}
  .path-grid{
    display:grid;grid-template-columns:repeat(3,1fr);gap:32px;
  }
  .path-card{
    background:#fff;border:1px solid var(--hairline);border-radius:4px;
    padding:36px 32px;display:flex;flex-direction:column;gap:16px;
    min-height:100%;
  }
  .path-card .kicker{
    font-family:var(--sans);font-weight:500;font-size:11.5px;
    letter-spacing:0.1em;text-transform:uppercase;color:var(--stein);
  }
  .path-card h3{
    font-family:var(--serif);font-weight:500;font-size:24px;
    color:var(--petrol);letter-spacing:-0.01em;line-height:1.2;
  }
  .path-card .big-date{
    font-family:var(--serif);font-weight:500;font-size:40px;line-height:1;
    color:var(--petrol);letter-spacing:-0.015em;
  }
  .path-card .big-date small{display:block;font-size:14px;font-family:var(--sans);font-weight:500;color:var(--stein);margin-top:10px;letter-spacing:0.04em;}
  .path-card p{font-size:15px;color:var(--tinte);line-height:1.55;flex:1;}
  .path-card .contact-line{font-family:var(--sans);font-weight:500;font-size:17px;color:var(--petrol);line-height:1.5;}
  .path-card .contact-line a{color:var(--petrol);text-decoration:none;}
  .path-card .contact-line a:hover{text-decoration:underline;}
  .path-card .btn{align-self:flex-start;margin-top:auto;}

  /* ---------- Kooperationen & Partner (Logo-Leiste) ---------- */
  .partners-section{
    background:var(--offwhite);
    padding:60px 0;
    border-top:1px solid var(--hairline);
  }
  .partners-head{max-width:760px;margin-bottom:48px;}
  .partners-head .eyebrow{display:block;margin-bottom:14px;}
  .partners-head h2{font-size:36px;margin-bottom:16px;}
  .partners-head p{color:var(--stein);font-size:17px;line-height:1.6;}
  .partners-logos{
    list-style:none;margin:0;padding:40px 0 0;
    display:grid;grid-template-columns:repeat(5,1fr);
    gap:16px 20px;align-items:center;
    border-top:1px solid var(--hairline);
  }
  .partner-logo{
    display:flex;align-items:center;justify-content:center;
    height:88px;padding:8px;
    filter:grayscale(100%) opacity(0.72);
    transition:filter .3s ease, transform .3s ease;
  }
  .partner-logo:hover{
    filter:grayscale(0) opacity(1);
    transform:scale(1.18);
    z-index:2;position:relative;
  }
  .partner-logo img{max-height:100%;max-width:100%;width:auto;height:auto;object-fit:contain;}
  .partners-foot{margin-top:36px;}

  @media (max-width:960px){
    .partners-section{padding:36px 0;}
    .partners-logos{grid-template-columns:repeat(3,1fr);gap:12px;}
  }
  @media (max-width:560px){
    .partners-logos{grid-template-columns:repeat(2,1fr);}
  }

  /* ---------- Footer ---------- */
  footer.site-footer{
    background:var(--petrol);
    color:var(--creme);
    padding:80px 0 36px;
  }
  .footer-grid{
    display:grid;grid-template-columns:1.2fr 1fr 1fr;gap:64px;
  }
  .footer-col h4{
    font-family:var(--sans);font-size:11px;font-weight:600;
    letter-spacing:0.16em;text-transform:uppercase;
    color:rgba(245,239,231,0.6);
    margin-bottom:20px;
  }
  .footer-col ul{list-style:none;margin:0;padding:0;}
  .footer-col li{margin-bottom:10px;}
  .footer-col a{color:var(--creme);font-size:14.5px;text-decoration:none;border-bottom:1px solid transparent;transition:border-color .2s;}
  .footer-col a:hover{border-bottom-color:var(--creme);}
  .footer-brand .footer-logo{
    margin-bottom:28px;
  }
  .footer-brand .footer-logo{display:inline-block;cursor:pointer;max-width:100%;}
  .footer-brand .footer-logo .logo-stack{
    position:relative;display:block;width:100%;max-width:360px;
    transition:transform .3s ease;
  }
  .footer-brand .footer-logo .logo-stack img{
    display:block;width:100%;height:auto;max-width:360px;
    transition:opacity .35s ease, filter .35s ease;
  }
  .footer-brand .footer-logo .logo-bw{filter:brightness(0) invert(1);}
  .footer-brand .footer-logo .logo-color{position:absolute;inset:0;opacity:0;}
  .footer-brand .footer-logo:hover .logo-stack{transform:scale(1.02);}
  .footer-brand .footer-logo:hover .logo-bw{opacity:0;}
  .footer-brand .footer-logo:hover .logo-color{opacity:1;}
  .footer-brand address{
    font-style:normal;font-size:14.5px;line-height:1.7;color:rgba(245,239,231,0.9);
  }
  .footer-brand address a{color:rgba(245,239,231,0.9);}
  .socials{display:flex;gap:12px;margin-top:20px;}
  .socials a{
    width:36px;height:36px;border:1px solid rgba(245,239,231,0.25);
    border-radius:50%;display:inline-flex;align-items:center;justify-content:center;
    color:var(--creme);
  }
  .socials a:hover{background:rgba(245,239,231,0.08);border-color:rgba(245,239,231,0.5);}
  .footer-bottom{
    margin-top:56px;padding-top:24px;
    border-top:1px solid rgba(245,239,231,0.15);
    display:flex;justify-content:space-between;align-items:center;flex-wrap:wrap;gap:16px;
    font-size:13px;color:rgba(245,239,231,0.6);
  }

  /* ---------- Mobile Menu Backdrop ---------- */
  .nav-backdrop{
    position:fixed;inset:0;z-index:900;
    background:rgba(10,54,56,0.45);
    backdrop-filter:blur(3px);
    -webkit-backdrop-filter:blur(3px);
    opacity:0;visibility:hidden;pointer-events:none;
    transition:opacity .25s ease, visibility .25s ease;
  }
  .nav-backdrop.is-visible{opacity:1;visibility:visible;pointer-events:auto;}
  body.nav-open{overflow:hidden;}

  /* ---------- Responsive ---------- */
  @media (max-width:1080px){
    /* Mobile: Logo zentriert, Hamburger oben rechts, Menü als Drawer */
    .header-inner{padding:14px var(--pad-mob) 12px;gap:0;}
    .logo .logo-stack,
    .logo .logo-stack img{height:64px;}
    .site-header[data-scrolled="true"] .logo .logo-stack,
    .site-header[data-scrolled="true"] .logo .logo-stack img{height:32px;}
    .nav-row{display:contents;}
    .header-actions{display:none;}
    .hamburger{display:block;}

    /* Full-Screen Mobile-Drawer von rechts.
       Höhe per JS-CSS-Variable --header-h gesetzt, weil sich die
       Header-Höhe je nach Logo-Höhe unterscheidet. */
    .main-nav{
      position:fixed;top:var(--header-h, 92px);right:0;bottom:auto;
      width:min(360px, 86vw);left:auto;
      height:calc(100vh - var(--header-h, 92px));
      height:calc(100dvh - var(--header-h, 92px));
      background:var(--offwhite);
      flex-direction:column;align-items:stretch;
      max-height:none;overflow-y:auto;overscroll-behavior:contain;
      transform:translateX(100%);
      transition:transform .3s cubic-bezier(0.2,0.8,0.2,1);
      border-top:1px solid var(--hairline);
      border-left:1px solid var(--hairline);
      box-shadow:-12px 0 32px -16px rgba(10,54,56,0.22);
      z-index:950;
    }
    .main-nav.open{transform:translateX(0);}

    .nav-list{flex-direction:column;height:auto;gap:0;padding:8px 0 24px;}
    .nav-item{display:block;border-bottom:1px solid var(--hairline);}
    .nav-link{
      height:auto;padding:18px 22px;justify-content:space-between;
      border-bottom:0;width:100%;
      font-size:18px;font-weight:500;
    }
    /* Chevron statt „+ / −" — dezenter und weniger „Formular-mäßig" */
    .nav-item.has-dropdown > .nav-link::after{
      content:"";display:inline-block;width:10px;height:10px;
      border-right:1.5px solid var(--petrol);border-bottom:1.5px solid var(--petrol);
      transform:rotate(45deg) translate(-2px,-2px);
      transition:transform .2s ease;margin-right:6px;flex-shrink:0;
    }
    .nav-item.has-dropdown.open > .nav-link::after{
      transform:rotate(-135deg) translate(-4px,-4px);
    }
    .dropdown-mega,
    .nav-item:hover > .dropdown-mega,
    .nav-item:focus-within > .dropdown-mega{
      position:static;display:block;grid-template-columns:1fr;
      opacity:1;visibility:visible;pointer-events:auto;transform:none;
      border:0;min-width:0;padding:0;max-height:0;overflow:hidden;
      background:var(--creme);
      transition:max-height .3s ease;
    }
    .nav-item.open > .dropdown-mega{max-height:2000px;padding:8px 0 16px;}
    .mega-col{padding:6px 22px;}
    .mega-col h4{
      font-size:10.5px;letter-spacing:0.14em;color:var(--bordeaux);
      padding-top:10px;padding-bottom:8px;margin-bottom:6px;
      border-bottom:1px solid var(--hairline);
    }
    .mega-col li a{font-size:15px;padding:9px 0;}

    /* Footer der Mobile-Navigation: Kalender + Kontakt als Kacheln */
    .nav-footer{
      display:grid;grid-template-columns:1fr 1fr;gap:10px;
      padding:12px 22px 8px;
      border-top:1px solid var(--hairline);
      background:var(--offwhite);
    }
    .nav-footer a{
      display:flex;align-items:center;justify-content:center;gap:8px;
      padding:14px 10px;
      font-family:var(--sans);font-weight:500;font-size:14px;
      color:var(--creme);background:var(--petrol);
      text-decoration:none;
      transition:background .2s;
    }
    .nav-footer a + a{background:var(--bordeaux);}
    .nav-footer a:hover{background:var(--petrol-dark);}
    .nav-footer a + a:hover{background:#581e2d;}
  }
  @media (min-width:1081px){
    /* Desktop: nav-footer versteckt */
    .nav-footer{display:none;}
  }
  @media (max-width:960px){
    /* Container-Padding auch auf Tablets reduzieren */
    .container{padding:0 24px;}

    .hero{padding:56px 0 var(--space-section-sm);}
    .hero-grid{grid-template-columns:1fr;gap:28px;}
    .hero-photo{aspect-ratio:4/3;max-height:480px;}
    .hero-sub{font-size:17px;line-height:1.55;}
    section{padding:var(--space-section-sm) 0;}

    /* News-Dates: News oben, Termine darunter */
    .news-dates{grid-template-columns:1fr;gap:40px;}
    .news-dates > div, .news-dates > aside{
      padding:24px 24px 28px;
    }

    /* News-Cards: stacked — Bild oben, Text unten (wie Desktop, aber 1 Spalte) */
    .news-list{grid-template-columns:1fr;gap:28px;}
    .news-card{display:flex;flex-direction:column;gap:14px;}
    .news-card .thumb{aspect-ratio:16/10;border-radius:2px;}
    .news-card h3{font-size:19px;}
    .news-card .excerpt{
      display:-webkit-box;-webkit-box-orient:vertical;-webkit-line-clamp:3;
      overflow:hidden;font-size:15px;line-height:1.55;
    }
    /* Featured auf Mobile: dieselbe stacked-Struktur, leicht größerer Titel */
    .news-list .news-card.featured{
      grid-column:auto;grid-template-columns:1fr;gap:14px;align-items:stretch;
    }
    .news-list .news-card.featured .thumb{aspect-ratio:16/10;}
    .news-list .news-card.featured h3{
      font-size:22px;font-family:var(--serif);font-weight:500;letter-spacing:-0.005em;
    }
    .news-list .news-card.featured .excerpt{-webkit-line-clamp:3;font-size:15.5px;}

    /* Section-Head: Titel und „Alle Beiträge"-Link untereinander */
    .section-head{flex-direction:column;align-items:flex-start;gap:10px;margin-bottom:24px;}
    .section-head .all-link{white-space:normal;}

    /* Pillars — eine Spalte bereits ab 960px */
    .pillars,.pillars-collage{grid-template-columns:1fr;gap:20px;}
    .pillar-card{padding:28px 24px;min-height:auto;}
    .pillar-quote{transform:none;}
    .pillar-quote:hover{transform:none;}

    .voice-grid{grid-template-columns:1fr;gap:32px;}
    .voice-photo{max-width:360px;aspect-ratio:4/5;}
    .path-grid{grid-template-columns:1fr;}
    .path-section{padding:var(--space-section-sm) 0;}

    /* Date-Row: knapperer Datums-Spalter */
    .date-row{grid-template-columns:72px 1fr;gap:14px;padding:18px 0;}
    .date-row .date-main{font-size:22px;}

    .footer-grid{grid-template-columns:1fr 1fr;gap:28px 32px;}
    .footer-brand{grid-column:1 / -1;}
    .footer-brand .footer-logo .logo-stack,
    .footer-brand .footer-logo .logo-stack img{max-width:280px;}
    .footer-brand address{font-size:14px;}
    .footer-col h4{margin-bottom:14px;}
    .footer-col li{margin-bottom:8px;}
    .footer-col a{font-size:13.5px;}
    .footer-bottom{margin-top:36px;font-size:12px;flex-direction:column;align-items:flex-start;gap:8px;}
    .site-footer{padding:56px 0 28px;}
  }
  @media (max-width:560px){
    .container{padding:0 var(--pad-mob);}
    h2{font-size:26px;}
    .pillars-head h2,.path-head h2{font-size:28px;}
    .pillars-quote{font-size:21px;}
    .voice-quote{font-size:22px;}
    /* Hero-CTA-Row vertikal stapeln */
    .hero-cta-row{flex-direction:column;align-items:flex-start;gap:14px;}
  }

  /* ---------- Tweaks panel ---------- */
  .tweaks-panel{
    position:fixed;bottom:20px;right:20px;z-index:2000;
    background:#fff;border:1px solid var(--hairline);border-radius:6px;
    padding:18px 20px;width:300px;
    font-family:var(--sans);font-size:13px;
    box-shadow:0 8px 28px rgba(14,77,79,0.12);
    display:none;
  }
  .tweaks-panel.open{display:block;}
  .tweaks-panel h5{
    font-family:var(--sans);font-size:11px;font-weight:600;
    letter-spacing:0.14em;text-transform:uppercase;color:var(--petrol);
    margin:0 0 14px;
  }
  .tweak-row{margin-bottom:14px;}
  .tweak-row label{display:block;font-weight:500;margin-bottom:6px;color:var(--tinte);}
  .tweak-row select, .tweak-row input[type=text]{
    width:100%;padding:7px 9px;border:1px solid var(--hairline);
    border-radius:3px;background:#fff;font-family:var(--sans);font-size:13px;
  }
</style>
<slot name="head" />
